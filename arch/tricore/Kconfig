menu "TriCore Architecture Options"
	depends on TRICORE

config ARCH
	string
	default "tricore"

config CPU_TC162
	select ARCH_HAS_NOCACHE_MEMORY_SUPPORT
	select CPU_HAS_DCACHE
	select CPU_HAS_ICACHE
	select CPU_CACHE_INCOHERENT
	select CPU_HAS_FPU
	imply FPU
	bool

config CPU_TC18
	select ARCH_HAS_NOCACHE_MEMORY_SUPPORT
	select CPU_HAS_DCACHE
	select CPU_HAS_ICACHE
	select CPU_CACHE_INCOHERENT
	bool

config TRICORE_CSA_COUNT
	int "Number of Context Save Areas allocated"
	default 256
	help
		This option controls the number of Context Save Areas (CSAs) allocated by the
		kernel. CSAs are used to store the upper and lower context information during
		function calls and interrupts. The default value of 256 is typically sufficient
		for most applications, but it can be increased if your application has a large
		number of nested function calls, interrupts or threads.

config TRICORE_RESET_TRAMPOLINE
	bool "Trampoline to jump to cached address"
	default y
	help
		Enable startup trampoline function which jumps from
		any address (e.g. no cached) to the actual startup
		function.

menu "TriCore Processor Options"

if CPU_TC18
config CPU_HAS_TRICORE_VIRTUALIZATION
	bool
	default n

config TRICORE_VIRTUALIZATION
	bool "TriCore Virtualization Support"
	depends on CPU_HAS_TRICORE_VIRTUALIZATION
	default n
	help
		When enabled, the kernel will use the virtualization features of the TriCore
		architecture to support running multiple virtual machines (VMs) on the same
		hardware. Each VM can run its own instance of the operating system or
		applications, providing isolation and security between them. This option is
		only available on CPUs that support TriCore virtualization.

config TRICORE_VM_ID
	int "TriCore Virtual Machine ID"
	depends on TRICORE_VIRTUALIZATION
	default 0
	help
		This option specifies the ID of the virtual machine (VM) that the kernel will
		run on when TriCore virtualization is enabled.
		 * VM0 is the hypervisor VM, which is responsible for managing the other VMs
		and providing access to shared resources. It has dedicated hardware resources
		(HRHV) and is responsible for handling hvcall instructions and IRQ requests
		for VM2 - VM7.
		 * VM1 is the real-time VM, which is designed for running real-time applications
		that require low-latency and deterministic behavior. It has dedicated hardware
		resources (HRA). IRQs mapped to VM1 are handled directly by the CPU and
		do not trigger the hypervisor.
		 * VM2 - VM7 are general-purpose VMs that can be used for running various
		applications. They share a common hardware resource (HRB) and rely on the
		hypervisor to schedule their execution. IRQs mapped to a VM that is not loaded
		in HRB trigger the hypervisor.
endif

endmenu

config DCACHE_LINE_SIZE
	default 32

config ICACHE_LINE_SIZE
	default 32

config GEN_ISR_TABLES
	default y

config GEN_IRQ_VECTOR_TABLE
	default n

config NUM_IRQ_PRIORITIES
	int
	default 256

endmenu
