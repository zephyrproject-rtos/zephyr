config MP_PLUGIN_ZJPEG
	bool "JPEG plugin support"

if MP_PLUGIN_ZJPEG

config MP_ZJPEG_PARSER_MAX_FRAME_SIZE
	int "Maximum JPEG frame size in bytes"
	default 0
	help
	  Maximum size of a single JPEG frame that the parser can accumulate when
	  downstream does not provide a usable pool.
	  Default value is set to 0 to disable the internal staging pool entirely
	  (no memory reserved).

config MP_ZJPEG_PARSER_POOL_NUM
	int "Staging pool buffer count"
	range 1 255
	default 2
	help
	  Number of buffers in the parser's internal staging pool.
	  2 is usually enough (one partial, one output).

config MP_ZJPEG_DECODER_POOL_NUM
	int "Number of buffers in the jpeg decoder's output pool"
	range 1 255
	default 1

config MP_ZJPEG_DECODER_MAX_OUT_FRAME_SIZE
	int "Maximum decoded output frame size in bytes"
	default 153600
	help
	  Maximum decoded output frame size in bytes for the SW JPEG decoder internal pool.
	  Default value is set for 320x240 RGB565 format.

config MP_ZJPEG_ENCODER
	bool "Software JPEG encoder element"
	help
	  Build the software JPEG encoder element (mp_zjpeg_encoder) and the
	  vendored bitbank JPEGENC library (jpeg_enc.c). The encoder accepts RGB565
	  frames on its sink pad and produces JPEG frames on its source pad.

config MP_ZJPEG_ENCODER_POOL_NUM
	int "Number of buffers in the jpeg encoder's output pool"
	depends on MP_ZJPEG_ENCODER
	range 1 255
	default 2
	help
	  Number of buffers in the SW JPEG encoder's internal output pool.
	  2-3 buffers allow pipelining (one being filled, one in flight).

config MP_ZJPEG_ENCODER_MAX_OUT_FRAME_SIZE
	int "Maximum encoded output frame size in bytes"
	depends on MP_ZJPEG_ENCODER
	default 153600
	help
	  Maximum encoded JPEG frame size in bytes for the SW JPEG encoder internal
	  pool. JPEG output is variable in size; this is a safe upper bound sized to
	  the raw RGB565 frame (W * H * 2), since the compressed output is smaller
	  than the raw input at these quality levels. Default is set for 320x240
	  RGB565. The library reserves a 512-byte high-water margin and requires a
	  buffer of at least 1024 bytes.

endif # MP_PLUGIN_ZJPEG
