config MP_PLUGIN_ZAUD
	bool "Audio plugin support"
	select AUDIO

if MP_PLUGIN_ZAUD

config MP_ZAUD_BUFFER_POOL_SZ_MAX
	int "Size of the largest buffer in the buffer pool"
	default 98304

config MP_ZAUD_BUFFER_POOL_NUM_MAX
	int "Number of maximum sized buffers in the buffer pool"
	default 10

config MP_ZAUD_I2S_CODEC_SINK_SILENCE_PRIME
	bool "Prime the I2S TX with silence and start it at PLAYING"
	help
	  Start the I2S TX with silence buffers when the pipeline reaches
	  PLAYING instead of waiting for buffers from upstream. Needed when the
	  capture source's receiver is clock-synced to this sink's transmitter,
	  for example a codec whose ADC shares the DAC frame clock: the source
	  produces nothing until the transmitter runs, so a source-first
	  pipeline would deadlock. Leave this off for self-clocked sources such
	  as a DMIC.

config MP_ZAUD_I2S_CODEC_SINK_SILENCE_PRIME_COUNT
	int "Number of silence buffers to prime the TX with"
	default 6
	depends on MP_ZAUD_I2S_CODEC_SINK_SILENCE_PRIME
	help
	  How many silence buffers to queue before starting the transmitter.
	  These bridge the startup latency until the capture source delivers
	  its first block; too few and the transmitter underruns before real
	  audio arrives. Must not exceed the I2S TX queue depth, and the buffer
	  pool has to hold this many on top of the capture ring.

config MP_ZAUD_I2S_CODEC_SINK_SET_OUTPUT_VOLUME
	bool "Set codec output volume in the I2S codec sink"
	help
	  When enabled, the I2S codec sink programs the codec output volume
	  after configuring it. Without this, the codec keeps its driver
	  default (typically 0 dB / unity), which can overdrive the analog
	  output stage and sound distorted on boards with a fixed line/speaker
	  amplifier.

config MP_ZAUD_I2S_CODEC_SINK_OUTPUT_VOLUME
	int "Codec output volume (codec-specific units)"
	default 106
	depends on MP_ZAUD_I2S_CODEC_SINK_SET_OUTPUT_VOLUME
	help
	  Output volume value passed to audio_codec_set_property() as the
	  AUDIO_PROPERTY_OUTPUT_VOLUME for AUDIO_CHANNEL_ALL. The units are
	  codec specific. For the WM8962 the field is 7 bits where 121 (0x79)
	  is 0 dB, each step is 1 dB and values up to and including 47 (0x2F)
	  mute the output. The default of 106 is approximately -15 dB.

endif # MP_PLUGIN_ZAUD
