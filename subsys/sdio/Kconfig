# Role-neutral SDIO subsystem configuration

menuconfig SDIO
	bool "Role-neutral SDIO subsystem"
	help
	  Enable the standalone, role-neutral SDIO subsystem. Unlike the
	  SD-card centered SDIO protocol support (SDIO_STACK), this subsystem
	  models SDIO as a general transport with explicit host and
	  device/slave roles, decoupled from struct sd_card.

if SDIO

module = SDIO
module-str = SDIO subsystem
source "subsys/logging/Kconfig.template.log_config"

config SDIO_LOCK_TIMEOUT_MS
	int "SDIO bus lock timeout (ms)"
	default 500
	help
	  Maximum time to wait for the per-endpoint bus lock when issuing a
	  function I/O operation.

endif # SDIO
