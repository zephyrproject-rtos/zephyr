menuconfig GRAPHIC
	bool "GRAPHIC subsystem"
	select GRAPHIC_DRIVERS
	help
	  Enable support for the graphic subsystem as well as graphic drivers.

if GRAPHIC

module = GRAPHIC
module-str = graphic
source "subsys/logging/Kconfig.template.log_config"

config GRAPHIC_SHELL
	bool "Graphic shell"
	depends on SHELL

endif # GRAPHIC
