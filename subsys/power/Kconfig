menu "Power"

config POWER
	bool

config POWER_QOS
	bool "Power QoS constraints"
	select POWER
	help
	  Enable common power constraint aggregation helpers. The first supported
	  constraints are CPU P-state minimum and maximum requests. The helper only
	  aggregates requests and reports conflicts; resource policies remain
	  responsible for selecting and applying hardware states.

config POWER_ENERGY_MODEL
	bool "Power energy model helper"
	depends on CPU_FREQ
	select POWER
	help
	  Enable common energy-score helpers for power and CPU frequency policies.
	  The helper computes comparable active, transition and idle scores from
	  already collected workload, P-state and PM idle-state facts. It does not
	  choose P-states or idle states.

endmenu
