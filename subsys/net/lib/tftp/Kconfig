config TFTP_LIB
	bool "Socket TFTP Library Support [EXPERIMENTAL]"
	select EXPERIMENTAL
	select NET_SOCKETS
	help
	  Enable the Zephyr TFTP Library

if TFTP_LIB

module=TFTP
module-dep=NET_LOG
module-str=Log level for TFTP
module-help=Enables tftp debug messages.
source "subsys/net/Kconfig.template.log_config.net"

config TFTPC_REQUEST_TIMEOUT
	int "Maximum amount of time the TFTP Client will wait for a response from the server."
	default 5000
	help
	  Maximum amount of time (in msec) that the TFTP Client will wait for
	  data from the TFTP Server. Once this time has elapsed, the TFTP Client
	  will assume that the Server failed and close the connection.

config TFTPC_REQUEST_RETRANSMITS
	int "Number of times the TFTP Client will retransmit the request to the server."
	default 5
	help
	  Once the TFTP Client sends out a request, it will wait
	  TFTPC_REQUEST_TIMEOUT msecs for the data to arrive from the TFTP Server.
	  However, if it doesn't arrive within the given time we will re-transmit
	  the request to the server in hopes that the server will respond within
	  time to this request. This number dictates the number of times we will
	  do re-tx of our request before giving up and exiting.

config TFTPS
	bool "TFTP Server Support [EXPERIMENTAL]"
	select FILE_SYSTEM
	help
	  Enable the Zephyr TFTP Server implementation.
	  The server supports multiple concurrent clients, serves files from
	  all mounted file systems, and supports UDP socket and serial transports.

if TFTPS

config TFTPS_MAX_CLIENTS
	int "Maximum number of concurrent TFTP client connections"
	default 1
	help
	  Maximum number of concurrent client connections the TFTP server
	  can handle simultaneously. Each client connection requires a
	  session structure.

config TFTPS_REQUEST_TIMEOUT
	int "TFTP Server request timeout in milliseconds"
	default 5000
	help
	  Maximum amount of time (in milliseconds) that the TFTP server
	  will wait for client packets before timing out a session.
	  Sessions that timeout are automatically cleaned up.

config TFTPS_POLL_TIMEOUT_MS
	int "TFTP Server polling timeout in milliseconds"
	default 100
	help
	  Interval (in milliseconds) that the server checks for events
	  on active sockets. This also impacts the granularity of session timeouts.

config TFTPS_MAX_RETRIES
	int "Maximum number of retries for TFTP operations"
	default 5
	help
	  Maximum number of times the server will retry failed operations
	  before giving up.

config TFTPS_STACK_SIZE
	int "TFTP Server thread stack size"
	default 2048
	help
	  Stack size for the TFTP server thread. Increase this if you
	  experience stack overflow issues with large file transfers
	  or many concurrent clients.

endif # TFTPS

endif # TFTP_LIB
