DT_COMPAT_INTEL_ADSP_IPC := intel,adsp-host-ipc

config IPC_MSG_BACKEND_INTEL_ADSP_IPC
	bool "Backend for the Intel Audio DSP IPC"
	default $(dt_compat_enabled,$(DT_COMPAT_INTEL_ADSP_IPC)) if !SOF
	help
	  Backend for Intel Audio DSP IPC.

	  Note that this is currently not used SOF as its own driver for this hardware.
