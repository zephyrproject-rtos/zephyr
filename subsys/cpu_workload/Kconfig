menuconfig CPU_WORKLOAD
	bool "CPU Workload Estimator"
	select EXPERIMENTAL
	help
	  CPU workload estimator signals and aggregation helpers. This subsystem
	  provides forward-looking workload estimates for CPU frequency and power
	  policies. It consumes lower-level signals such as CPU load history and
	  per-thread runtime profiles, but does not select frequencies or idle states.

if CPU_WORKLOAD

module = CPU_WORKLOAD
module-str = CPU Workload Estimator
source "subsys/logging/Kconfig.template.log_config"

config CPU_WORKLOAD_READY_BACKLOG
	bool "CPU ready backlog workload signal"
	select THREAD_MONITOR
	select THREAD_RUNTIME_STATS
	select SCHED_THREAD_USAGE
	select SCHED_THREAD_USAGE_AUTO_ENABLE
	select CPU_WORKLOAD_THREAD_PROFILE
	help
	  Estimate runnable backlog work by scanning runnable threads and summing
	  their per-thread CPU burst profiles. This exposes the first forward-looking
	  workload signal for CPU frequency and power policies.

config CPU_WORKLOAD_READY_BACKLOG_MIN_CONFIDENCE
	int "Minimum thread profile confidence for ready backlog"
	default 20
	range 0 100
	depends on CPU_WORKLOAD_READY_BACKLOG
	help
	  Minimum per-thread burst profile confidence required before that profile
	  contributes its average burst cycles to the ready backlog.

config CPU_WORKLOAD_READY_BACKLOG_FALLBACK_CYCLES
	int "Fallback cycles for unprofiled ready threads"
	default 0
	range 0 2147483647
	depends on CPU_WORKLOAD_READY_BACKLOG
	help
	  Conservative fallback cycles added for each runnable thread whose burst
	  profile is missing or below the configured confidence threshold. A value
	  of 0 reports only profiled work.

config CPU_WORKLOAD_ARRIVAL_PROFILE
	bool "CPU wakeup-arrival workload signal"
	select THREAD_MONITOR
	select THREAD_RUNTIME_STATS
	select SCHED_THREAD_USAGE
	select SCHED_THREAD_USAGE_AUTO_ENABLE
	select CPU_WORKLOAD_THREAD_PROFILE
	help
	  Attribute thread wakeups to arrival sources and estimate the expected
	  cycles from those arrivals using per-thread burst profiles. This provides
	  a forward-looking signal for work that arrived since the previous query.

config CPU_WORKLOAD_WORK_PROFILE
	bool "CPU k_work handler workload profile"
	help
	  Track a lightweight per-work-item handler profile from workqueue dispatch.
	  The profile maintains an EWMA of handler execution time in CPU cycles,
	  plus a warm-up sample count and confidence value. This distinguishes work
	  items processed by the same workqueue thread so policies can use the real
	  cost of the next queued handler.

config CPU_WORKLOAD_WORK_PROFILE_EWMA_SHIFT
	int "k_work handler workload EWMA shift"
	default 3
	range 1 8
	depends on CPU_WORKLOAD_WORK_PROFILE
	help
	  Shift used by the k_work handler EWMA. A value of 3 gives alpha = 1/8,
	  using avg = ((7 * avg) + handler_cycles) / 8. Smaller values react faster;
	  larger values smooth more aggressively.

endif # CPU_WORKLOAD
