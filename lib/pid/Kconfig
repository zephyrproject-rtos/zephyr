config PID_CONTROLLER
	bool "PID controller library"
	help
	  Generic discrete PID controller with anti-windup, using
	  Q16.16 fixed-point arithmetic. Suitable for motor control,
	  thermal regulation, and other feedback control applications.
	  No FPU or kernel dependencies required.
