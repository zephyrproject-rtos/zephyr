&sram0 {
	/* Sized so the demand_paging arena exceeds the backing store after
	 * accounting for the kernel image (which can grow with unity builds
	 * or future kernel changes); see test_k_mem_page_out().
	 */
	reg = <0x0 0x40000000 0x0 0x76000>;
};
