/ {
	euart0: uart-emul {
		compatible = "zephyr,uart-emul";
		status = "okay";
		current-speed = <115200>;
		rx-fifo-size = <256>;
		tx-fifo-size = <256>;
	};

	test_proxy_agent: test-proxy-agent {
		compatible = "zephyr,zbus-proxy-agent-uart";
		uart-device = <&euart0>;
		status = "disabled";     /* Disabled so the proxy agent is not auto-started */
	};
};
