&flash0 {
	partitions {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		slot1_partition: partition@80000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0x00080000 0x00080000>;
		};
	};
};
