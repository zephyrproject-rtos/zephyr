/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
	};

	aliases {
		sdhc0 = &sdhc;
	};
};

&usbotg_fs {
	status = "okay";
	pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12>;
	pinctrl-names = "default";

	cdc_acm_uart0: cdc_acm_uart0 {
		status = "okay";
		compatible = "zephyr,cdc-acm-uart";
	};
};

&cdc_acm_uart0 {
	status = "okay";
};

&wifi {
	status = "disabled";
};

&sdhc {
	hw-flow-control;
	bus-width = <4>;
	sdhi-on-gpios = <&gpiob 10 GPIO_ACTIVE_HIGH>;
};
