# These white-box unit tests compile selected PTP implementation files
# directly, without enabling CONFIG_PTP and linking the full subsystem.
# Per-test Kconfig files intentionally redeclare selected PTP Kconfig entries
# so tests can provide defaults while CONFIG_PTP and its dependencies remain
# disabled. Keep those redeclarations test-local.
# Provide common PTP Kconfig defaults needed by those files here.

config PTP_LOG_LEVEL
	default 3
