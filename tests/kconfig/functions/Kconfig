config KCONFIG_ARITHMETIC_ADD_10
	int
	default $(add, 10)

config KCONFIG_ARITHMETIC_ADD_10_3
	hex
	default $(add_hex, 10, 3)

config KCONFIG_ARITHMETIC_ADD_10_3_2
	int
	default $(add, 0xa, 3, 0b10)

