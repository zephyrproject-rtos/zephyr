config KCONFIG_VND_PWM_ENABLED_N
	bool
	default $(dt_compat_enabled,$(DT_COMPAT_VND_PWM))

config KCONFIG_VND_PWM_ENABLED_NUM_0
	int
	default $(dt_compat_enabled_num,$(DT_COMPAT_VND_PWM))

