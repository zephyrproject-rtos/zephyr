 *
 * Copyright (c) 2026 Espressif Systems (Shanghai) Co., Ltd.
 *
 * Self-loopback test overlay:
 *   unit 0 : GPIO10 (CH0 sig)      + GPIO11 (CH1 sig, quadrature phase B)
 *   unit 1 : GPIO12 (CH0 sig)
 *   unit 2 : GPIO13 (CH0 sig)      -- carries high-limit watchpoint
 *   unit 3 : GPIO14 (CH0 sig)      -- carries zero-cross watchpoint
 */

/ {
	aliases {
		qdec0 = &pcnt;
		pulse0 = &pulse0_alias;
		pulse0b = &pulse0b_alias;
		pulse1 = &pulse1_alias;
		pulse2 = &pulse2_alias;
		pulse3 = &pulse3_alias;
	};

	pulse_aliases {
		compatible = "gpio-keys";

		pulse0_alias: pulse0_alias {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "pulse0";
		};

		pulse0b_alias: pulse0b_alias {
			gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
			label = "pulse0b";
		};

		pulse1_alias: pulse1_alias {
			gpios = <&gpio0 12 GPIO_ACTIVE_HIGH>;
			label = "pulse1";
		};

		pulse2_alias: pulse2_alias {
			gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;
			label = "pulse2";
		};

		pulse3_alias: pulse3_alias {
			gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;
			label = "pulse3";
		};
	};
};

&pinctrl {
	pcnt_default: pcnt_default {
		group1 {
			pinmux = <PCNT0_CH0SIG_GPIO10>,
				 <PCNT0_CH1SIG_GPIO11>,
				 <PCNT1_CH0SIG_GPIO12>,
				 <PCNT2_CH0SIG_GPIO13>,
				 <PCNT3_CH0SIG_GPIO14>;
		};
	};
};

&pcnt {
	pinctrl-0 = <&pcnt_default>;
	pinctrl-names = "default";
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	/*
	 * unit 0: quadrature-capable (CH0 + CH1 wired).
	 *
	 * Channel A (reg=0): rising edge on sig -> increment, falling -> decrement.
	 * Channel B (reg=1): rising edge on sig -> decrement, falling -> increment.
	 *
	 * Together this forms a 4x quadrature decoder when both signals move
	 * 90 degrees out of phase. If we drive only sig A in simple toggles
	 * with sig B held low, channel A contributes both sides of the wave
	 * (pos: +1, neg: -1 - net 0). For the simple counting tests we hold
	 * the B input low, so sig_neg_mode is set to 0 on channel A to
	 * guarantee +1 per rising edge only.
	 */
	unit0@0 {
		reg = <0>;
		#address-cells = <1>;
		#size-cells = <0>;
		counts-per-revolution = <400>;

		channelA@0 {
			reg = <0>;
			sig-pos-mode = <1>;
			sig-neg-mode = <0>;
			ctrl-h-mode = <0>;
			ctrl-l-mode = <0>;
		};

		channelB@1 {
			reg = <1>;
			sig-pos-mode = <2>;
			sig-neg-mode = <0>;
			ctrl-h-mode = <0>;
			ctrl-l-mode = <0>;
		};
	};

	unit1@1 {
		reg = <1>;
		#address-cells = <1>;
		#size-cells = <0>;

		channelA@0 {
			reg = <0>;
			sig-pos-mode = <1>;
			sig-neg-mode = <0>;
			ctrl-h-mode = <0>;
			ctrl-l-mode = <0>;
		};
	};

	/* unit 2: armed with a high-limit watchpoint at +10 */
	unit2@2 {
		reg = <2>;
		#address-cells = <1>;
		#size-cells = <0>;
		high-limit = <10>;

		channelA@0 {
			reg = <0>;
			sig-pos-mode = <1>;
			sig-neg-mode = <0>;
			ctrl-h-mode = <0>;
			ctrl-l-mode = <0>;
		};
	};

	/*
	 * unit 3: same wiring as unit1/2 but with zero-cross-event enabled.
	 * We verify the DT wiring compiles and the unit still counts normally;
	 * triggering the zero-cross event at runtime would require the counter
	 * to be driven negative first, which needs additional bench setup.
	 */
	unit3@3 {
		reg = <3>;
		#address-cells = <1>;
		#size-cells = <0>;
		zero-cross-event;

		channelA@0 {
			reg = <0>;
			sig-pos-mode = <1>;
			sig-neg-mode = <0>;
			ctrl-h-mode = <0>;
			ctrl-l-mode = <0>;
		};
	};
};
