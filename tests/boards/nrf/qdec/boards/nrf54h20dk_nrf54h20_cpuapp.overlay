/ {
	aliases {
		qdec-0 = &qdec130;
		qdec-1 = &qdec131;
		qenca = &phase_a;
		qencb = &phase_b;
		qencc = &phase_c;
		qencd = &phase_d;
	};

	encoder-emulate {
		compatible = "gpio-leds";
		phase_a: phase_a {
			gpios = <&gpio2 9 GPIO_ACTIVE_HIGH>;
		};
		phase_b: phase_b {
			gpios = <&gpio2 11 GPIO_ACTIVE_HIGH>;
		};
		phase_c: phase_c {
			gpios = <&gpio1 1 GPIO_ACTIVE_HIGH>;
		};
		phase_d: phase_d {
			gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
		};
	};
};

&pinctrl {
	qdec_130_pinctrl: qdec_130_pinctrl {
		group1 {
			psels = <NRF_PSEL(QDEC_A, 2, 8)>,
				<NRF_PSEL(QDEC_B, 2, 10)>;
		};
	};

	qdec_130_sleep_pinctrl: qdec_130_sleep_pinctrl {
		group1 {
			psels = <NRF_PSEL(QDEC_A, 2, 8)>,
				<NRF_PSEL(QDEC_B, 2, 10)>;
			low-power-enable;
		};
	};

	qdec_131_pinctrl: qdec_131_pinctrl {
		group1 {
			psels = <NRF_PSEL(QDEC_A, 1, 0)>,
				<NRF_PSEL(QDEC_B, 1, 2)>;
		};
	};

	qdec_131_sleep_pinctrl: qdec_131_sleep_pinctrl {
		group1 {
			psels = <NRF_PSEL(QDEC_A, 1, 0)>,
				<NRF_PSEL(QDEC_B, 1, 2)>;
			low-power-enable;
		};
	};
};

&gpio1 {
	status = "okay";
};

&gpio2 {
	status = "okay";
};

&qdec130 {
	status = "okay";
	pinctrl-0 = <&qdec_130_pinctrl>;
	pinctrl-1 = <&qdec_130_sleep_pinctrl>;
	pinctrl-names = "default", "sleep";
	steps = <127>;
	led-pre = <500>;
	zephyr,pm-device-runtime-auto;
};

&qdec131 {
	status = "okay";
	pinctrl-0 = <&qdec_131_pinctrl>;
	pinctrl-1 = <&qdec_131_sleep_pinctrl>;
	pinctrl-names = "default", "sleep";
	steps = <127>;
	led-pre = <500>;
	zephyr,pm-device-runtime-auto;
};

/* To prevent enabling console receiver. */
&uart136 {
	disable-rx;
};
