/* i2s-node0 is the transmitter/receiver */

/ {
	aliases {
		i2s-node0 = &i2s0;
	};
};

&pinctrl {
	i2s0_default: i2s0_default {
		group1 {
			pinmux = <I2S0_O_WS_GPIO41>,
				 <I2S0_O_BCK_GPIO40>;
		};

		group2 {
			pinmux =  <I2S0_O_SD_GPIO39>;
			input-enable;
		};

		group3 {
			pinmux = <I2S0_I_SD_GPIO39>;
			output-enable;
		};
	};
};

&i2s0 {
	status = "okay";
	pinctrl-0 = <&i2s0_default>;
	pinctrl-names = "default";

	full-duplex;
	dmas = <&dma 2>, <&dma 3>;
	dma-names = "rx", "tx";
};

&dma {
	status = "okay";
};
