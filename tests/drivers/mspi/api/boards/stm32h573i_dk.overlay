/ {
	aliases {
		mspi0 = &xspi1;
	};
};

/* Delete the mx25lm51245 since MSPI_MAX_DEVICE is 1 */
/delete-node/ &mx25lm51245;

&xspi1 {
	mspi_device: mspi_device@0 {
		status = "okay";
		compatible = "zephyr,mspi-emul-device";
		reg = <0x0>;
		mspi-max-frequency = <48000000>;
	};
};
