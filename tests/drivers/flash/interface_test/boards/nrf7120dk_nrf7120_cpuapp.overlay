&mspi00 {
	status = "okay";
};

&mx25u25645g {
	status = "okay";

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot1_partition: partition@0 {
			label = "image-1";
			reg = <0x0 DT_SIZE_K(680)>;
		};
	};
};

&cpuapp_mram {
	partitions {
		/delete-node/ partition@178000;
	};
};
