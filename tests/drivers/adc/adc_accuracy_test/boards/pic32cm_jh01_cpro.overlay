/* Connect the PA11 to VCC for the test */

/ {
	zephyr,user {
		io-channels = <&adc0 1>;
		reference-mv = <3300>;
		expected-accuracy = <32>;
	};
};

&adc0 {
	#address-cells = <1>;
	#size-cells = <0>;
	prescaler = <2>;
	status = "okay";

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_VDD_1";
		zephyr,vref-mv = <3300>;
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_TICKS, 10)>;
		zephyr,input-positive = <MCHP_ADC_AIN11>;
		zephyr,resolution = <12>;
	};
};
