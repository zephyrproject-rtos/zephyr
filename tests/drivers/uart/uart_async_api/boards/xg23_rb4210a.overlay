/ {
	chosen {
		zephyr,console = &usart0;
		zephyr,shell-uart = &usart0;
		zephyr,uart-pipe = &usart0;
	};
};


/*
 * Need to connect PA7 and PA6 of the Expension Pin header
 */
&pinctrl{
	eusart0_default: eusart0_default {
		group0 {
			pins = <EUSART0_TX_PA7>;
			drive-push-pull;
			output-high;
		};
		group1 {
			pins = <EUSART0_RX_PA6>;
			input-enable;
			silabs,input-filter;
		};
	};
	usart0_default: usart0_default {
		group0 {
			pins = <USART0_TX_PA8>;
			drive-push-pull;
			output-high;
		};
		group1 {
			pins = <USART0_RX_PA9>;
			input-enable;
			silabs,input-filter;
		};
	};
};

dut: &eusart0 {
	compatible = "silabs,eusart-uart";
	dmas = <&dma0 DMA_REQSEL_EUSART0TXFL>,
		<&dma0 DMA_REQSEL_EUSART0RXFL>;
	dma-names = "tx", "rx";
	current-speed = <115200>;
	pinctrl-0 = <&eusart0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&usart0 {
	compatible = "silabs,usart-uart";
	current-speed = <115200>;
	pinctrl-0 = <&usart0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&dma0 {
	status = "okay";
};
