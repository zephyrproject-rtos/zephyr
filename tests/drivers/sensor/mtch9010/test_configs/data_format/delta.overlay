&uart1 {
	status = "okay";
	current-speed = <38400>;

	dut: mtch9010 {
		status = "okay";
		compatible = "microchip,mtch9010";

		// Device Configuration
		mtch9010-operating-mode = "capacitive";
		mtch9010-extended-output-enable;
		mtch9010-extended-output-format = "delta";
		mtch9010-reference-value = <0>;
		mtch9010-detect-value = <600>;
	};
};
