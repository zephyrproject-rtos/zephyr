/ {
	zephyr,user {
		io-channels = <&dac1 1>;
		io-channel-names = "dac1";
	};
};

&dac1 {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	channel@1 {
		reg = <1>;
		zephyr,resolution = <12>;
	};
};
