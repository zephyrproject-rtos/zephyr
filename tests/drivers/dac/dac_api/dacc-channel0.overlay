/ {
	zephyr,user {
		io-channels = <&dacc 0>;
		io-channel-names = "dac1";
	};
};

&dacc {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,resolution = <12>;
	};
};
