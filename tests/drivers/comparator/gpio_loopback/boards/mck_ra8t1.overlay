#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	aliases {
		test-comp = &acmphs0;
	};

	zephyr,user {
		test-gpios = <&ioport6 6 GPIO_ACTIVE_HIGH>;
		dac = <&dac0>;
		dac-channel-id = <0>;
		dac-resolution = <12>;
	};
};

&acmphs_global {
	status = "okay";

	acmphs0 {
		/*
		 * Since ivref3 is internally routed from to DA0 (DAC),
		 * there is no need to add pinsel of ivref3.
		 */
		pinctrl-0 = <&acmphs0_ivcmp0>;
		pinctrl-names = "default";
		interrupts = <90 12>;
		interrupt-names = "hs";
		reference-input-source = "ivref3";
		compare-input-source = "ivcmp0";
		noise-filter = <1>;
		status = "okay";
	};
};
