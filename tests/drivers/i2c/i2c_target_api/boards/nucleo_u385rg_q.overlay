/* I2C bus pins are exposed on the ST Arduino header.
 *
 *  Bus        SDA                    SCL
 *          Pin   Hdr              Pin   Hdr
 *  i2c3    PC1   CN8:5            PC0   CN8:6
 *  i2c2    PB14  CN10:28          PB13  CN10:30
 *
 * Short Pin PB7 to PC1, and PB6 to PC0, for the test to pass.
 */

&i2c3 {
	eeprom0: eeprom@54 {
		compatible = "zephyr,i2c-target-eeprom";
		reg = <0x54>;
		size = <256>;
	};
};

&i2c2 {
	eeprom1: eeprom@56 {
		compatible = "zephyr,i2c-target-eeprom";
		reg = <0x56>;
		size = <256>;
	};
};
