/* I2C bus pins are exposed on the STMod+.
 *
 *  Bus        SDA               SCL
 *          Pin   Hdr         Pin   Hdr
 *  i2c1    PB9   CN1:9      PB8  CN1:10
 *  i2c3    PC1   CN4:5      PC0  CN4:6
 *
 * Short Pin PB9 to PC1, and PB8 to PC0, for the test to pass.
 */

&i2c1 {
	eeprom0: eeprom@54 {
		compatible = "zephyr,i2c-target-eeprom";
		reg = <0x54>;
		size = <256>;
	};
};

&i2c3 {
	eeprom1: eeprom@56 {
		compatible = "zephyr,i2c-target-eeprom";
		reg = <0x56>;
		size = <256>;
	};
};
