/ {
	aliases {
		sdhc-sd = &sdhc_sd;
		sdhc-emmc = &sdhc_emmc;
		sdhc-sdio = &sdhc_sdio;
	};

	sdhc_sd: sdhc_emul_sd {
		compatible = "zephyr,sdhc-emul";
		card-type = "sdhc";
		capacity-blocks = <1024>;
		card-inserted;
		status = "okay";
	};

	sdhc_emmc: sdhc_emul_emmc {
		compatible = "zephyr,sdhc-emul";
		card-type = "emmc";
		capacity-blocks = <1024>;
		card-inserted;
		status = "okay";
	};

	sdhc_sdio: sdhc_emul_sdio {
		compatible = "zephyr,sdhc-emul";
		card-type = "sdio";
		capacity-blocks = <1024>;
		sdio-func-count = <2>;
		card-inserted;
		status = "okay";
	};
};
