/ {
	test {
		#address-cells = <1>;
		#size-cells = <1>;

		test_gpio: gpio@deadbeef {
			compatible = "vnd,gpio";
			gpio-controller;
			reg = <0xdeadbeef 0x1000>;
			#gpio-cells = <0x2>;
			status = "okay";
		};

		test_uart: uart@55556666 {
			compatible = "vnd,serial";
			reg = <0x55556666 0x1000>;
			status = "okay";

			test_uart_itron: itron {
				compatible = "noritake,itron";
				status = "okay";
				columns = <20>;
				rows = <2>;
			};

			test_nhd_k3z: nhd-k3z {
				compatible = "newhaven,nhd-k3z";
				status = "okay";
				columns = <16>;
				rows = <2>;
			};
		};
	};
};
