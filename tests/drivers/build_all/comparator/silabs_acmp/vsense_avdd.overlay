#include <zephyr/dt-bindings/comparator/silabs/silabs-acmp.h>

&acmp0 {
	status = "okay";
	hysteresis-mode = "disabled";
	accuracy-mode = "low";
	input-range = "full";
	input-positive = <ACMP_INPUT_VSENSE01DIV4>;
	input-negative = <ACMP_INPUT_VREFDIVAVDD>;
	vref-divider = <63>;
};
