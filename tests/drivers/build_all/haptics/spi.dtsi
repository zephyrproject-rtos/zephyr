test_spi_cs40l26@0 {
	compatible = "cirrus,cs40l26";
	reg = <0x0>;
	spi-max-frequency = <5000000>;
	status = "okay";
};

test_spi_cs40l27@1 {
	compatible = "cirrus,cs40l27";
	reg = <0x1>;
	spi-max-frequency = <5000000>;
	status = "okay";
};
