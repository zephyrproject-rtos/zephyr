drv2605@0 {
	compatible = "ti,drv2605";
	reg = <0x0>;
	status = "okay";

	actuator-mode = "LRA";
};

test_i2c_cs40l50@1 {
	compatible = "cirrus,cs40l50";
	reg = <0x1>;
	status = "okay";
};

