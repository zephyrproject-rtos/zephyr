/****************************************
 * PLEASE KEEP REG ADDRESSES SEQUENTIAL *
 **************************************
 */

drv2605@0 {
	compatible = "ti,drv2605";
	reg = <0x0>;
	status = "okay";

	actuator-mode = "LRA";
};

cs40l5x@1 {
	compatible = "cirrus,cs40l5x";
	reg = <0x1>;
	status = "okay";

	reset-gpios = <&test_gpio 0 0>;
};

test_i2c_cs40l26@2 {
	compatible = "cirrus,cs40l26";
	reg = <0x2>;
	status = "okay";
};

test_cs40l27@3 {
	compatible = "cirrus,cs40l27";
	reg = <0x3>;
	status = "okay";
};
