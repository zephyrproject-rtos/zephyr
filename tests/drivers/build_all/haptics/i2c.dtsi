	compatible = "cirrus,cs40l51";
	reg = <0x2>;
	status = "okay";
};

test_i2c_cs40l52@3 {
	compatible = "cirrus,cs40l52";
	reg = <0x3>;
	status = "okay";
};

test_i2c_cs40l53@4 {
	compatible = "cirrus,cs40l53";
	reg = <0x4>;
	status = "okay";
};

test_i2c_cs40l26@5 {
	compatible = "cirrus,cs40l26";
	reg = <0x5>;
	status = "okay";
};

test_cs40l27@6 {
	compatible = "cirrus,cs40l27";
	reg = <0x6>;
	status = "okay";
};
