#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	test {
		#address-cells = <1>;
		#size-cells = <1>;

		test_gpio: gpio@100 {
			compatible = "vnd,gpio";
			gpio-controller;
			reg = <0x100 0x100>;
			#gpio-cells = <2>;
			status = "okay";
		};

		test_uart: uart@0 {
			compatible = "vnd,serial";
			reg = <0x0 0x1000>;
			current-speed = <9600>;
			status = "okay";

			gnss_nmea_generic: gnss-nmea-generic {
				compatible = "gnss-nmea-generic";
				timepulse-gpios = <&test_gpio 0 GPIO_ACTIVE_HIGH>;
			};

			gnss_air530z: air530z {
				compatible = "luatos,air530z";
			};

			gnss_lc86g: lc86g {
				compatible = "quectel,lc86g";
				pps-mode = "GNSS_PPS_MODE_ENABLED";
			};

			gnss_m8: m8 {
				compatible = "u-blox,m8";
			};

			gnss_m10: m10 {
				compatible = "u-blox,m10";
			};

			gnss_f9p: f9p {
				compatible = "u-blox,f9p";
			};
		};
	};
};
