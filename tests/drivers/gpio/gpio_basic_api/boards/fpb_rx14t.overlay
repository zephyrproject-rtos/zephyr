/ {
	resources {
		compatible = "test-gpio-basic-api";
		out-gpios = <&ioport7 1 0>; /* P71 */
		in-gpios = <&ioport7 2 0>; /* P72 */
	};
};

&port_irq6 {
	status = "okay";
	renesas,digital-filtering;
};

&port_irq7 {
	status = "okay";
	renesas,digital-filtering;
};

&ioport7 {
	status = "okay";
};
