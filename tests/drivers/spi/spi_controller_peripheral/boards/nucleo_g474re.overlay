/* The two SPI instances need to be connected as follows:
 * CN10:28 (SPI2 MISO) to CN7:2 (SPI3 MISO)
 * CN10:26 (SPI2 MOSI) to CN7:3 (SPI3 MOSI)
 * CN10:16 (SPI2 NSS) to CN7:17 (SPI3 NSS)
 * CN10:30 (SPI2 SCK) to CN7:1 (SPI3 SCK)
 */

&spi2 {
	pinctrl-0 = <&spi2_miso_pb14 &spi2_mosi_pb15 &spi2_nss_pb12 &spi2_sck_pb13>;
	pinctrl-names = "default";
	interrupts = <36 1>;
	status = "okay";

	dut_spi_dt: test-spi-dev@0 {
		compatible = "vnd,spi-device";
		spi-max-frequency = <DT_FREQ_M(1)>;
		reg = <0>;
	};
};

dut_spis: &spi3 {
	pinctrl-0 = <&spi3_miso_pc11 &spi3_mosi_pc12 &spi3_nss_pa15 &spi3_sck_pc10>;
	pinctrl-names = "default";
	interrupts = <51 0>;
	status = "okay";

	dut_spis_dt: test-spi-dev@0 {
		compatible = "vnd,spi-device";
		spi-max-frequency = <DT_FREQ_M(1)>;
		reg = <0>;
	};
};
