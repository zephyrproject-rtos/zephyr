&spi1 {
	dmas = <&dma1 3 0x20440
		&dma1 2 0x20480>;
	dma-names = "tx", "rx";
};

&dma1 {
	status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa5
		     &spi1_miso_pa6 &spi1_mosi_pa7>;
	status = "okay";
};
