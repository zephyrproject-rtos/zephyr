&spi0 {
	cs-gpios = <&gpioa 6 GPIO_ACTIVE_LOW>;

	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};

	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};
};

&gpioa {
	status = "okay";
};
