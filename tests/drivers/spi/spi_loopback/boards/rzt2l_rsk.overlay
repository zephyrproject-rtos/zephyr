&pinctrl {
	/omit-if-no-ref/ spi0_pins: spi0 {
		spi0-pinmux {
			pinmux = <RZT_PINMUX(PORT_13, 3, 10)>, /* CK0 */
				 <RZT_PINMUX(PORT_22, 1, 7)>, /* MOSI0 */
				 <RZT_PINMUX(PORT_13, 2, 10)>, /* MISO0 */
				 <RZT_PINMUX(PORT_07, 3, 3)>; /* SSL0 */
			drive-strength = "high";
			slew-rate = "fast";
		};
	};
};

&spi0 {
	pinctrl-0 = <&spi0_pins>;
	pinctrl-names = "default";
	status = "okay";

	dmas = <&dma0 1 RZ_DMA_PERIPH_TO_MEM>,
	       <&dma0 0 RZ_DMA_MEM_TO_PERIPH>;
	dma-names = "rx", "tx";

	slow@2 {
		compatible = "test-spi-loopback-slow";
		reg = <2>;
		spi-max-frequency = <500000>;
	};

	fast@2 {
		compatible = "test-spi-loopback-fast";
		reg = <2>;
		spi-max-frequency = <2500000>;
	};
};

&dma0 {
	status = "okay";
	dma-buf-addr-alignment = <1>;
};
