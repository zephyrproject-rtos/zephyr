&spi1 {
	dmas = <&lpdma1 0 5 STM32_DMA_PERIPH_TX
		&lpdma1 1 4 STM32_DMA_PERIPH_RX>;
	dma-names = "tx", "rx";
	fifo-enable;

	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};

	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <16000000>;
	};
};
