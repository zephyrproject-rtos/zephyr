&pinctrl {
	sci4_spi_default: sci4_spi_default {
		group1 {
			/* MISO4 MOSI4 SCK4 */
			psels = <RA_PSEL(RA_PSEL_SCI_4, 4, 14)>,
				<RA_PSEL(RA_PSEL_SCI_4, 4, 15)>,
				<RA_PSEL(RA_PSEL_SCI_4, 7, 8)>;
			drive-strength = "high";
		};
	};
};

&sci4 {
	pinctrl-0 = <&sci4_spi_default>;
	pinctrl-names = "default";
	interrupts = <95 1>, <94 1>, <93 1>, <92 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";

	spi {
		status = "okay";

		slow@0 {
			compatible = "test-spi-loopback-slow";
			reg = <0>;
			spi-max-frequency = <1000000>;
		};

		fast@0 {
			compatible = "test-spi-loopback-fast";
			reg = <0>;
			spi-max-frequency = <2500000>;
		};
	};

	uart {
		status = "disabled";
	};

	i2c {
		status = "disabled";
	};
};
