source "Kconfig.zephyr"

config TEST_CRYPTO_IO_ALIGNMENT_BYTES
	int "Alignment (bytes) for hash test IO buffers"
	default 4
	help
	  Alignment (in bytes) applied to the hash test input and output
	  buffers, and to which their sizes are rounded up.  Some crypto
	  drivers require IO buffers handed to them to be cache-line
	  aligned and to occupy whole cache lines so that the driver's
	  cache-maintenance operations do not corrupt unrelated data
	  sharing a partial cache line.  Boards whose crypto driver has
	  this requirement should override this value (typically to the
	  D-Cache line size) via a board overlay.
