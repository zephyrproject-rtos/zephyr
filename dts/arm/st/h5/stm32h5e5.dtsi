#include <st/h5/stm32h5e4.dtsi>

/ {
	soc {
		compatible = "st,stm32h5e5", "st,stm32h5", "simple-bus";

		usbotg_hs: usb@42040000 {
			compatible = "st,stm32n6-otghs", "st,stm32-otghs";
			reg = <0x42040000 DT_SIZE_K(128)>;
			interrupts = <161 0>;
			interrupt-names = "otghs";
			num-bidir-endpoints = <9>;
			ram-size = <4096>;
			clocks = <&rcc STM32_CLOCK(AHB2, 14)>;
			phys = <&otghs_phy>;
			status = "disabled";
		};
	};

	otghs_phy: otghs_phy {
		compatible = "st,stm32h5-otghs-phy";
		clocks = <&rcc STM32_CLOCK(AHB2, 13)>;
		resets = <&rctl STM32_RESET(AHB2, 13)>;
		#phy-cells = <0>;
		status = "disabled";
	};
};
