#include <st/u5/stm32u5.dtsi>

/ {
  soc {
    /* USB-C PD is not available on this part. */
    /delete-node/ ucpd@4000dc00;

    /* Advanced Encryption Standard hardware accelerator is not available on this part. */
    /delete-node/ aes@420c0000;

    compatible = "st,stm32u535", "st,stm32u5", "simple-bus";

    usb: usb@40016000 {
      compatible = "st,stm32-usb";
      reg = <0x40016000 0x400>;
      interrupts = <73 0>;
      interrupt-names = "usb";
      num-bidir-endpoints = <8>;
      ram-size = <2048>;
      maximum-speed = "full-speed";
      clocks = <&rcc STM32_CLOCK_BUS_APB2 0x01000000>,
      <&rcc STM32_SRC_HSI48 ICKLK_SEL(0)>;
      phys = <&usb_fs_phy>;
      status = "disabled";
    };
  };

  usb_fs_phy: usb_fs_phy {
    compatible = "usb-nop-xceiv";
    #phy-cells = <0>;
  };
};
