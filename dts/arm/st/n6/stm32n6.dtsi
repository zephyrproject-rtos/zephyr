			bsec: efuse@6009000 {
				compatible = "st,stm32-bsec";
				reg = <0x6009000 0x1000>;
				st,upper-fuse-limit = <256>;
				status = "disabled";

				nvmem-layout {
					compatible = "fixed-layout";
					#address-cells = <1>;
					#size-cells = <1>;

					otp124_hconf1: opt124_hconf1@1f0 {
						reg = <0x1f0 0x4>;
						#nvmem-cell-cells = <0>;
					};

					mac_address0: mac-address@2a4 {
						reg = <0x2a4 0x6>;
						#nvmem-cell-cells = <0>;
					};

					mac_address1: mac-address@2ac {
						reg = <0x2ac 0x6>;
						#nvmem-cell-cells = <0>;
					};
				};
			};

			dcmipp: dcmipp@8002000 {
				compatible = "st,stm32-dcmipp";
				reg = <0x8002000 0x1000>;
				clock-names = "dcmipp", "dcmipp-ker", "csi";
				clocks = <&rcc STM32_CLOCK(APB5, 2)>,
					 <&rcc STM32_SRC_IC17 DCMIPP_SEL(2)>,
					 <&rcc STM32_CLOCK(APB5, 6)>;
				interrupts = <48 0>, <47 0>;
				interrupt-names = "dcmipp", "dcmipp_csi";
				resets = <&rctl STM32_RESET(APB5, 2)>,
					 <&rctl STM32_RESET(APB5, 6)>;
				status = "disabled";

				pipes {
					compatible = "st,stm32-dcmipp-pipes";
					#address-cells = <1>;
					#size-cells = <0>;

					pipe_dump: pipe@0 {
						reg = <0>;
					};

					pipe_main: pipe@1 {
						reg = <1>;
					};

					pipe_aux: pipe@2 {
						reg = <2>;
					};
				};

				port {
					endpoint {
						remote-endpoint-label = "";
						bus-type = <VIDEO_BUS_TYPE_CSI2_DPHY>;
					};
				};
			};

