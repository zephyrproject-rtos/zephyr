				reg = <0x2003c00 0x400>;
				clocks = <&rcc STM32_CLOCK(APB2, 15)>,
					 <&rcc STM32_SRC_TIMG NO_SEL>;
				resets = <&rctl STM32_RESET(APB2, 15)>;
				interrupts = <135 0>;
				interrupt-names = "global";
				status = "disabled";

				counter {
					compatible = "st,stm32-counter";
					status = "disabled";
				};
			};

			xspim: xspim@802b400 {
				compatible = "st,stm32-xspim";
				reg = <0x802b400 0x400>;
				clocks = <&rcc STM32_CLOCK(AHB5, 13)>;
				io-port-1 = <&xspi1>;
				io-port-2 = <&xspi2>;
				status = "disabled";
			};

			xspi1: xspi@8025000 {
				compatible = "st,stm32-xspi";
				reg = <0x8025000 0x1000>, <0x90000000 DT_SIZE_M(256)>;
				interrupts = <170 0>;
				clock-names = "xspix", "xspi-ker";
				clocks = <&rcc STM32_CLOCK(AHB5, 5)>,
					 <&rcc STM32_SRC_HCLK5 XSPI1_SEL(0)>;
				#address-cells = <1>;
				#size-cells = <0>;
				status = "disabled";
			};

			xspi2: spi@802a000 {
				compatible = "st,stm32-xspi";
				reg = <0x802a000 0x1000>, <0x70000000 DT_SIZE_M(256)>;
				interrupts = <171 0>;
				clock-names = "xspix", "xspi-ker";
				clocks = <&rcc STM32_CLOCK(AHB5, 12)>,
					 <&rcc STM32_SRC_HCLK5 XSPI2_SEL(0)>;
				#address-cells = <1>;
				#size-cells = <0>;
				status = "disabled";
			};

			xspi3: spi@802d000 {
				compatible = "st,stm32-xspi";
				reg = <0x802d000 0x1000>, <0x80000000 DT_SIZE_M(256)>;
				interrupts = <172 0>;
				clock-names = "xspix", "xspi-ker";
				clocks = <&rcc STM32_CLOCK(AHB5, 17)>,
					 <&rcc STM32_SRC_HCLK5 XSPI3_SEL(0)>;
				#address-cells = <1>;
				#size-cells = <0>;
				status = "disabled";
			};

			usbotg_hs1: otghs@8040000 {
				compatible = "st,stm32n6-otghs", "st,stm32-otghs";
				reg = <0x8040000 0x2000>;
				interrupts = <177 0>;
				interrupt-names = "otghs";
				num-bidir-endpoints = <9>;
				ram-size = <4096>;
				maximum-speed = "high-speed";
				clocks = <&rcc STM32_CLOCK(AHB5, 26)>,
					 <&rcc STM32_SRC_HSE OTGPHY1CKREF_SEL(1)>;
				phys = <&usbphyc1>;
				status = "disabled";
			};

			usbotg_hs2: otghs@8080000 {
				compatible = "st,stm32n6-otghs", "st,stm32-otghs";
				reg = <0x8080000 0x2000>;
				interrupts = <178 0>;
				interrupt-names = "otghs";
				num-bidir-endpoints = <9>;
				ram-size = <4096>;
				maximum-speed = "high-speed";
				clocks = <&rcc STM32_CLOCK(AHB5, 29)>,
					 <&rcc STM32_SRC_HSE OTGPHY2CKREF_SEL(1)>;
				phys = <&usbphyc2>;
				status = "disabled";
			};

			usbphyc1: usbphyc@803fc00 {
				compatible = "st,stm32-usbphyc";
				reg = <0x803fc00 0x400>;
				clocks = <&rcc STM32_CLOCK(AHB5, 27)>;
				#phy-cells = <0>;
			};

			usbphyc2: usbphyc@80c0000 {
				compatible = "st,stm32-usbphyc";
				reg = <0x80c0000 0x400>;
				clocks = <&rcc STM32_CLOCK(AHB5, 28)>;
				#phy-cells = <0>;
			};

			ltdc: ltdc@8001000 {
				compatible = "st,stm32-ltdc";
				reg = <0x8001000 0x1000>;
				interrupts = <193 0>, <194 0>;
				interrupt-names = "ltdc", "ltdc_er";
				clocks = <&rcc STM32_CLOCK(APB5, 1)>,
					 <&rcc STM32_SRC_PCLK5 LTDC_SEL(0)>;
				resets = <&rctl STM32_RESET(APB5, 1)>;
				status = "disabled";
			};

			rng: rng@4020000 {
				compatible = "st,stm32-rng";
				reg = <0x4020000 0x400>;
				interrupts = <40 0>;
				clocks = <&rcc STM32_CLOCK(AHB3, 0)>;
				nist-config = <0xf00d00>;
				health-test-config = <0xaac7>;
				status = "disabled";
			};

			sai1_a: sai1@2005804 {
				compatible = "st,stm32-sai";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x2005804 0x20>;
				clocks = <&rcc STM32_CLOCK(APB2, 21)>;
				dmas = <&gpdma1 1 91 (STM32_DMA_MODE_NORMAL |
						      STM32_DMA_PRIORITY_HIGH |
						      STM32_DMA_16BITS)>;
				status = "disabled";
			};

			sai1_b: sai1@2005824 {
				compatible = "st,stm32-sai";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x2005824 0x20>;
				clocks = <&rcc STM32_CLOCK(APB2, 21)>;
				dmas = <&gpdma1 0 92 (STM32_DMA_MODE_NORMAL |
						      STM32_DMA_PRIORITY_HIGH |
						      STM32_DMA_16BITS)>;
				status = "disabled";
			};

			sai2_a: sai2@2005c04 {
				compatible = "st,stm32-sai";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x2005c04 0x20>;
				clocks = <&rcc STM32_CLOCK(APB2, 22)>;
				dmas = <&gpdma1 3 93 (STM32_DMA_MODE_NORMAL |
						      STM32_DMA_PRIORITY_HIGH |
						      STM32_DMA_16BITS)>;
				status = "disabled";
			};

			sai2_b: sai2@2005c24 {
				compatible = "st,stm32-sai";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x2005c24 0x20>;
				clocks = <&rcc STM32_CLOCK(APB2, 22)>;
				dmas = <&gpdma1 2 94 (STM32_DMA_MODE_NORMAL |
						      STM32_DMA_PRIORITY_HIGH |
						      STM32_DMA_16BITS)>;
				status = "disabled";
			};

			npu: npu@80e0000 {
				compatible = "st,stm32-npu";
				reg = <0x80e0000 DT_SIZE_K(128)>;
				clocks = <&rcc STM32_CLOCK(AHB5, 31)>;
				resets = <&rctl STM32_RESET(AHB5, 31)>;
				status = "disabled";
			};

			npu_cache: cache-controller@80dfc00 {
				compatible = "st,stm32-npu-cache";
				reg = <0x80dfc00 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(AHB5, 30)>;
				resets = <&rctl STM32_RESET(AHB5, 30)>;
				status = "okay";
			};

			venc: venc@8005000 {
				compatible = "st,stm32-venc";
				reg = <0x8005000 0x1000>;
				interrupts = <62 0>;
				clocks = <&rcc STM32_CLOCK(APB5, 5)>;
				resets = <&rctl STM32_RESET(APB5, 5)>;
				status = "disabled";
			};

			jpeg: codec@8023000 {
				compatible = "st,stm32-jpeg";
				reg = <0x8023000 0x1000>;
				interrupts = <61 0>;
				clocks = <&rcc STM32_CLOCK(AHB5, 3)>;
				resets = <&rctl STM32_RESET(AHB5, 3)>;
				status = "disabled";
			};

			iwdg: watchdog@6004800 {
				compatible = "st,stm32-watchdog";
				reg = <0x6004800 0x400>;
				interrupts = <18 0>;
				status = "disabled";
			};

			wwdg: watchdog@2c00 {
				compatible = "st,stm32-window-watchdog";
				reg = <0x2c00 0x400>;
				clocks = <&rcc STM32_CLOCK(APB1, 11)>;
				interrupts = <19 0>;
				status = "disabled";
			};

			crc: crc@6024c00 {
				compatible = "st,stm32-crc";
				reg = <0x6024c00 0x400>;
				clocks = <&rcc STM32_CLOCK(AHB4, 19)>;
				resets = <&rctl STM32_RESET(AHB4, 19)>;
				status = "disabled";
			};
		};
	};

	iocell: iocell {
		compatible = "st,stm32-iocell";
		status = "disabled";

		/* If iocell is enabled,
		 * the bsec node needs to be enabled as well
		 */
		nvmem-cells = <&otp124_hconf1>;
		nvmem-cell-names = "safeguard";

		vddio {
			domain = <STM32_DT_IOCELL_VDD>;
		};

		vddio2 {
			domain = <STM32_DT_IOCELL_VDDIO2>;
		};

		vddio3 {
			domain = <STM32_DT_IOCELL_VDDIO3>;
		};

		vddio4 {
			domain = <STM32_DT_IOCELL_VDDIO4>;
		};

		vddio5 {
			domain = <STM32_DT_IOCELL_VDDIO5>;
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <4>;
};
