#include <st/u3/stm32u3.dtsi>

/ {
	soc {
		compatible = "st,stm32u3c5", "st,stm32u3", "simple-bus";

		pinctrl: pin-controller@42020000 {
			gpiof: gpio@42021400 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x42021400 0x400>;
				clocks = <&rcc STM32_CLOCK(AHB2, 5)>;
			};
		};

		pwr: power@40030800 {
			wkup-pin@8 {
				/* PF2 is also available on these variants */
				wkup-gpios = <&gpiof 2 STM32_PWR_WKUP_EVT_SRC_0>,
					     <&gpioa 7 STM32_PWR_WKUP_EVT_SRC_1>,
					     <&gpiob 10 STM32_PWR_WKUP_EVT_SRC_2>;
			};
		};
	};
};
