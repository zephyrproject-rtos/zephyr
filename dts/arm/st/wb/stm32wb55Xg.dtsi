#include <st/wb/stm32wb55.dtsi>

/ {
	sram0: memory@20000000 {
		reg = <0x20000000 DT_SIZE_K(192)>;
	};

	soc {
		flash-controller@58004000 {
			flash0: flash@8000000 {
				/* Physical flash size is 1MByte but the last 148kByte
				 * are assigned to the wireless firmware running on
				 * Cortex-M0 companion.
				 */
				reg = <0x08000000 DT_SIZE_K(876)>;
				ranges = <0 0x8000000 DT_SIZE_K(876)>;
			};
		};
	};
};

&pwr {
	wkup-pin@2 {
		reg = <0x2>;
		wkup-gpios = <&gpioc 13 STM32_PWR_WKUP_PIN_NOT_MUXED>;
	};

	wkup-pin@3 {
		reg = <0x3>;
		wkup-gpios = <&gpioc 12 STM32_PWR_WKUP_PIN_NOT_MUXED>;
	};

	wkup-pin@5 {
		reg = <0x5>;
		wkup-gpios = <&gpioc 5 STM32_PWR_WKUP_PIN_NOT_MUXED>;
	};
};
