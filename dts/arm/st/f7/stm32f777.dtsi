#include <st/f7/stm32f767.dtsi>

/ {
	soc {
		compatible = "st,stm32f777", "st,stm32f7", "simple-bus";

		cryp: crypto@50060000 {
			compatible = "st,stm32-cryp";
			reg = <0x50060000 0x400>;
			clocks = <&rcc STM32_CLOCK(AHB2, 4)>;
			resets = <&rctl STM32_RESET(AHB2, 4)>;
			interrupts = <79 0>;
			status = "disabled";
		};
	};
};
