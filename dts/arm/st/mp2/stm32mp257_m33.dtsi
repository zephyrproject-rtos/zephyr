#include <arm/armv8-m.dtsi>
#include <freq.h>
#include <mem.h>
#include <zephyr/dt-bindings/clock/stm32mp2_clock.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-m33";
			reg = <0>;
		};
	};

	ddr_code: memory0@80100000 {
		compatible = "mmio-sram";
		reg = <0x80100000 DT_SIZE_K(128)>;
	};

	ddr_sys: memory1@80a00000 {
		compatible = "mmio-sram";
		reg = <0x80a00000 DT_SIZE_K(256)>;
	};

	soc {
		compatible = "st,stm32mp257", "st,stm32mp2", "simple-bus";

		rcc: rcc@44200000  {
			compatible = "st,stm32mp2-rcc";
			clocks-controller;
			#clock-cells = <2>;
			reg = <0x44200000 DT_SIZE_K(64)>;
		};

		exti: interrupt-controller@46230000 {
			compatible = "st,stm32-exti";
			interrupt-controller;
			#interrupt-cells = <1>;
			#address-cells = <1>;
			reg = <0x46230000 DT_SIZE_K(1)>;
			num-lines = <16>;
			interrupts = <17 0>, <18 0>, <19 0>, <20 0>,
					 <21 0>, <22 0>, <23 0>, <24 0>,
					 <25 0>, <26 0>, <27 0>, <28 0>,
					 <29 0>, <30 0>, <31 0>, <32 0>;
			interrupt-names = "line0", "line1", "line2", "line3",
					  "line4", "line5", "line6", "line7",
					  "line8", "line9", "line10", "line11",
					  "line12", "line13", "line14", "line15";
			line-ranges = <0 1>, <1 1>, <2 1>, <3 1>,
				      <4 1>, <5 1>, <6 1>, <7 1>,
				      <8 1>, <9 1>, <10 1>, <11 1>,
				      <12 1>, <13 1>, <14 1>, <15 1>;
		};

		pinctrl: pin-controller@44240000 {
			compatible = "st,stm32-pinctrl";
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x44240000 0x2000>;

			gpioa: gpio@44240000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44240000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOA, CLK)>;
			};

			gpiob: gpio@44250000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44250000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOB, CLK)>;
			};

			gpioc: gpio@44260000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44260000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOC, CLK)>;
			};

			gpiod: gpio@44270000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44270000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOD, CLK)>;
			};

			gpioe: gpio@44280000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44280000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOE, CLK)>;
			};

			gpiof: gpio@44290000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x44290000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOF, CLK)>;
			};

			gpiog: gpio@442a0000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x442a0000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOG, CLK)>;
			};

			gpioh: gpio@442b0000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x442b0000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOH, CLK)>;
			};

			gpioi: gpio@442c0000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x442c0000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOI, CLK)>;
			};

			gpioj: gpio@442d0000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x442d0000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOJ, CLK)>;
			};

			gpiok: gpio@442e0000 {
				compatible = "st,stm32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x442e0000 DT_SIZE_K(1)>;
				clocks = <&rcc STM32_CLOCK(GPIOK, CLK)>;
			};
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <4>;
};
