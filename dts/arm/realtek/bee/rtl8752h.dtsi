#include <mem.h>
#include <arm/armv6-m.dtsi>
#include <freq.h>
#include <dt-bindings/pinctrl/rtl8752h-pinctrl.h>
#include <dt-bindings/clock/rtl8752h-clocks.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	chosen {
		zephyr,flash = &flash;
		zephyr,flash-controller = &fmc;
		zephyr,sram = &data_ram_app_0;
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-m0+";
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <1>;
			clock-frequency = <40000000>;
		};
	};

	rom {
		#address-cells = <1>;
		#size-cells = <1>;

		rom: memory@0 {
			/* rom code region */
			reg = <0x0 DT_SIZE_K(148)>;
		};

		bee_bt_controller: memory@25000 {
			/* bt controller code region */
			reg = <0x25000 DT_SIZE_K(196)>;
		};
	};

	bee_bt_hci: bee_bt_hci {
		compatible = "realtek,bee-bt-hci";
		status = "disabled";
	};

	soc {
		cctl: clock-controller@40000200 {
			compatible = "realtek,bee-cctl";
			reg = <0x40000200 0x400>;
			#clock-cells = <1>;
			status = "okay";
		};

		data_ram@200000 {
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x200000 DT_SIZE_K(104)>;

			data_ram_rsvd_0: memory@200000 {
				/* reserved memory for internal usage(e.g. bt stack) */
				compatible = "mmio-sram";
				reg = <0x200000 DT_SIZE_K(34)>;
			};

			data_ram_app_0: memory@208800 {
				compatible = "mmio-sram";
				reg = <0x208800 DT_SIZE_K(57)>;
			};

			data_ram_heap: memory@216c00 {
				compatible = "mmio-sram";
				reg = <0x216c00 DT_SIZE_K(13)>;
			};
		};

		buffer_ram@280000 {
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x280000 DT_SIZE_K(16)>;

			buffer_ram_rsvd0: memory@280000 {
				/* reserved memory for internal usage(e.g. bt stack) */
				compatible = "mmio-sram";
				reg = <0x280000 (DT_SIZE_K(1) + 512)>;
			};

			buffer_ram_heap: memory@280600 {
				compatible = "mmio-sram";
				reg = <0x280600 (DT_SIZE_K(14) + 512)>;
			};
		};

		cache@21a000 {
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x21a000 DT_SIZE_K(8)>;
		};

		fmc: flash-controller@40080000 {
			compatible = "realtek,rtl8752h-flash-controller";
			reg = <0x40080000 0x12c>;
			#address-cells = <1>;
			#size-cells = <1>;
			status = "okay";

			flash: flash@800000 {
				compatible = "soc-nv-flash";
				write-block-size = <1>;
				erase-block-size = <4096>;
				#address-cells = <1>;
				#size-cells = <1>;

				partitions {
					compatible = "fixed-partitions";
					#address-cells = <1>;
					#size-cells = <1>;

					rsvd_partition: partition@0 {
						label = "rsvd-image";
						reg = <0x0 DT_SIZE_K(4)>;
					};

					oem_cfg_partition: partition@1000 {
						label = "oem-cfg-image";
						reg = <0x1000 DT_SIZE_K(4)>;
					};

					ota_header_partition: partition@2000 {
						label = "ota-header-image";
						reg = <0x2000 DT_SIZE_K(4)>;
					};

					rom_patch_partition: partition@3000 {
						label = "rom-patch-image";
						reg = <0x3000 DT_SIZE_K(28)>;
					};

					fsbl_partition: partition@a000 {
						label = "fsbl-image";
						reg = <0xa000 DT_SIZE_K(4)>;
					};

					bt_stack_patch_partition: partition@b000 {
						label = "bt-stack-patch-image";
						reg = <0xb000 DT_SIZE_K(40)>;
					};
				};
			};
		};

		pinctrl: pin-controller@40000280 {
			compatible = "realtek,bee-pinctrl";
			reg = <0x40000280 0x864>;
		};

		gpioa: gpio@40001000 {
			compatible = "realtek,bee-gpio";
			gpio-controller;
			#gpio-cells = <2>;
			reg = <0x40001000 0x64>;
			clocks = <&cctl APB_CLK(GPIO)>;
			interrupts = <30 0>, <29 0>, <27 0>, <26 0>;
			status = "disabled";
		};

		uart0: serial@40011000 {
			compatible = "realtek,bee-uart";
			reg = <0x40011000 0x60>;
			clocks = <&cctl APB_CLK(UART0)>;
			interrupts = <11 0>;
			status = "disabled";
		};

		/* uart1 is reserved for realtek bee internal log system. */
		uart1: serial@40012000 {
			compatible = "realtek,bee-uart";
			reg = <0x40012000 0x60>;
			clocks = <&cctl APB_CLK(UART1)>;
			interrupts = <12 0>;
			status = "disabled";
		};

		uart2: serial@40012400 {
			compatible = "realtek,bee-uart";
			reg = <0x40012400 0x60>;
			clocks = <&cctl APB_CLK(UART2)>;
			interrupts = <31 0>;
			status = "disabled";
		};

		/* basic timers */
		timer2: timer@40002028 {
			compatible = "realtek,bee-timer", "realtek,bee-basic-timer";
			reg = <0x40002028 0x10>;
			clocks = <&cctl APB_CLK(TIMER)>;
			interrupts = <4 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};

		timer3: timer@4000203c {
			compatible = "realtek,bee-timer", "realtek,bee-basic-timer";
			reg = <0x4000203c 0x10>;
			clocks = <&cctl APB_CLK(TIMER)>;
			interrupts = <3 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};

		timer4: timer@40002050 {
			compatible = "realtek,bee-timer", "realtek,bee-basic-timer";
			reg = <0x40002050 0x10>;
			clocks = <&cctl APB_CLK(TIMER)>;
			interrupts = <8 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};

		timer5: timer@40002064 {
			compatible = "realtek,bee-timer", "realtek,bee-basic-timer";
			reg = <0x40002064 0x10>;
			clocks = <&cctl APB_CLK(TIMER)>;
			interrupts = <8 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};

		/* enhanced timers */
		timer6: timer@40003000 {
			compatible = "realtek,bee-timer", "realtek,bee-enhanced-timer";
			reg = <0x40003000 0x400>;
			clocks = <&cctl APB_CLK(ENHTIMER)>;
			interrupts = <24 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};

		timer7: timer@40003024 {
			compatible = "realtek,bee-timer", "realtek,bee-enhanced-timer";
			reg = <0x40003024 0x400>;
			clocks = <&cctl APB_CLK(ENHTIMER)>;
			interrupts = <25 0>;
			status = "disabled";

			counter {
				compatible = "realtek,bee-counter-timer";
				status = "disabled";
			};
		};
	};

	clocks {
		clk_32K_systick: clk-32K-systick {
			#clock-cells = <0>;
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_K(32)>;
			status = "okay";
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <3>;
};

&systick {
	external-clock-source;
};
