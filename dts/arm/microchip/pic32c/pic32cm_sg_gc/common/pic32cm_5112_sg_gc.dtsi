/ {
	soc {
		nvmctrl@44004000 {
			boot_flash: flash@8000000 {
				reg = <0x08000000 DT_SIZE_K(16)>;
				ranges = <0x0 0x08000000 DT_SIZE_K(16)>;
			};

			config_flash: flash@a000000 {
				reg = <0x0a000000 DT_SIZE_K(32)>;
				ranges = <0x0 0x0a000000 DT_SIZE_K(32)>;
			};

			program_flash: flash@c000000 {
				reg = <0x0c000000 DT_SIZE_K(512)>;
				ranges = <0x0 0x0c000000 DT_SIZE_K(512)>;
			};
		};

		sram0: memory@20000000 {
			reg = <0x20000000 DT_SIZE_K(128)>;
			ranges = <0x0 0x20000000 DT_SIZE_K(128)>;
		};
	};
};
