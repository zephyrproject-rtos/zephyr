#include <arm/armv8-m.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/clock/mchp_pic32cm_sg_gc_clock.h>

/ {
	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-m23";
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <1>;

			mpu: mpu@e000ed90 {
				compatible = "arm,armv8m-mpu";
				reg = <0xe000ed90 0x40>; /* 64 bytes for ARMv8-M MPU */
			};
		};
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;

		sram0: memory@20000000 {
			compatible = "mmio-sram";
			#address-cells = <1>;
			#size-cells = <1>;
		};

		nvmctrl: nvmctrl@44004000 {
			reg = <0x44004000 0x2000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges;

			boot_flash: flash@8000000 {
				compatible = "soc-nv-flash";
				#address-cells = <1>;
				#size-cells = <1>;
			};

			config_flash: flash@a000000 {
				compatible = "soc-nv-flash";
				#address-cells = <1>;
				#size-cells = <1>;
			};

			program_flash: flash@c000000 {
				compatible = "soc-nv-flash";
				#address-cells = <1>;
				#size-cells = <1>;
			};
		};

		clock: clock@4400a000 {
			compatible = "microchip,pic32cm-sg-gc-clock";
			reg = <0x4400a000 0x60>, <0x44006000 0x8c>,
			      <0x45008000 0x20>, <0x44008000 0x11c>, <0x45002000 0x30>;
			reg-names = "mclk", "oscctrl",
				    "osc32kctrl", "gclk", "supc";
			interrupts = <4 0>, <5 0>, <6 0>,
				     <7 0>, <8 0>, <9 0>;
			interrupt-names = "xosc", "dfll", "pll",
					  "xosc32k-rdy", "xosc32k-fail", "mclk-rdy";

			xosc: xosc {
				compatible = "microchip,pic32cm-sg-gc-xosc";
			};

			dfll48m: dfll48m {
				compatible = "microchip,pic32cm-sg-gc-dfll48m";
			};

			dpll0: dpll0 {
				compatible = "microchip,pic32cm-sg-gc-dpll";
			};

			rtcclock: rtcclock {
				compatible = "microchip,pic32cm-sg-gc-rtc";
				#clock-cells = <1>;
			};

			xosc32k: xosc32k {
				compatible = "microchip,pic32cm-sg-gc-xosc32k";
			};

			gclkgen: gclkgen {
				compatible = "microchip,pic32cm-sg-gc-gclkgen";
			};

			gclkperiph: gclkperiph {
				compatible = "microchip,pic32cm-sg-gc-gclkperiph";
				#clock-cells = <1>;
			};

			mclkdomain: mclkdomain {
				compatible = "microchip,pic32cm-sg-gc-mclkdomain";
			};

			mclkperiph: mclkperiph {
				compatible = "microchip,pic32cm-sg-gc-mclkperiph";
				#clock-cells = <1>;
			};
		};

		pinctrl: pinctrl@44800000 {
			compatible = "microchip,port-g1-pinctrl";
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x44800000 0x200>;
			ranges = <0x44800000 0x44800000 0x200>;

			porta: gpio@44800000 {
				compatible = "microchip,port-g1-gpio";
				reg = <0x44800000 0x80>;
				gpio-controller;
				#gpio-cells = <2>;
				#microchip,pin-cells = <2>;
				status = "disabled";
			};

			portb: gpio@44800080 {
				compatible = "microchip,port-g1-gpio";
				reg = <0x44800080 0x80>;
				gpio-controller;
				#gpio-cells = <2>;
				#microchip,pin-cells = <2>;
				status = "disabled";
			};

			portc: gpio@44800100 {
				compatible = "microchip,port-g1-gpio";
				reg = <0x44800100 0x80>;
				gpio-controller;
				#gpio-cells = <2>;
				#microchip,pin-cells = <2>;
				status = "disabled";
			};

			portd: gpio@44800180 {
				compatible = "microchip,port-g1-gpio";
				reg = <0x44800180 0x80>;
				gpio-controller;
				#gpio-cells = <2>;
				#microchip,pin-cells = <2>;
				status = "disabled";
			};
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <2>;
};
