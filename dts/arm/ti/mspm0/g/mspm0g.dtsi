#include <ti/mspm0/mspm0.dtsi>

/{
	clocks: clock-buses {
		pll: pll {
			compatible = "ti,mspm0-pll";
			clocks = <&sysosc 0>;
			p-div = <2>;
			q-div = <5>;
			clk1-div = <2>;
			clk2x-div = <2>;
			#clock-cells = <0>;
			status = "okay";
		};
	};
};
