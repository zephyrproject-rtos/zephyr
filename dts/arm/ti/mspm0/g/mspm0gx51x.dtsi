#include <ti/mspm0/g/mspm0g.dtsi>

/ {
	soc {
                gpioc: gpio@400a4000 {
                compatible = "ti,mspm0-gpio";
                reg = <0x400a4000 0x2000>;
                interrupts = <1 0>;
                status = "disabled";
                gpio-controller;
                #gpio-cells = <2>;
                };

                i2c2: i2c@400f4000 {
                        compatible = "ti,mspm0-i2c";
                        clocks = <&ckm MSPM0_CLOCK_ULPCLK>;
                        clock-frequency = <I2C_BITRATE_STANDARD>;
                        #address-cells = <1>;
                        #size-cells = <0>;
                        reg = <0x400f4000 0x2000>;
                        interrupts = <25 0>;
                        status = "disabled";
                };
	};
};