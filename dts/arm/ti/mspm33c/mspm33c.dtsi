#include <arm/armv8-m.dtsi>
#include <freq.h>

/ {
	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-m33";
			reg = <0>;
			clock-frequency = <DT_FREQ_M(32)>;
		};
	};

	soc {
		sram0: memory@30000000 {
			compatible = "mmio-sram";
		};

		flash_controller: flash-controller@40042000 {
			reg = <0x40042000 DT_SIZE_K(8)>;
			interrupts = <2 0>;
			ranges;
			#address-cells = <1>;
			#size-cells = <1>;

			flash0: flash@10000000 {
				compatible = "soc-nv-flash";
				erase-block-size = <DT_SIZE_K(2)>;
				write-block-size = <16>;
				#address-cells = <1>;
				#size-cells = <1>;
			};
		};

		pinctrl: pin-controller@400f0000 {
			compatible = "ti,mspm0-pinctrl";
			#address-cells = <1>;
			#size-cells = <1>;
			reg = <0x400f0000 0x6000>;

			gpioa: gpio@400f0000 {
				compatible = "ti,mspm0-gpio";
				reg = <0x400f0000 0x2000>;
				interrupts = <6 0>;
				status = "disabled";
				gpio-controller;
				#gpio-cells = <2>;
			};

			gpiob: gpio@400f2000 {
				compatible = "ti,mspm0-gpio";
				reg = <0x400f2000 0x2000>;
				interrupts = <7 0>;
				status = "disabled";
				gpio-controller;
				#gpio-cells = <2>;
			};

			gpioc: gpio@400f4000 {
				compatible = "ti,mspm0-gpio";
				reg = <0x400f4000 0x2000>;
				interrupts = <8 0>;
				status = "disabled";
				gpio-controller;
				#gpio-cells = <2>;
			};
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <2>;
};
