/ {
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		sram0_s: sram0_s@34000000 {
			/* Secure image memory */
			reg = <0x34000000 DT_SIZE_K(16)>;
		};

		sram0_ns: sram0_ns@24004000 {
			/* Non-Secure image memory */
			reg = <0x24004000 DT_SIZE_K(44)>;
		};
	};
};

&flash0 {
	partitions {
		ranges;
		#address-cells = <1>;
		#size-cells = <1>;

		slot0_partition: partition@0 {
			compatible = "zephyr,mapped-partition";
			label = "slot0_s";
			reg = <0x0 DT_SIZE_K(128)>;
		};

		slot0_ns_partition: partition@20000 {
			compatible = "zephyr,mapped-partition";
			label = "slot0_ns";
			reg = <0x20000 DT_SIZE_K(128)>;
		};
	};
};
