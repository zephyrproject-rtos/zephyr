			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt21: gpio@40310a80 {
			compatible = "infineon,gpio";
			reg = <0x40310a80 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <61 0>;
			gpio-controller;
			ngpios = <4>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt23: gpio@40310b80 {
			compatible = "infineon,gpio";
			reg = <0x40310b80 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <63 0>;
			gpio-controller;
			ngpios = <5>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt24: gpio@40310c00 {
			compatible = "infineon,gpio";
			reg = <0x40310c00 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <64 0>;
			gpio-controller;
			ngpios = <2>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt25: gpio@40310c80 {
			compatible = "infineon,gpio";
			reg = <0x40310c80 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <65 0>;
			gpio-controller;
			ngpios = <6>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt26: gpio@40310d00 {
			compatible = "infineon,gpio";
			reg = <0x40310d00 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <66 0>;
			gpio-controller;
			ngpios = <5>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt27: gpio@40310d80 {
			compatible = "infineon,gpio";
			reg = <0x40310d80 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <67 0>;
			gpio-controller;
			ngpios = <2>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt28: gpio@40310e00 {
			compatible = "infineon,gpio";
			reg = <0x40310e00 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <68 0>;
			gpio-controller;
			ngpios = <6>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt29: gpio@40310e80 {
			compatible = "infineon,gpio";
			reg = <0x40310e80 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <37 0>;
			gpio-controller;
			ngpios = <2>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		gpio_prt30: gpio@40310f00 {
			compatible = "infineon,gpio";
			reg = <0x40310f00 0x80>;
			interrupt-parent = <&intmux_ch2>;
			interrupts = <69 0>;
			gpio-controller;
			ngpios = <2>;
			status = "disabled";
			#gpio-cells = <2>;
		};

		scb0: scb@40600000 {
			compatible = "infineon,scb";
			reg = <0x40600000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <20 0>;
			clk-dst = <0x0108>;
			status = "disabled";
		};

		scb1: scb@40610000 {
			compatible = "infineon,scb";
			reg = <0x40610000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <135 0>;
			clk-dst = <0x0109>;
			status = "disabled";
		};

		scb2: scb@40620000 {
			compatible = "infineon,scb";
			reg = <0x40620000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <136 0>;
			clk-dst = <0x010a>;
			status = "disabled";
		};

		scb3: scb@40630000 {
			compatible = "infineon,scb";
			reg = <0x40630000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <137 0>;
			clk-dst = <0x010b>;
			status = "disabled";
		};

		scb4: scb@40640000 {
			compatible = "infineon,scb";
			reg = <0x40640000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <138 0>;
			clk-dst = <0x010c>;
			status = "disabled";
		};

		scb5: scb@40650000 {
			compatible = "infineon,scb";
			reg = <0x40650000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <139 0>;
			clk-dst = <0x010d>;
			status = "disabled";
		};

		scb6: scb@40660000 {
			compatible = "infineon,scb";
			reg = <0x40660000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <140 0>;
			clk-dst = <0x010e>;
			status = "disabled";
		};

		scb7: scb@40670000 {
			compatible = "infineon,scb";
			reg = <0x40670000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <141 0>;
			clk-dst = <0x010f>;
			status = "disabled";
		};

		scb8: scb@40680000 {
			compatible = "infineon,scb";
			reg = <0x40680000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <142 0>;
			clk-dst = <0x0110>;
			status = "disabled";
		};

		scb9: scb@40690000 {
			compatible = "infineon,scb";
			reg = <0x40690000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <143 0>;
			clk-dst = <0x0111>;
			status = "disabled";
		};

		scb10: scb@406a0000 {
			compatible = "infineon,scb";
			reg = <0x406a0000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <144 0>;
			clk-dst = <0x0112>;
			status = "disabled";
		};

		scb11: scb@406b0000 {
			compatible = "infineon,scb";
			reg = <0x406b0000 0x10000>;
			interrupt-parent = <&intmux_ch3>;
			interrupts = <145 0>;
			clk-dst = <0x0113>;
			status = "disabled";
		};

		m7_0_itcm: itcm@a0000000 {
			compatible = "zephyr,memory-region", "arm,itcm";
			reg = <0xa0000000 DT_SIZE_K(64)>;
			zephyr,memory-region = "M7_0_ITCM";
			zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_FLASH)>;
		};

		m7_0_dtcm: dtcm@a0010000 {
			compatible = "zephyr,memory-region", "arm,dtcm";
			reg = <0xa0010000 DT_SIZE_K(64)>;
			zephyr,memory-region = "M7_0_DTCM";
			zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_RAM_NOCACHE)>;
		};

		m7_1_itcm: itcm@a0100000 {
			compatible = "zephyr,memory-region", "arm,itcm";
			reg = <0xa0100000 DT_SIZE_K(64)>;
			zephyr,memory-region = "M7_1_ITCM";
			zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_FLASH)>;
		};

		m7_1_dtcm: dtcm@a0110000 {
			compatible = "zephyr,memory-region", "arm,dtcm";
			reg = <0xa0110000 DT_SIZE_K(64)>;
			zephyr,memory-region = "M7_1_DTCM";
			zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_RAM_NOCACHE)>;
		};
	};
};
