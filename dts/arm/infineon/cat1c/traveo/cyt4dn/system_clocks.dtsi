#include <freq.h>
#include <zephyr/dt-bindings/pinctrl/ifx_cat1-pinctrl.h>

/ {
	clocks: clocks {
		oscillators: oscillators {
			#address-cells = <1>;
			#size-cells = <0>;

			eco: eco@2 {
				compatible = "infineon,clk-osc";
				reg = <0x2>;
				#clock-cells = <0>;
				clock-frequency = <DT_FREQ_M(16)>;
				status = "disabled";
			};
		};

		pll {
			#address-cells = <1>;
			#size-cells = <0>;

			pll0: pll400@1 {
				compatible = "infineon,clk-pll";
				reg = <0x1>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <40>;
				q-div = <1>;
				output-div = <2>;
				status = "disabled";
			};

			pll1: pll400@2 {
				compatible = "infineon,clk-pll";
				reg = <0x2>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <25>;
				q-div = <1>;
				output-div = <2>;
				status = "disabled";
			};

			pll2: pll400@3 {
				compatible = "infineon,clk-pll";
				reg = <0x3>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <40>;
				q-div = <1>;
				output-div = <2>;
				status = "disabled";
			};

			pll3: pll400@4 {
				compatible = "infineon,clk-pll";
				reg = <0x4>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <31>;
				q-div = <1>;
				frac-div = <0x400000>;
				output-div = <2>;
				status = "disabled";
			};

			pll4: pll400@5 {
				compatible = "infineon,clk-pll";
				reg = <0x5>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <27>;
				q-div = <1>;
				output-div = <2>;
				frac-div = <0x800000>;
				status = "disabled";
			};

			pll5: pll@6 {
				compatible = "infineon,clk-pll";
				reg = <0x6>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <50>;
				q-div = <2>;
				output-div = <2>;
				status = "disabled";
			};

			pll6: pll@7 {
				compatible = "infineon,clk-pll";
				reg = <0x7>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <25>;
				q-div = <2>;
				output-div = <2>;
				status = "disabled";
			};

			pll7: pll@8 {
				compatible = "infineon,clk-pll";
				reg = <0x8>;
				#clock-cells = <0>;
				clocks = <&eco>;
				p-div = <50>;
				q-div = <2>;
				output-div = <2>;
				status = "disabled";
			};
		};

		rootclocks {
			#address-cells = <1>;
			#size-cells = <0>;

			clk_hf0: clk_hf@0 {
				compatible = "infineon,clk-hf";
				reg = <0x0>;
				#clock-cells = <0>;
				clocks = <&pll5>;
				divider = <1>;
				slow-clk-divider = <1>;
				status = "disabled";
			};

			clk_hf1: clk_hf@1 {
				compatible = "infineon,clk-hf";
				reg = <0x1>;
				#clock-cells = <0>;
				clocks = <&pll0>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf2: clk_hf@2 {
				compatible = "infineon,clk-hf";
				reg = <0x2>;
				#clock-cells = <0>;
				clocks = <&pll6>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf3: clk_hf@3 {
				compatible = "infineon,clk-hf";
				reg = <0x3>;
				#clock-cells = <0>;
				clocks = <&pll5>;
				divider = <2>;
				status = "disabled";
			};

			clk_hf4: clk_hf@4 {
				compatible = "infineon,clk-hf";
				reg = <0x4>;
				#clock-cells = <0>;
				clocks = <&pll5>;
				divider = <4>;
				status = "disabled";
			};

			clk_hf5: clk_hf@5 {
				compatible = "infineon,clk-hf";
				reg = <0x5>;
				#clock-cells = <0>;
				clocks = <&pll1>;
				divider = <2>;
				status = "disabled";
			};

			clk_hf6: clk_hf@6 {
				compatible = "infineon,clk-hf";
				reg = <0x6>;
				#clock-cells = <0>;
				clocks = <&pll1>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf7: clk_hf@7 {
				compatible = "infineon,clk-hf";
				reg = <0x7>;
				#clock-cells = <0>;
				clocks = <&pll1>;
				divider = <2>;
				status = "disabled";
			};

			clk_hf8: clk_hf@8 {
				compatible = "infineon,clk-hf";
				reg = <0x8>;
				#clock-cells = <0>;
				clocks = <&pll2>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf9: clk_hf@9 {
				compatible = "infineon,clk-hf";
				reg = <0x9>;
				#clock-cells = <0>;
				clocks = <&pll2>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf10: clk_hf@a {
				compatible = "infineon,clk-hf";
				reg = <0xa>;
				#clock-cells = <0>;
				clocks = <&pll3>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf11: clk_hf@b {
				compatible = "infineon,clk-hf";
				reg = <0xb>;
				#clock-cells = <0>;
				clocks = <&pll4>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf12: clk_hf@c {
				compatible = "infineon,clk-hf";
				reg = <0xc>;
				#clock-cells = <0>;
				clocks = <&pll4>;
				divider = <1>;
				status = "disabled";
			};

			clk_hf13: clk_hf@d {
				compatible = "infineon,clk-hf";
				reg = <0xd>;
				#clock-cells = <0>;
				clocks = <&pll4>;
				divider = <1>;
				status = "disabled";
			};
		};

		periclocks {
			clk_peri0: clk_peri0 {
				compatible = "infineon,clk-peri";
				#clock-cells = <1>;
				clocks = <&clk_hf0>;
				ifx,peri-clk-inst = <IFX_PERI_GRP_INST_SEL(0, 0)>;
				ifx,pclk-count = <84>;
				ifx,8-bit-max-divider = <9>;
				ifx,16-bit-max-divider = <16>;
				ifx,16-5-bit-max-divider = <7>;
				ifx,24-5-bit-max-divider = <3>;
			};

			clk_peri1: clk_peri1 {
				compatible = "infineon,clk-peri";
				#clock-cells = <1>;
				clocks = <&clk_hf2>;
				ifx,peri-clk-inst = <IFX_PERI_GRP_INST_SEL(1, 0)>;
				ifx,pclk-count = <21>;
				ifx,8-bit-max-divider = <3>;
				ifx,16-bit-max-divider = <4>;
				ifx,16-5-bit-max-divider = <0>;
				ifx,24-5-bit-max-divider = <7>;
			};
		};
	};
};
