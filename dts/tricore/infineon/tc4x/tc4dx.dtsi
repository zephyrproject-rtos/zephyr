#include <infineon/tc4x/tc4dx-irq.h>

&sys_pll {
	fpllppu: sys_pll@3 {
		compatible = "infineon,aurix-pll-clock";
		reg = <3>;
		clocks = <&sys_pll>;
		k-div = <1>;
		k-pre-div = "1.1";
		#clock-cells = <0>;
	};
};

/ {
	model = "infineon,tc4dx";
	compatible = "infineon,tc4dx";

	clocks {
		fsourceppu: fsourceppu {
			compatible = "infineon,aurix-clock-mux";
			clocks = <&fpllppu>;
			#clock-cells = <0>;
		};

		fppu: fppu {
			compatible = "infineon,aurix-clock";
			clocks = <&fsourceppu>;
			clock-frequency = <454545454>;
			#clock-cells = <0>;
		};

		fcpu0: fcpu0 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpu1: fcpu1 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpu2: fcpu2 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpu3: fcpu3 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpu4: fcpu4 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpu5: fcpu5 {
			compatible = "infineon,aurix-clock";
			clocks = <&fsri>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		fcpucs: fcpucs {
			compatible = "infineon,aurix-clock";
			clocks = <&fsrics>;
			clock-frequency = <DT_FREQ_M(500)>;
			#clock-cells = <0>;
		};

		ffsi: ffsi {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(100)>;
			#clock-cells = <0>;
		};

		fleth: fleth {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(125)>;
			#clock-cells = <0>;
		};

		fgeth: fgeth {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(250)>;
			#clock-cells = <0>;
		};

		fcanxl: fcanxl {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(250)>;
			#clock-cells = <0>;
		};

		fcpb: fcpb {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(100)>;
			clock-names = "fcpb";
			status = "disabled";
			#clock-cells = <0>;
		};

		fegtm: fegtm {
			compatible = "infineon,aurix-clock";
			clocks = <&fsource0>;
			clock-frequency = <DT_FREQ_M(500)>;
			clock-names = "fegtm";
			status = "disabled";
			#clock-cells = <0>;
		};
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@f8800000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf8800000 0x40000>;
			clocks = <&fcpu0>;
		};

		cpu1: cpu@f8840000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf8840000 0x40000>;
			clocks = <&fcpu1>;
		};

		cpu2: cpu@f8880000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf8880000 0x40000>;
			clocks = <&fcpu2>;
		};

		cpu3: cpu@f88c0000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf88c0000 0x40000>;
			clocks = <&fcpu3>;
		};

		cpu4: cpu@f8900000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf8900000 0x40000>;
			clocks = <&fcpu4>;
		};

		cpu5: cpu@f8940000 {
			compatible = "infineon,tricore", "infineon,tc18";
			reg = <0xf8940000 0x40000>;
			clocks = <&fcpu5>;
		};
	};

	dmu_hci: flash_controller@f8040000 {
		compatible = "infineon,tc4x-dmu";
		#address-cells = <1>;
		#size-cells = <1>;
		reg = <0xf8040000 0x20>;

		flash0: flash@80000000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x80000000 DT_SIZE_M(4)>;
		};

		flash1: flash@80400000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x80400000 DT_SIZE_M(4)>;
		};

		flash2: flash@80800000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x80800000 DT_SIZE_M(2)>;
		};

		flash3: flash@80a00000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x80a00000 DT_SIZE_M(4)>;
		};

		flash4: flash@80e00000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x80e00000 DT_SIZE_M(4)>;
		};

		flash5: flash@81200000 {
			compatible = "infineon,tc4x-nv-flash", "soc-nv-flash";
			write-block-size = <256>;
			reg = <0x81200000 DT_SIZE_M(2)>;
		};
	};

	dsram0: memory@70000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x70000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM0";
	};

	dsram1: memory@60000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x60000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM1";
	};

	dsram2: memory@50000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x50000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM2";
	};

	dsram3: memory@40000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x40000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM3";
	};

	dsram4: memory@30000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x30000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM4";
	};

	dsram5: memory@20000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x20000000 DT_SIZE_K(240)>;
		zephyr,memory-region = "DSRAM5";
	};

	psram0: memory@70100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x70100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM0";
	};

	psram1: memory@60100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x60100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM1";
	};

	psram2: memory@50100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x50100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM2";
	};

	psram3: memory@40100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x40100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM3";
	};

	psram4: memory@30100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x30100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM4";
	};

	psram5: memory@20100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x20100000 DT_SIZE_K(64)>;
		zephyr,memory-region = "PSRAM5";
	};

	dlmu0: memory@90000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90000000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU0";
	};

	dlmu1: memory@90080000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90080000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU1";
	};

	dlmu2: memory@90100000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90100000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU2";
	};

	dlmu3: memory@90180000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90180000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU3";
	};

	dlmu4: memory@90200000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90200000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU4";
	};

	dlmu5: memory@90280000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x90280000 DT_SIZE_K(512)>;
		zephyr,memory-region = "DLMU5";
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;
		interrupt-parent = <&ir>;
		compatible = "simple-bus";
		ranges;

		wdtcpu0: wdt@f0000018 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf0000018 0x30>;
			status = "disabled";
		};

		wdtcpu1: wdt@f0000048 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf0000048 0x30>;
			status = "disabled";
		};

		wdtcpu2: wdt@f0000078 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf0000078 0x30>;
			status = "disabled";
		};

		wdtcpu3: wdt@f00000a8 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf00000a8 0x30>;
			status = "disabled";
		};

		wdtcpu4: wdt@f00000d8 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf00000d8 0x30>;
			status = "disabled";
		};

		wdtcpu5: wdt@f0000108 {
			compatible = "infineon,aurix-watchdog";
			reg = <0xf0000108 0x30>;
			status = "disabled";
		};

		stm0: timer@f8800000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf8800000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU0_SR0 1>, <IRQ_STMCPU0_SR2 1>,
				     <IRQ_STMCPU0_SR4 1>, <IRQ_STMCPU0_SR6 1>,
				     <IRQ_STMCPU0_SR8 1>, <IRQ_STMCPU0_SR10 1>,
				     <IRQ_STMCPU0_SR12 1>, <IRQ_STMCPU0_SR14 1>;
		};

		stm1: timer@f8840000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf8840000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU1_SR0 1>, <IRQ_STMCPU1_SR2 1>,
				     <IRQ_STMCPU1_SR4 1>, <IRQ_STMCPU1_SR6 1>,
				     <IRQ_STMCPU1_SR8 1>, <IRQ_STMCPU1_SR10 1>,
				     <IRQ_STMCPU1_SR12 1>, <IRQ_STMCPU1_SR14 1>;
		};

		stm2: timer@f8880000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf8880000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU2_SR0 1>, <IRQ_STMCPU2_SR2 1>,
				     <IRQ_STMCPU2_SR4 1>, <IRQ_STMCPU2_SR6 1>,
				     <IRQ_STMCPU2_SR8 1>, <IRQ_STMCPU2_SR10 1>,
				     <IRQ_STMCPU2_SR12 1>, <IRQ_STMCPU2_SR14 1>;
		};

		stm3: timer@f88c0000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf88c0000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU3_SR0 1>, <IRQ_STMCPU3_SR2 1>,
				     <IRQ_STMCPU3_SR4 1>, <IRQ_STMCPU3_SR6 1>,
				     <IRQ_STMCPU3_SR8 1>, <IRQ_STMCPU3_SR10 1>,
				     <IRQ_STMCPU3_SR12 1>, <IRQ_STMCPU3_SR14 1>;
		};

		stm4: timer@f8900000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf8900000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU4_SR0 1>, <IRQ_STMCPU4_SR2 1>,
				     <IRQ_STMCPU4_SR4 1>, <IRQ_STMCPU4_SR6 1>,
				     <IRQ_STMCPU4_SR8 1>, <IRQ_STMCPU4_SR10 1>,
				     <IRQ_STMCPU4_SR12 1>, <IRQ_STMCPU4_SR14 1>;
		};

		stm5: timer@f8940000 {
			compatible = "infineon,aurix-stm";
			reg = <0xf8940000 0x200>;
			clocks = <&fstm>;
			interrupts = <IRQ_STMCPU5_SR0 1>, <IRQ_STMCPU5_SR2 1>,
				     <IRQ_STMCPU5_SR4 1>, <IRQ_STMCPU5_SR6 1>,
				     <IRQ_STMCPU5_SR8 1>, <IRQ_STMCPU5_SR10 1>,
				     <IRQ_STMCPU5_SR12 1>, <IRQ_STMCPU5_SR14 1>;
		};

		pinctrl: pinctrl@f003a000 {
			compatible = "infineon,tc4x-pinctrl";
			reg = <0xf003a000 0xa400>;
			#address-cells = <1>;
			#size-cells = <1>;
			status = "okay";

			p00: gpio@f003a000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003a000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p01: gpio@f003a400 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003a400 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p02: gpio@f003a800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003a800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p03: gpio@f003ac00 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003ac00 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p04: gpio@f003b000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003b000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p10: gpio@f003c800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003c800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p13: gpio@f003d400 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003d400 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p14: gpio@f003d800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003d800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p15: gpio@f003dc00 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003dc00 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p16: gpio@f003e000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003e000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p20: gpio@f003f000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003f000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p21: gpio@f003f400 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003f400 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p22: gpio@f003f800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003f800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p23: gpio@f003fc00 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf003fc00 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p25: gpio@f0040400 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0040400 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p30: gpio@f0041800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0041800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p31: gpio@f0041c00 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0041c00 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p32: gpio@f0042000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0042000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p33: gpio@f0042400 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0042400 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p34: gpio@f0042800 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0042800 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p35: gpio@f0042c00 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0042c00 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};

			p40: gpio@f0044000 {
				compatible = "infineon,tc4x-gpio";
				reg = <0xf0044000 0x400>;
				gpio-controller;
				#gpio-cells = <2>;
				status = "disabled";
			};
		};

		asclin0: asclin@f46c0000 {
			reg = <0xf46c0000 512>;
			interrupts = <IRQ_ASCLIN0_TX 2>, <IRQ_ASCLIN0_RX 3>, <IRQ_ASCLIN0_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin1: asclin@f46c0200 {
			reg = <0xf46c0200 512>;
			interrupts = <IRQ_ASCLIN1_TX 2>, <IRQ_ASCLIN1_RX 3>, <IRQ_ASCLIN1_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin2: asclin@f46c0400 {
			reg = <0xf46c0400 512>;
			interrupts = <IRQ_ASCLIN2_TX 2>, <IRQ_ASCLIN2_RX 3>, <IRQ_ASCLIN2_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin3: asclin@f46c0600 {
			reg = <0xf46c0600 512>;
			interrupts = <IRQ_ASCLIN3_TX 2>, <IRQ_ASCLIN3_RX 3>, <IRQ_ASCLIN3_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin4: asclin@f46c0800 {
			reg = <0xf46c0800 512>;
			interrupts = <IRQ_ASCLIN4_TX 2>, <IRQ_ASCLIN4_RX 3>, <IRQ_ASCLIN4_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin5: asclin@f46c0a00 {
			reg = <0xf46c0a00 512>;
			interrupts = <IRQ_ASCLIN5_TX 2>, <IRQ_ASCLIN5_RX 3>, <IRQ_ASCLIN5_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin6: asclin@f46c0c00 {
			reg = <0xf46c0c00 512>;
			interrupts = <IRQ_ASCLIN6_TX 2>, <IRQ_ASCLIN6_RX 3>, <IRQ_ASCLIN6_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
