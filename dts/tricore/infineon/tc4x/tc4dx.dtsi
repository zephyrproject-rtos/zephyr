			status = "disabled";
		};

		asclin5: asclin@f46c0a00 {
			reg = <0xF46C0A00 512>;
			interrupts = <IRQ_ASCLIN5_TX 2>, <IRQ_ASCLIN5_RX 3>, <IRQ_ASCLIN5_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin6: asclin@f46c0c00 {
			reg = <0xF46C0C00 512>;
			interrupts = <IRQ_ASCLIN6_TX 2>, <IRQ_ASCLIN6_RX 3>, <IRQ_ASCLIN6_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin7: asclin@f46c0e00 {
			reg = <0xF46C0E00 512>;
			interrupts = <IRQ_ASCLIN7_TX 2>, <IRQ_ASCLIN7_RX 3>, <IRQ_ASCLIN7_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin8: asclin@f46c1000 {
			reg = <0xF46C1000 512>;
			interrupts = <IRQ_ASCLIN8_TX 2>, <IRQ_ASCLIN8_RX 3>, <IRQ_ASCLIN8_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin9: asclin@f46c1200 {
			reg = <0xF46C1200 512>;
			interrupts = <IRQ_ASCLIN9_TX 2>, <IRQ_ASCLIN9_RX 3>, <IRQ_ASCLIN9_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin10: asclin@f46c1400 {
			reg = <0xF46C1400 512>;
			interrupts = <IRQ_ASCLIN10_TX 2>, <IRQ_ASCLIN10_RX 3>, <IRQ_ASCLIN10_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin11: asclin@f46c1600 {
			reg = <0xF46C1600 512>;
			interrupts = <IRQ_ASCLIN11_TX 2>, <IRQ_ASCLIN11_RX 3>, <IRQ_ASCLIN11_ERR 4>;
			interrupt-names = "tx", "rx", "err";
			clocks = <&ccu CLOCK_FASCLINF>, <&ccu CLOCK_FASCLINS>;
			clock-names = "fasclinf", "fasclins";
			status = "disabled";
		};

		asclin12: asclin@f46c1800 {
			reg = <0xF46C1800 512>;
			interrupts = <IRQ_ASCLIN12_TX 2>, <IRQ_ASCLIN12_RX 3>, <IRQ_ASCLIN12_ERR 4>;
			interrupt-names = "tx", "rx", "err";
