// 0x40001000 - watchdog
// 0x40001008 - system clock
// 0x4000100C - power

#include <freq.h>
#include <mem.h>

/ {
	soc {
		sram: memory@20000000 {
			compatible = "mmio-sram";
			reg = <0x20000000 0>;

			sram0 = {
				reg = <SOC_SRAM_SIZE>;
			};
			sram1 = {
				reg = <DT_SIZE_K(2)>;
			};
		};

		flash: flash-controller@40001800 {
			compatible = "wch,ch5xx-flash-controller";
			reg = <0x40001800 0x400>;
			#address-cells = <1>;
			#size-cells = <1>;

			flash0: flash@00000000 {
				compatible = "soc-nv-flash";
				reg = <0x00000000 0>;

				codeflash = {
					reg = <SOC_CODEFLASH_SIZE>;
				};
				dataflash = {
					reg = <DT_SIZE_K(32)>;
				};
				bootloader = {
					reg = <DT_SIZE_K(24)>;
				};
				infoflash = {
					reg = <DT_SIZE_K(8)>;
				};
			};
		};

		pwr: pwr@4000100C {
			compatible = "wch,ch5xx-pwr";
			reg = <0x4000100C 0x20>;
		};
	}
}
