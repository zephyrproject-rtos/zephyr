/ {
	#address-cells = <1>;
	#size-cells = <1>;

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu@0 {
			clock-frequency = <0>;
			device_type = "cpu";
			compatible = "nuclei,bumblebee", "riscv";
			reg = <0>;
			riscv,isa = "rv32imac";
		};
	};

	flash0: flash@8000000 {
		compatible = "soc-nv-flash";
		label = "FLASH_GD32";
	};

	sram0: memory@20000000 {
		compatible = "mmio-sram";
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "gigadevice,gd32vf103-soc", "simple-bus";
		ranges;

		eclic: interrupt-controller@d2000000 {
			#interrupt-cells = <2>;
			compatible = "nuclei,eclic";
			interrupt-controller;
			reg = <0xd2000000 0x0001
			       0xd2000004 0x0001
			       0xd2000400 0x1000>;
			label = "GD32_ECLIC";
		};
	};

};

