#include <xtensa/xtensa.dtsi>

/ {
	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@9eac0000 {
			device_type = "cpu";
			compatible = "cdns,tensilica-xtensa-lx7";
			clock-frequency = <600000000>;
			reg = <0x9eac0000>;
		};
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		acp_intc: acp-intc {
			compatible = "amd,acp-intc";
			interrupt-controller;
			#interrupt-cells = <1>;
			status = "okay";
		};

		acp_host_dma: acp-host-dma {
			compatible = "amd,acp-host-dma";
			#dma-cells = <3>;
			status = "okay";
		};

		sdw_dai: acp-sdw-dai {
			compatible = "amd,acp-sdw-dai";
			status = "okay";
		};

		acp_sdw_dma: acp-sdw-dma@1243a00 {
			compatible = "amd,acp-sdw-dma";
			dma-channels = <64>;
			#dma-cells = <3>;
			reg = <0x1243a00 4>;
			status = "okay";
		};

		sdw_dai0: acp-sdw-dai0 {
			compatible = "amd,acp-sdw-dai";
			status = "okay";
			dai-index = <0>;
		};

		sdw_dai1: acp-sdw-dai1 {
			compatible = "amd,acp-sdw-dai";
