&flash0 {
	partitions {
		#address-cells = <0x1>;
		#size-cells = <0x1>;
		ranges;

		boot_partition: partition@0 {
 			compatible = "zephyr,mapped-partition";
			label = "mcuboot";
			reg = <0x0 0x10000>;
		};

		slot0_partition: partition@10000 {
 			compatible = "zephyr,mapped-partition";
			label = "image-0";
			reg = <0x10000 DT_SIZE_K(256)>;
		};

		slot1_partition: partition@50000 {
 			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0x50000 DT_SIZE_K(256)>;
		};

		storage_partition: partition@90000 {
 			compatible = "zephyr,mapped-partition";
			label = "storage";
			reg = <0x90000 0x370000>;
		};
	};
};
