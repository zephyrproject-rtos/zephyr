&flash0 {
	partitions {
		ranges;
		#address-cells = <0x1>;
		#size-cells = <0x1>;

		boot_partition: partition@0 {
			compatible = "zephyr,mapped-partition";
			label = "mcuboot";
			reg = <0x0 DT_SIZE_K(64)>;
		};

#ifdef WITH_CPU1_PARTITIONS
		slot0_partition: partition@10000 {
			compatible = "zephyr,mapped-partition";
			label = "image-0";
			reg = <0x10000 DT_SIZE_K(256)>;
		};

		slot1_partition: partition@50000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0x50000 DT_SIZE_K(256)>;
		};

		slot2_partition: partition@90000 {
			compatible = "zephyr,mapped-partition";
			label = "image-0-cpu1";
			reg = <0x90000 DT_SIZE_K(256)>;
		};

		slot3_partition: partition@d0000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1-cpu1";
			reg = <0xd0000 DT_SIZE_K(256)>;
		};

		storage_partition: partition@110000 {
			compatible = "zephyr,mapped-partition";
			label = "storage";
			reg = <0x110000 0x2f0000>;
		};
#else
		slot0_partition: partition@10000 {
			compatible = "zephyr,mapped-partition";
			label = "image-0";
			reg = <0x10000 0xd0000>;
		};

		slot1_partition: partition@e0000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0xe0000 0xd0000>;
		};

		storage_partition: partition@1b0000 {
			compatible = "zephyr,mapped-partition";
			label = "storage";
			reg = <0x1b0000 0x250000>;
		};
#endif
	};
};
