menu "LVGL NemaGFX support"

config LV_USE_NEMA_GFX
	bool "This option enable Think Silicon NemaGFX GPU2D hardware acceleration"
	imply FPU
	help
	   This option enable LVGL rendering hardware acceleration using
	   Think Silicon NemaGFX (GPU2D).

if LV_USE_NEMA_GFX

config LV_NEMA_HAL_RING_SIZE
	int "NemaGFX ring size"
	default 1024
	help
	  Size of the NemaGFX command ring.

choice LV_NEMA_LIB_CHOICE
	prompt "NemaGFX library variant"
	default LV_NEMA_LIB_M33_REVC

	config LV_NEMA_LIB_M33_REVC
		bool "M33 RevC"

	config LV_NEMA_LIB_M33_NEMAPVG
		bool "M33 NemaP-VG"

	config LV_NEMA_LIB_M55
		bool "M55"

	config LV_NEMA_LIB_M7
		bool "M7"
endchoice

config LV_USE_NEMA_LIB
	int
	default 1 if LV_NEMA_LIB_M33_REVC
	default 2 if LV_NEMA_LIB_M33_NEMAPVG
	default 3 if LV_NEMA_LIB_M55
	default 4 if LV_NEMA_LIB_M7

choice LV_NEMA_HAL_CHOICE
	prompt "NemaGFX HAL implementation"
	default LV_NEMA_HAL_CUSTOM

	config LV_NEMA_HAL_CUSTOM
	bool "Custom HAL"

	config LV_NEMA_HAL_STM32
	bool "STM32 HAL"
	depends on SOC_FAMILY_STM32
endchoice

config LV_USE_NEMA_HAL
	bool
	default 0 if LV_NEMA_HAL_CUSTOM
	default 1 if LV_NEMA_HAL_STM32

config LV_NEMA_STM32_HAL_INCLUDE
	string "STM32 HAL header include"

config LV_USE_NEMA_VG
	bool "This option enable NemaVG (Vector Graphics)"

if LV_USE_NEMA_VG
	config LV_NEMA_GFX_MAX_RESX
	int "Maximum horizontal resolution"
	default 800

	config LV_NEMA_GFX_MAX_RESY
	int "Maximum vertical resolution"
	default 600
endif # LV_USE_NEMA_VG

endif # LV_USE_NEMA_GFX

endmenu
