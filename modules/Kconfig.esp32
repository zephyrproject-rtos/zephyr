config ZEPHYR_HAL_ESPRESSIF_MODULE
	bool

config ZEPHYR_HAL_ESPRESSIF_MODULE_BLOBS
	bool

config BUILD_ONLY_NO_BLOBS
	default y if (DT_HAS_ESPRESSIF_ESP32_WIFI_ENABLED || \
		      DT_HAS_ESPRESSIF_ESP32_BT_HCI_ENABLED || \
		      DT_HAS_ESPRESSIF_ESP32_IEEE802154_ENABLED) && \
		     !ZEPHYR_HAL_ESPRESSIF_MODULE_BLOBS

config HAS_ESPRESSIF_HAL
	bool
	depends on SOC_FAMILY_ESPRESSIF_ESP32
