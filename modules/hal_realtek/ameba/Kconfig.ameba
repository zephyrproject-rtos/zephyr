config REALTEK_AMEBA_OS_WRAPPER
	bool "Realtek Ameba OS Wrapper Layer"
	depends on SOC_FAMILY_REALTEK_AMEBA
	help
	  Enable the Realtek Ameba OS wrapper abstraction layer.
	  This provides RTOS abstraction for Ameba HAL drivers.
