config MBEDTLS_CIPHERSUITE_TLS1_3_AES_256_GCM_SHA384
	bool "Ciphersuite TLS1_3_AES_256_GCM_SHA384"
	select MBEDTLS_SSL_PROTO_TLS1_3
	select PSA_WANT_ALG_SHA_384
	select PSA_WANT_KEY_TYPE_AES
	select PSA_WANT_ALG_GCM
	imply PSA_WANT_KEY_TYPE_ECC_PUBLIC_KEY
	imply PSA_WANT_ALG_ECDSA
	imply PSA_WANT_ECC_SECP_R1_256
	help
	  By default ECDSA with secp256r1 elliptic curve is implied by
	  this Kconfig option. Other elliptic curves or RSA can be enabled
	  depending on the application requirements.

