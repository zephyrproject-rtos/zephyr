config MBEDTLS_CIPHERSUITE_TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
	bool "Ciphersuite TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"
	imply MBEDTLS_SSL_PROTO_TLS1_2
	imply MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED
	imply PSA_WANT_ALG_SHA_256
	imply PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_IMPORT
	imply PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_EXPORT
	imply PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_GENERATE
	imply PSA_WANT_ECC_SECP_R1_256
