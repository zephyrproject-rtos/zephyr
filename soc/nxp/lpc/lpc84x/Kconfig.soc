config SOC_SERIES_LPC84X
	bool
	select SOC_FAMILY_LPC

config SOC_SERIES
	default "lpc84x" if SOC_SERIES_LPC84X

config SOC_LPC845
	bool
	select SOC_SERIES_LPC84X
	select SOC_PART_NUMBER_LPC845M301JBD64

config SOC_PART_NUMBER_LPC845M301JBD64
	bool

config SOC_PART_NUMBER
	default "LPC845M301JBD64" if SOC_PART_NUMBER_LPC845M301JBD64

config SOC
	default "lpc845" if SOC_LPC845
