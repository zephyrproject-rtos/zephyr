config SOC_MIMXRT798S_CM33_CPU0
	select CPU_CORTEX_M33
	select CLOCK_CONTROL
	select CPU_CORTEX_M_HAS_DWT
	select ARM
	select CPU_HAS_ARM_SAU
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select ARMV8_M_DSP
	select ARM_TRUSTZONE_M
	select CPU_CORTEX_M_HAS_SYSTICK
	select HAS_MCUX
	select HAS_MCUX_XCACHE
	select CACHE_MANAGEMENT
	select CPU_HAS_ICACHE
	select CPU_HAS_DCACHE
	select INIT_ARCH_HW_AT_BOOT
	select SOC_RESET_HOOK
	select SOC_EARLY_INIT_HOOK
	select WUC if PM
	select HAS_PM
	select SOC_IMXRT7XX_POWER_DOMAIN_COMPUTE

config SOC_MIMXRT798S_CM33_CPU1
	select CPU_CORTEX_M33
	select CLOCK_CONTROL
	select CPU_CORTEX_M_HAS_DWT
	select ARM
	select CPU_HAS_ARM_SAU
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select ARMV8_M_DSP
	select ARM_TRUSTZONE_M
	select CPU_CORTEX_M_HAS_SYSTICK
	select HAS_MCUX
	select HAS_PM
	select SOC_IMXRT7XX_POWER_DOMAIN_SENSE

config SOC_IMXRT7XX_POWER_DOMAIN_COMPUTE
	bool
	help
	  Selected when building for a core residing in the RT7xx Compute
	  power domain. This domain is controlled by PMC0/SLEEPCON0 and
	  covers the Common, Compute and Media rails.

config SOC_IMXRT7XX_POWER_DOMAIN_SENSE
	bool
	help
	  Selected when building for a core residing in the RT7xx Sense
	  power domain. This domain is controlled by PMC1/SLEEPCON1.

config SOC_MIMXRT7XX_PM_XIP_HANDOVER
	bool
	default y if FLASH_MCUX_XSPI_XIP
	depends on PM
	help
	  Internal (not a user option): compile in the XIP suspend/resume
	  helpers and invoke them from the low-power entry path. When entering
	  deep sleep / DSR while executing XIP, the XSPI controller and its
	  caches must be quiesced before the relevant power domain is removed
	  and brought back up afterwards. Auto-enabled for XIP
	  (FLASH_MCUX_XSPI_XIP) builds with PM.

config MCUX_CORE_SUFFIX
	default "_cm33_core0" if SOC_MIMXRT798S_CM33_CPU0
	default "_cm33_core1" if SOC_MIMXRT798S_CM33_CPU1
