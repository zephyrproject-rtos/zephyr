if SOC_SERIES_STM32H5X

configdefault CACHE_MANAGEMENT
	default y

choice CACHE_TYPE
	default EXTERNAL_CACHE
endchoice

config ROM_START_OFFSET
	default 0x400 if BOOTLOADER_MCUBOOT

config STM32_INT_FLASH_SECURE_BASE_ADDRESS
	default 0x0c000000

endif # SOC_SERIES_STM32H5X
