	select ARM
	select CPU_CORTEX_M33
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select ARMV8_M_DSP
	select CPU_CORTEX_M_HAS_DWT
	select HAS_STM32CUBE
	select STM32_HAL2
	select HAS_SWO
	select HAS_POWEROFF
	select SOC_EARLY_INIT_HOOK
