config SOC_SERIES_STM32MP2X
	bool
	select SOC_FAMILY_STM32

config SOC_SERIES
	default "stm32mp2x" if SOC_SERIES_STM32MP2X

config SOC_STM32MP257FXX_M33
	bool
	select SOC_SERIES_STM32MP2X

config SOC
	default "stm32mp257fxx" if SOC_STM32MP257FXX_M33
