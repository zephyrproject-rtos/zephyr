config SOC_SERIES_STM32MP13X
	select ARM
	select CPU_CORTEX_A7

	select ARM_ARCH_TIMER
	select CPU_HAS_FPU

	select KERNEL_DIRECT_MAP if MMU
	select SOC_EARLY_INIT_HOOK
	select SYS_CLOCK_EXISTS
	select XIP

	select HAS_STM32CUBE
