if SOC_STM32G031XX

config NUM_IRQS
	default 30

# Reduce kernel stack sizes to fit in 2 KiB RAM
config MAIN_STACK_SIZE
	default 640

config IDLE_STACK_SIZE
	default 200

config ISR_STACK_SIZE
	default 512

endif # SOC_STM32G031XX
