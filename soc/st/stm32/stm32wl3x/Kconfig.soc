config SOC_SERIES_STM32WL3X
	bool
	select SOC_FAMILY_STM32

config SOC_SERIES
	default "stm32wl3x" if SOC_SERIES_STM32WL3X

config SOC_STM32WL33XX
	bool
	select SOC_SERIES_STM32WL3X

config SOC
	default "stm32wl33" if SOC_STM32WL33XX
