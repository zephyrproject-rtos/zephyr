if SOC_SERIES_EFR32ZG28

config NUM_IRQS
	# must be >= the highest interrupt number used
	default 78

config PM
	select UART_INTERRUPT_DRIVEN

config GPIO_GECKO
	default y

config SOC_GECKO_SDID
	default 235 if SOC_SERIES_EFR32ZG28

endif
