if SOC_SERIES_XG22

config NUM_IRQS
	# must be >= the highest interrupt number used
	default 60

config PM
	select UART_INTERRUPT_DRIVEN

config GPIO_GECKO
	default y

config SOC_GECKO_SDID
	default 205

endif
