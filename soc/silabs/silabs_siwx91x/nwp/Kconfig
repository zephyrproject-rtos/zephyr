config SILABS_SIWX91X_NWP
	bool "Silabs Network Coprocessor"
	depends on DT_HAS_SILABS_SIWX91X_NWP_ENABLED
	select NET_BUF
	select POLL
	help
	  Add support for Network Coprocessor (also named NWP) presents on SiWx91x parts.

config SILABS_SIWX91X_NWP_WISECONNECT
	bool
	depends on SILABS_SIWX91X_NWP_BROKEN
	help
	  This implementation is no more provided

config SILABS_SIWX91X_NWP_BROKEN
	bool

if SILABS_SIWX91X_NWP

module = SIWX91X_NWP
module-str = siwx91x_nwp
source "subsys/logging/Kconfig.template.log_config"

config SIWX91X_NWP_INIT_PRIORITY
	int "Init priority"
	default 39
	help
	  Initialization priority of the SiWx91x Network Processor. NWP init must
	  have a higher priority than services that depend on it, such as Bluetooth,
	  Wi-Fi and crypto.

config SIWX91X_NWP_THREAD_STACK_SIZE
	int "Stack size for interrupt handler"
	default 1536
	help
	  Size of the stack used for internal thread which is ran for Network Co-Processor
	  communication.

config SIWX91X_NWP_THREAD_PRIO
	int "Priority for interrupt handler"
	default -15
	help
	  Priority level of the internal thread which is ran for Network Co-Processor
	  communication.

endif
