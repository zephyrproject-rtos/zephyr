if SOC_ACP_7_0

config DCACHE
	default y

choice CACHE_TYPE
	default ARCH_CACHE
endchoice

config DCACHE_LINE_SIZE
	default 128

config CACHE_MANAGEMENT
	default y

config XTENSA_TIMER
	default y

config SYS_CLOCK_HW_CYCLES_PER_SEC
	default $(dt_node_int_prop_int,/cpus/cpu@0,clock-frequency)

config KERNEL_ENTRY
	default "__start"

endif # SOC_ACP_7_0
