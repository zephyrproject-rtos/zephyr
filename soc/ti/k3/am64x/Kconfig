config SOC_SERIES_AM64X_M4
	select ARM
	select CPU_CORTEX_M4
	select CPU_HAS_FPU
	select CPU_CORTEX_M_HAS_SYSTICK
	select DYNAMIC_INTERRUPTS
	select CPU_CORTEX_M_HAS_DWT
	select UART_NS16550_ACCESS_WORD_ONLY
	select EXTERNAL_ADDRESS_TRANSLATION
	select MM_DRV
	select MM_TI_RAT
	select SOC_EARLY_INIT_HOOK

# There are multiple reasons why the MPU needs to be always enabled for this SoC
# series. This includes that a lot of peripherals are in memory regions that are
# cached by default and have no ordering guarantees and that firmware memory is
# either in a shared memory region while needing a non-shared region for atomic
# instructions to work or being in external DRAM, which is marked as XN by
# default.
config SOC_SERIES_AM64X_R5
	select ARM
	select ARM_MPU
	select CPU_CORTEX_R5
	select CPU_HAS_ARM_MPU
	select VFP_SP_D16
	select ARM_CUSTOM_INTERRUPT_CONTROLLER
	select TI_VIM
	select TI_DM_TIMER
	select UART_NS16550_ACCESS_WORD_ONLY if UART_NS16550
	select SOC_EARLY_INIT_HOOK
