# TI Tiva C TM4C123x Series

config SOC_SERIES_TM4C123X
	bool
	select SOC_FAMILY_TI_TIVA_C

config SOC_SERIES
	default "tm4c123x" if SOC_SERIES_TM4C123X

config SOC_TI_TM4C123GH6PM
	bool
	select SOC_SERIES_TM4C123X
	help
	  TI Tiva C Series TM4C123GH6PM (ARM Cortex-M4F, 80 MHz,
	  256 KB Flash, 32 KB SRAM)

config SOC
	default "ti_tm4c123gh6pm" if SOC_TI_TM4C123GH6PM
