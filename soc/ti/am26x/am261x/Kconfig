config SOC_SERIES_AM261X_R5F
	select ARM
	select ARM_CUSTOM_INTERRUPT_CONTROLLER
	select CPU_CORTEX_R5
	select CPU_HAS_ARM_MPU
	select CPU_HAS_FPU
	select CPU_HAS_DCACHE
	select CPU_HAS_ICACHE
	select PINCTRL
	select SOC_EARLY_INIT_HOOK
	select SOC_PREP_HOOK
	select TI_VIM

config SOC_PART_NUMBER
	default "AM2612" if SOC_AM261X_R5F0_0 || SOC_AM261X_R5F0_1

config CORES_IN_LOCKSTEP_MODE
	bool "Run R5F cores in lockstep mode"
	depends on SOC_SERIES_AM261X_R5F
	help
	  Configure the dual Cortex-R5F cores to operate in lockstep mode.
	  When disabled (default), cores run independently in dual-core mode.
