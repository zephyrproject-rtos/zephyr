config SOC_SERIES_MSPM0G3XXX
	bool
	select SOC_FAMILY_TI_MSPM0
	help
		Enable support for TI MSPM0G3XXX SoCs

config SOC_MSPM0G3507
	bool
	select SOC_SERIES_MSPM0G3XXX

config SOC_SERIES
	default "mspm0g3xxx" if SOC_SERIES_MSPM0G3XXX

config SOC
	default "mspm0g3507" if SOC_MSPM0G3507
