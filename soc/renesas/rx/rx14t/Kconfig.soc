config SOC_SERIES_RX14T
	bool
	select SOC_FAMILY_RENESAS_RX
	help
	  Renesas RX14T series

config SOC_R5F514T5AMFM
	bool
	select SOC_SERIES_RX14T
	help
	  SOC_R5F514T5AMFM

config SOC_SERIES
	default "rx14t" if SOC_SERIES_RX14T

config SOC
	default "r5f514t5amfm" if SOC_R5F514T5AMFM
