if SOC_FAMILY_AURIX

config SYS_CLOCK_HW_CYCLES_PER_SEC
	default $(dt_node_int_prop_int,/clocks/fstm,clock-frequency)

config CLOCK_CONTROL
	default y

config BUILD_OUTPUT_HEX
	default y

if TEST
# Increase the default CSA count to pass the tests
config TRICORE_CSA_COUNT
	default 384
endif

rsource "*/Kconfig.defconfig"

endif # SOC_FAMILY_AURIX
