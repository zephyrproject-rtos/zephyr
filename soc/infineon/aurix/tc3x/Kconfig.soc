# Infineon AURIX 2nd Generation Devices

config SOC_SERIES_TC3X
	bool
	select SOC_FAMILY_AURIX

config SOC_SERIES
	default "tc3x" if SOC_SERIES_TC3X

config SOC_TC37x
	bool
	select SOC_SERIES_TC3X

config SOC_TC39xB
	bool
	select SOC_SERIES_TC3X

config SOC_TC375TP
	bool
	select SOC_TC37x

config SOC_TC375TP_CPU0
	bool
	select SOC_TC375TP

config SOC_TC375TP_CPU1
	bool
	select SOC_TC375TP

config SOC_TC375TP_CPU2
	bool
	select SOC_TC375TP

config SOC_TC397XA
	bool
	select SOC_TC39xB

config SOC_TC397XA_CPU0
	bool
	select SOC_TC397XA

config SOC_TC397XA_CPU1
	bool
	select SOC_TC397XA

config SOC_TC397XA_CPU2
	bool
	select SOC_TC397XA

config SOC_TC397XA_CPU3
	bool
	select SOC_TC397XA

config SOC_TC397XA_CPU4
	bool
	select SOC_TC397XA

config SOC_TC397XA_CPU5
	bool
	select SOC_TC397XA

config SOC
	default "tc375tp" if SOC_TC375TP
	default "tc397xa" if SOC_TC397XA
