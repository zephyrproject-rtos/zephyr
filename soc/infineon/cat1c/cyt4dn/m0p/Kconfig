if SOC_SERIES_CYT4DN

config SOC_CYT4DN_CORE_M0PLUS
	bool
	default y if SOC_CYT4DNJBZS_M0PLUS
	select ARM
	select CPU_CORTEX_M0PLUS
	select CPU_CORTEX_M_HAS_SYSTICK
	select CPU_HAS_ARM_MPU
	select CPU_CORTEX_M_HAS_VTOR
	select SOC_PREP_HOOK
	select SOC_LATE_INIT_HOOK

config SOC_CYT4DN_START_M7_0
	bool "CYT4DN M7 Core 0 during M0+ startup"
	help
	  Enable starting M7 core 0 from M0+ core.

config SOC_CYT4DN_START_M7_1
	bool "CYT4DN M7 Core 1 during M0+ startup"
	help
	  Enable starting M7 core 1 from M0+ core.

endif
