if SOC_SERIES_CH32H41X

config SYS_CLOCK_HW_CYCLES_PER_SEC
	default $(dt_node_int_prop_int,/cpus/cpu@1,clock-frequency) if SOC_CH32H417_V5F
	default $(dt_node_int_prop_int,/cpus/cpu@0,clock-frequency)

config CLOCK_CONTROL
	default y if !SOC_CH32H417_V3F

rsource "Kconfig.defconfig.*"

endif # SOC_SERIES_CH32H41X
