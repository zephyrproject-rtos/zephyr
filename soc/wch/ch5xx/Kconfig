rsource "Kconfig_wch"

config SOC_FAMILY_CH5XX
	select RISCV
	select BUILD_OUTPUT_HEX
	select WCH_HAS_CODEFLASH
	select WCH_HAS_DATAFLASH
	select WCH_HAS_INFOFLASH
	select WCH_HAS_SRAM0

if SOC_FAMILY_CH5XX

config VECTOR_TABLE_SIZE
	int "Number of Interrupt and Exception Vectors"
	range 20 256
	help
	  This option defines the total number of interrupt and exception
	  vectors in the vector table.

rsource "ch5*/Kconfig"

endif # SOC_FAMILY_CH5XX
