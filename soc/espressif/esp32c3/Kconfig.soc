config SOC_SERIES_ESP32C3
	bool
	select SOC_FAMILY_ESPRESSIF_ESP32
	help
	  ESP32C3

config SOC_ESP32C3
	bool
	select SOC_SERIES_ESP32C3
	help
	  ESP32C3

config SOC_SERIES
	default "esp32c3" if SOC_SERIES_ESP32C3

config SOC
	default "esp32c3" if SOC_SERIES_ESP32C3
