if SOC_SERIES_ESP32S2

configdefault CACHE_MANAGEMENT
	default y

choice CACHE_TYPE
	default EXTERNAL_CACHE if CACHE_MANAGEMENT
endchoice

config MAIN_STACK_SIZE
	default 2048

if PM && TICKLESS_KERNEL

choice XTENSA_TIMER_LPM_TIMER
	default XTENSA_TIMER_LPM_TIMER_HOOK
endchoice

endif # PM && TICKLESS_KERNEL

endif # SOC_SERIES_ESP32S2
