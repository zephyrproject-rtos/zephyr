config TOOLCHAIN_ATFE
	def_bool y
	select PICOLIBC_SUPPORTED

config TOOLCHAIN_ATFE_SUPPORTS_THREAD_LOCAL_STORAGE
	depends on ARM || ARM64
	def_bool y
	select TOOLCHAIN_SUPPORTS_THREAD_LOCAL_STORAGE

config TOOLCHAIN_ATFE_SUPPORTS_GNU_EXTENSIONS
	def_bool y
	select TOOLCHAIN_SUPPORTS_GNU_EXTENSIONS
