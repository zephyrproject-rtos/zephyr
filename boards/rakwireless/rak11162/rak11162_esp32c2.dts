/dts-v1/;
#include <rakwireless/rak11160_esp32c2.dtsi>
#include <espressif/partitions_0x0_default_2M.dtsi>
#include "rak11162_esp32c2-pinctrl.dtsi"

/ {
	model = "RAK11162 WisBlock Core Module (ESP32-C2)";
	compatible = "rakwireless,rak11162-esp32c2";

	chosen {
		zephyr,sram = &sram1;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	aliases {
		watchdog0 = &wdt0;
	};

	soft_uart0: uart-bitbang {
		compatible = "zephyr,uart-bitbang";
		current-speed = <9600>;
		data-bits = <8>;
		parity = "none";
		stop-bits = "1";

		tx-gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;
		rx-gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;

		tx-timer = <&timer0>;
		rx-timer = <&timer0>;

		tx-fifo-size = <64>;
		rx-fifo-size = <64>;
	};
};

/*
 * Common board-level label for
 * the on-module ESP32-C2 <-> STM32WLE5 coprocessor UART link.
 */
coproc_uart: &uart1 {
	status = "okay";
	current-speed = <115200>;
};

&uart0 {
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&i2c0 {
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&adc0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&ledc0 {
	status = "okay";
	pinctrl-0 = <&ledc0_default>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		timer = <0>;
	};
};

&gpio0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&wifi {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

#include "rak11162_esp32c2_wisblock.dtsi"
