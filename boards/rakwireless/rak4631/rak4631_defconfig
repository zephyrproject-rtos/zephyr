# Enable MPU
CONFIG_ARM_MPU=y

# Enable hardware stack protection
CONFIG_HW_STACK_PROTECTION=y

# Enable RTT
CONFIG_USE_SEGGER_RTT=y

# Reassign pinctrl for WisBlock modules
CONFIG_PINCTRL_DYNAMIC=y

# Disable runtime PM by default
CONFIG_PM_DEVICE_RUNTIME_DEFAULT_ENABLE=n
