/dts-v1/;
#include <rakwireless/rak3112_appcpu.dtsi>
#include <espressif/partitions_0x0_amp_16M.dtsi>

/ {
	model = "RAK3312 WisBlock Core Module APPCPU";
	compatible = "rakwireless,rak3312";

	chosen {
		zephyr,code-partition = &slot0_appcpu_partition;
	};
};

&trng0 {
	status = "okay";
};

&ipm0 {
	status = "okay";
};
