# Enable Clocks
CONFIG_CLOCK_CONTROL=y

# Power Management
CONFIG_PM_DEVICE=y
CONFIG_NRFX_POWER=y

# GPIO
CONFIG_GPIO=y

# Memory Protection
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y
CONFIG_NULL_POINTER_EXCEPTION_DETECTION_NONE=y

# Cache
CONFIG_CACHE_MANAGEMENT=y
CONFIG_EXTERNAL_CACHE=y

# GRTC system timer
CONFIG_NRF_GRTC_START_SYSCOUNTER=y

# Regulator
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_INIT_PRIORITY=45

# Required for board.c dynamic pinctrl (wisblock_init)
CONFIG_PINCTRL_DYNAMIC=y
CONFIG_PINCTRL_KEEP_SLEEP_STATE=y
