if BOARD_RAK3362_NRF54L15_CPUAPP

config HAS_BT_CTLR
	default BT

config ROM_START_OFFSET
	default 0x800 if BOOTLOADER_MCUBOOT

endif # BOARD_RAK3362_NRF54L15_CPUAPP

if BOARD_RAK3362_NRF54L15_CPUAPP_NS

config BOARD_RAK3362
	select USE_DT_CODE_PARTITION

config HAS_BT_CTLR
	default BT

config BUILD_WITH_TFM
	default y

endif # BOARD_RAK3362_NRF54L15_CPUAPP_NS
