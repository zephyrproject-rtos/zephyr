/dts-v1/;

#include <renesas/ra/ra8/r7ka8p1kflcac_cm85.dtsi>
#include "ra8p1_titan_mini.dtsi"

/ {
	model = "Ruiside RA8P1 Titan Mini";
	compatible = "ruiside,ra8p1-titan-mini", "renesas,ra8p1", "renesas,ra8";

	chosen {
		zephyr,console = &uart2;
		zephyr,shell-uart = &uart2;
		zephyr,sram = &sram0;
		zephyr,flash = &code_mram_cm85;
		zephyr,flash-controller = &mram_ctrl;
		zephyr,code-partition = &slot0_partition;
		zephyr,entropy = &trng;
	};

	aliases {
		led0 = &led1;
		sw0 = &button0;
		sdhc0 = &sdhc0;
	};
};

&button0 {
	status = "okay";
};

&sci2 {
	pinctrl-0 = <&sci2_default>;
	pinctrl-names = "default";
	interrupts = <0 1>, <1 1>, <2 1>, <3 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";

	uart2: uart {
		current-speed = <115200>;
		status = "okay";
	};
};

&iic1 {
	#address-cells = <1>;
	#size-cells = <0>;
	clock-frequency = <I2C_BITRATE_FAST_PLUS>;
	pinctrl-0 = <&iic1_default>;
	pinctrl-names = "default";
	interrupts = <4 1>, <5 1>, <6 1>, <7 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";
};

/* SW1 user/boot button on P201, mapped to port IRQ4. */
&port_irq4 {
	interrupts = <8 12>;
	status = "okay";
};

/* RTL8211F PHY interrupt on P107, mapped to port IRQ31. */
&port_irq31 {
	interrupts = <9 12>;
	status = "okay";
};

&ulpt0 {
	interrupts = <10 1>;
	interrupt-names = "ulpti";
	status = "okay";

	timer {
		status = "okay";
	};
};

&ulpt1 {
	status = "okay";

	timer {
		status = "okay";
	};
};

&usbfs {
	interrupts = <11 12>, <12 12>;
	interrupt-names = "usbfs-i", "usbfs-r";
	status = "okay";

	zephyr_udc0: udc {
		status = "okay";
	};
};

&code_mram_cm85 {
	partitions {
		ranges;
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			compatible = "zephyr,mapped-partition";
			label = "mcuboot";
			reg = <0x0 DT_SIZE_K(64)>;
		};

		slot0_partition: partition@10000 {
			compatible = "zephyr,mapped-partition";
			label = "image-0";
			reg = <0x10000 DT_SIZE_K(344)>;
		};

		slot1_partition: partition@66000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0x66000 DT_SIZE_K(344)>;
		};

		storage_partition: partition@bc000 {
			compatible = "zephyr,mapped-partition";
			label = "storage";
			reg = <0xbc000 DT_SIZE_K(16)>;
		};
	};
};

&sdhc0 {
	interrupt-names = "accs", "card", "dma-req";
	interrupts = <13 12>, <14 12>, <15 12>;
	pinctrl-0 = <&sdhc0_default>;
	pinctrl-names = "default";
	status = "okay";

	sdmmc {
		compatible = "zephyr,sdmmc-disk";
		disk-name = "SD";
		status = "okay";
	};
};

&eswm {
	interrupts = <16 1>;
	interrupt-names = "gwdi";
	status = "okay";
};

&eth1 {
	phy-connection-type = "rgmii";
	local-mac-address = [74 90 50 01 02 04];
	phy-clock-type = "xtal";
	phy-handle = <&phy1>;
	pinctrl-0 = <&eth1_default>;
	pinctrl-names = "default";
	status = "okay";
};

&mdio0 {
	pinctrl-0 = <&mdio0_default>;
	pinctrl-names = "default";
	status = "okay";

	phy1: phy@1 {
		compatible = "realtek,rtl8211f";
		reg = <1>;
		int-gpios = <&ioport1 7 GPIO_ACTIVE_LOW>;
		reset-gpios = <&ioporta 7 GPIO_ACTIVE_HIGH>;
		realtek,rgmii-delay = "rxid";
		status = "okay";
	};
};
