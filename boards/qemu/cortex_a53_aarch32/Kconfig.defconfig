if BOARD_QEMU_CORTEX_A53_AARCH32

# QEMU loads Zephyr from a raw binary (-device loader), so always emit zephyr.bin.
config BUILD_OUTPUT_BIN
	default y

if QEMU_ICOUNT

config QEMU_ICOUNT_SHIFT
	default 4

config QEMU_ICOUNT_SLEEP
	default y

endif # QEMU_ICOUNT

endif # BOARD_QEMU_CORTEX_A53_AARCH32
