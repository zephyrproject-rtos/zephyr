/dts-v1/;

#include <infineon/tc3x/tc397xa_cpu0.dtsi>
#include "qemu_tc3x-pinctrl.dtsi"

/ {
	model = "QEMU AURIX TC39x";
	compatible = "infineon,qemu-tc39x";

	chosen {
		zephyr,flash = &flash0;
		zephyr,sram = &dsram0;
		zephyr,console = &asclin0;
		zephyr,shell-uart = &asclin0;
	};
};

&fosc {
	status = "okay";
};

&fstm {
	clock-frequency = <DT_FREQ_M(50)>;
};

&asclin0 {
	compatible = "infineon,asclin-uart";
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&stm0 {
	status = "okay";
};
