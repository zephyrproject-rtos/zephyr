/dts-v1/;

#include <qemu/virt-riscv64.dtsi>
#include <qemu/virt-riscv-plic.dtsi>

/ {
	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &ram0;
	};

	cpus {
		riscv,privilege-modes = "m", "s", "u";
	};
};

&uart0 {
	status = "okay";
};
