/dts-v1/;

#include "qemu_riscv32.dts"

&{/cpus/cpu@0} {
	riscv,isa-base = "rv32i";
	riscv,isa-extensions = "i", "m", "a", "c", "zicsr", "zifencei", "zfinx", "zdinx";
};

