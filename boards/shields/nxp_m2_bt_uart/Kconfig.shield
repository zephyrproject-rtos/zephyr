config SHIELD_NXP_M2_BT_UART
	def_bool $(shields_list_contains,nxp_m2_bt_uart)

if BT

config SYSTEM_WORKQUEUE_STACK_SIZE
	default 2048

config BT_LONG_WQ_STACK_SIZE
	default 2560

config MAIN_STACK_SIZE
	default 2560

if SHELL

config SHELL_STACK_SIZE
	default 4096

endif # SHELL

endif # BT
