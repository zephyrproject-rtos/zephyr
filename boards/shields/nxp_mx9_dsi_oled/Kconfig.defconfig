	default y

configdefault LV_Z_FULL_REFRESH
	default y

choice LV_COLOR_DEPTH
	default LV_COLOR_DEPTH_32
endchoice

endif # LVGL

endif # DISPLAY

endif # SHIELD_NXP_MX9_DSI_OLED
