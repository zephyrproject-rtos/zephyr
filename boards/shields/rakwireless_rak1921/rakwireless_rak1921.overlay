/ {
	chosen {
		zephyr,display = &rak1921_display;
	};
};

&wisblock_i2c1 {
	status = "okay";

	rak1921_display: ssd1306@3c {
		status = "okay";
		compatible = "solomon,ssd1306";
		reg = <0x3c>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0x22>;
	};
};
