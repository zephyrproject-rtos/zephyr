/dts-v1/;

#include <broadcom/bcm2710.dtsi>
#include <broadcom/bcm2711-pinctrl.dtsi>

/ {
	model = "Raspberry Pi Zero 2 W";
	compatible = "raspberrypi,model-zero-2-w", "brcm,bcm2710";

	chosen {
		zephyr,console = &uart1;
		zephyr,shell-uart = &uart1;
		zephyr,sram = &sram0;
	};
};

&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_gpio14>;
	current-speed = <115200>;
	status = "okay";
};

/*
 * Enable SPI0 on the 40-pin header. No pinctrl-0 here: SPI pin
 * roles can be application-specific (e.g. a display sharing the
 * MISO pin for a D/C line), so muxing is left to an application
 * overlay.
 */
&spi0 {
	status = "okay";
};
