/dts-v1/;
#include <arm/infineon/cat1c/traveo/cyt4dn/cyt4dn_m7.dtsi>
#include "kit_t2g_c2d6m_lite_common.dtsi"

/ {
	model = "Infineon Evaluation board for CYT4DNJBZS M7 Core 1";
	compatible = "infineon,kit_t2g_c2d6m_lite", "infineon,cyt4dn";

	aliases {
		led0 = &user_led3;
		sw0 = &user_bt2;
	};

	chosen {
		zephyr,sram = &sram_m7_1;
		zephyr,flash = &code_flash0;
		zephyr,dtcm = &dtcm;
		zephyr,itcm = &itcm;
		zephyr,code-partition = &m7_1_partition;
		zephyr,console = &uart9;
		zephyr,shell-uart = &uart9;
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_bt2: user_btn2 {
			label = "SW_1";
			gpios = <&gpio_prt0 3 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_1>;
		};
	};
};

&m7_1 {
	status = "okay";
};

&uart9 {
	status = "okay";
};

&gpio_prt0 {
	status = "okay";
};

&gpio_prt29 {
	status = "okay";
};
