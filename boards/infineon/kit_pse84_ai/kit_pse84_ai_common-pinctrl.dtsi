/* Configure pin control bias mode for uart2 pins */
&p6_7_scb2_uart_tx {
	drive-push-pull;
};

&p6_5_scb2_uart_rx {
	input-enable;
};

&p10_1_scb4_uart_tx {
	drive-push-pull;
};

&p10_0_scb4_uart_rx {
	input-enable;
};

&p10_3_scb4_uart_rts {
	drive-push-pull;
};

&p10_2_scb4_uart_cts {
	input-enable;
};
