#include <dt-bindings/pinctrl/silabs/xg28-pinctrl.h>

&pinctrl {
	usart0_default: usart0_default {
		group0 {
			pins = <USART0_TX_PD11>;
			drive-push-pull;
			output-high;
		};

		group1 {
			pins = <USART0_RX_PD12>;
			input-enable;
			silabs,input-filter;
		};
	};
};