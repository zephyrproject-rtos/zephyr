/dts-v1/;

#include <nxp/rw/nxp_rw6xx.dtsi>
#include "ubx_evk_iris_w1_common.dtsi"

/*
 * Ethernet variant for EVK-IRIS-W106-RW612 board
 */

&enet_mac {
	status = "okay";
	pinctrl-0 = <&pinmux_enet>;
	pinctrl-names = "default";
	phy-handle = <&phy>;
	zephyr,random-mac-address;
	phy-connection-type = "rmii";
};

&enet_mdio {
	status = "okay";
	pinctrl-0 = <&pinmux_mdio>;
	pinctrl-names = "default";

	phy: phy@2 {
		compatible = "microchip,ksz8081";
		reg = <2>;
		status = "okay";
		reset-gpios = <&hsgpio1 23 GPIO_ACTIVE_HIGH>;
		int-gpios = <&hsgpio0 21 GPIO_ACTIVE_HIGH>;
		microchip,interface-type = "rmii";
	};
};

/* XTAL is disconnected when using ethernet */
&xtal32 {
	status = "disabled";
};
