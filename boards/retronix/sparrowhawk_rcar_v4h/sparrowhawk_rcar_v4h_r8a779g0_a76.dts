/dts-v1/;
#include <mem.h>
#include <arm64/renesas/r8a779g0.dtsi>
#include "sparrowhawk_rcar_v4h_r8a779g0_a76-pinctrl.dtsi"

/ {
	model = "Retronix Sparrow Hawk on R-Car V4H";
	compatible = "retronix,sparrowhawk-v4h-ca76";

	chosen {
		zephyr,sram = &ram;
		zephyr,console = &hscif0;
		zephyr,shell-uart = &hscif0;
	};

	ram: memory@40000000 {
		device_type = "memory";
		reg = <0x0 0x40000000 0x0 DT_SIZE_G(2)>;
	};
};

/* USB serial */
&hscif0 {
	pinctrl-0 = <&hscif0_data_tx_default &hscif0_data_rx_default>;
	pinctrl-names = "default";
	status = "okay";
};
