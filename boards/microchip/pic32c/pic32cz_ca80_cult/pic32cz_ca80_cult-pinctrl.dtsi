#include <dt-bindings/pic32c/pic32cz_ca/pic32cz_ca80/pic32cz8110ca80208-pinctrl.h>

&pinctrl {
	sercom1_uart_default: sercom1_uart_default {
		group1 {
			pinmux = <PC4D_SERCOM1_PAD0>,
				 <PC7D_SERCOM1_PAD3>;
		};
	};
