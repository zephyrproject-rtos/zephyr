/dts-v1/;
#include <microchip/pic32c/pic32cm_sg_gc/pic32cm_gc00/pic32cm5112gc00100.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "PIC32CM GC00 Curiosity Pro";
	compatible = "microchip,pic32cm_gc00_cpro";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &program_flash;
		zephyr,code-partition = &code_partition;
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		sw0 = &button0;
		sw1 = &button1;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&porta 20 GPIO_ACTIVE_LOW>;
			label = "LED0";
		};

		led1: led_1 {
			gpios = <&porta 18 GPIO_ACTIVE_LOW>;
			label = "LED1";
		};
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&portb 7 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "SW0";
			zephyr,code = <INPUT_KEY_0>;
		};

		button1: button_1 {
			gpios = <&portb 11 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "SW1";
			zephyr,code = <INPUT_KEY_1>;
		};
	};
};

&boot_flash {
	partitions {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		boot_partition: partition@0 {
			label = "boot_flash";
			compatible = "zephyr,mapped-partition";
			reg = <0x0 DT_SIZE_K(16)>;
		};
	};
};

&program_flash {
	partitions {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		code_partition: partition@0 {
			label = "program_flash";
			compatible = "zephyr,mapped-partition";
			reg = <0x0 DT_SIZE_K(496)>;
		};

		storage_partition: partition@7c000 {
			label = "storage";
			compatible = "zephyr,mapped-partition";
			reg = <0x7c000 DT_SIZE_K(16)>;
		};
	};
};

&cpu0 {
	clock-frequency = <48000000>;
};

&porta {
	status = "okay";
};

&portb {
	status = "okay";
};
