config BOARD_EV48H83A
	select SOC_MEC1653B_NSZ if BOARD_EV48H83A_MEC1653B_NSZ
	select SOC_MEC1743_QLJ if BOARD_EV48H83A_MEC1743_QLJ
	select SOC_MEC1743_QSZ if BOARD_EV48H83A_MEC1743_QSZ
	select SOC_MEC1753_QLJ if BOARD_EV48H83A_MEC1753_QLJ
	select SOC_MEC1753_QSZ if BOARD_EV48H83A_MEC1753_QSZ
