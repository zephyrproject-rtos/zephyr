/dts-v1/;

#include <bflb/bl808.dtsi>
#include "m1s-pinctrl.dtsi"

/ {
	model = "Sipeed M1S";
	compatible = "bflb,bl808";

	chosen {
		zephyr,flash-controller = &sf_bank1;
		zephyr,flash = &w25q128jv;
		zephyr,code-partition = &slot0_partition;
		zephyr,sram = &all_ram;
		zephyr,console = &uart0;
		zephyr,log-uart = &log_uarts;
		zephyr,shell-uart = &uart0;
		zephyr,entropy = &sec_eng_trng;
	};

	aliases {
		watchdog0 = &wdt0;
	};

	log_uarts: log_uarts {
		compatible = "zephyr,log-uart";
		uarts = <&uart1>;
	};
};

&clk_flash {
	clocks = <&clk_bclk>;
	divider = <1>;
};

&sf_ctrl {
	override-bank1;
};

&sf_bank1 {
	reg = <0x58000000 DT_SIZE_M(16)>;
	ranges = <0x0 0x58000000 DT_SIZE_M(16)>;

	w25q128jv: flash@0 {
		compatible = "bflb,sf-flash", "soc-nv-flash";
		reg = <0 DT_SIZE_M(16)>;
		ranges;
		#address-cells = <1>;
		#size-cells = <1>;
		write-block-size = <4>;
		erase-block-size = <DT_SIZE_K(4)>;

		spi-bus-mode = <4>;
		sf-pad = <2>;
		jedec-id = [ef 40 18];

		/* The flash equipped on M1S modules doesn't support useful SFDP, and the
		 * flash header doesn't provide a working configuration.
		 * Manually set configuration for best performance.
		 */
		read-command = <0xeb>;
		read-dummy-cycles = <2>;
		continuous-read-command = <0xa0>;

		partitions {
			ranges;
			#address-cells = <1>;
			#size-cells = <1>;

			boot_header_partition: partition@0 {
				compatible = "zephyr,mapped-partition";
				label = "boot_header";
				reg = <0x00000000 0x2000>;
				read-only;
			};

			slot0_partition: partition@2000 {
				compatible = "zephyr,mapped-partition";
				label = "image-0";
				reg = <0x00002000 (DT_SIZE_M(8) - 0x2000)>;
				read-only;
			};

			storage_partition: partition@800000 {
				compatible = "zephyr,mapped-partition";
				label = "storage";
				reg = <0x00800000 DT_SIZE_M(8)>;
			};
		};
	};
};

&psram_uhs_ctrl {
	status = "okay";
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(320)>;
};

&uart0 {
	status = "okay";
	current-speed = <115200>;

	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&uart1 {
	status = "okay";
	current-speed = <115200>;

	pinctrl-0 = <&uart1_default>;
	pinctrl-1 = <&uart1_sleep>;
	pinctrl-names = "default", "sleep";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&sec_eng_trng {
	status = "okay";
};

&sec_eng_aes {
	status = "okay";
};

&sec_eng_sha {
	status = "okay";
};
