/dts-v1/;

#include <espressif/esp32c6/esp32c6_mini_n4.dtsi>
#include "adafruit_feather_esp32c6_hpcore-pinctrl.dtsi"
#include "adafruit_feather_esp32c6_connector.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>
#include <espressif/partitions_0x0_default.dtsi>

/ {
	model = "Adafruit Feather ESP32-C6 HPCORE";
	compatible = "espressif,esp32c6";

	chosen {
		zephyr,sram = &sramhp;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,ieee802154 = &ieee802154;
	};

	aliases {
		led0 = &led0;
		sw0 = &user_button;
		watchdog0 = &wdt0;
		i2c-0 = &i2c0;
		led-strip = &led_strip;
		fuel-gauge0 = &max17048;
	};

	leds {
		compatible = "gpio-leds";
		status = "okay";

		led0: led_0 {
			label = "Red-LED";
			gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		/*
		 * SW1/BOOT shares IO9 with the NeoPixel; enable only if
		 * the NeoPixel (led_strip) is disabled.
		 */
		status = "disabled";

		user_button: user_button {
			label = "BOOT SW1";
			gpios = <&gpio0 9 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	i2c_pwr: i2c_pwr {
		label = "I2C Power";
		compatible = "power-domain-gpio";
		#power-domain-cells = <0>;
		enable-gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <10>;
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&trng0 {
	status = "okay";
};

&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";

	max17048: max17048@36 {
		compatible = "maxim,max17048";
		status = "okay";
		reg = <0x36>;
		power-domains = <&i2c_pwr>;
	};
};

&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";
};

&i2s {
	pinctrl-0 = <&i2s_ws2812_led>;
	pinctrl-names = "default";
	status = "okay";

	led_strip: ws2812_strip@0 {
		compatible = "worldsemi,ws2812-i2s";
		reg = <0>;
		power-domains = <&i2c_pwr>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
	};
};

&gpio0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&wifi {
	status = "okay";
};

&ieee802154 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&usb_serial {
	status = "okay";
};

&dma {
	status = "okay";
};
