#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/gpio/arduino-header-r3.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include "ek_ra8t2-pinctrl.dtsi"

/ {
	leds {
		compatible = "gpio-leds";

		led1: led1 {
			gpios = <&ioport7 14 GPIO_ACTIVE_HIGH>;
			label = "LED1";
		};

		led2: led2 {
			gpios = <&ioport3 3 GPIO_ACTIVE_HIGH>;
			label = "LED2";
		};

		led3: led3 {
			gpios = <&ioporta 7 GPIO_ACTIVE_HIGH>;
			label = "LED3";
		};
	};

	buttons {
		compatible = "gpio-keys";

		button0: s1 {
			gpios = <&ioport0 9 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button switch 1";
			zephyr,code = <INPUT_KEY_0>;
			status = "disabled";
		};

		button1: s2 {
			gpios = <&ioport0 8 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button switch 2";
			zephyr,code = <INPUT_KEY_1>;
			status = "disabled";
		};
	};

	mikrobus_header: mikrobus-connector {
		compatible = "mikro-bus";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &ioport0 4 0>,	/* AN  */
			   <1 0 &ioport4 2 0>,	/* RST */
			   <2 0 &ioport2 4 0>,	/* CS   */
			   <3 0 &ioport2 3 0>,	/* SCK  */
			   <4 0 &ioport3 13 0>,	/* MISO */
			   <5 0 &ioport2 2 0>,	/* MOSI */
			   /* +3.3V */
			   /* GND */
			   <6 0 &ioport8 10 0>,	/* PWM  */
			   <7 0 &ioport9 3 0>,	/* INT  */
			   <8 0 &ioport8 8 0>,	/* RX   */
			   <9 0 &ioport8 9 0>,	/* TX   */
			   <10 0 &ioport4 0 0>, /* SCL  */
			   <11 0 &ioport4 1 0>; /* SDA  */
		/* +5V */
		/* GND */
	};

	arduino_header: arduino-connector {
		compatible = "arduino-header-r3";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <ARDUINO_HEADER_R3_A0 0 &ioport0 1 0>,
			   <ARDUINO_HEADER_R3_A1 0 &ioport0 7 0>,
			   <ARDUINO_HEADER_R3_A2 0 &ioport0 3 0>,
			   <ARDUINO_HEADER_R3_A3 0 &ioport0 4 0>,
			   <ARDUINO_HEADER_R3_A4 0 &ioport0 14 0>,
			   <ARDUINO_HEADER_R3_A5 0 &ioport0 15 0>,
			   <ARDUINO_HEADER_R3_D0 0 &ioport8 8 0>,
			   <ARDUINO_HEADER_R3_D1 0 &ioport8 9 0>,
			   <ARDUINO_HEADER_R3_D2 0 &ioport0 11 0>,
			   <ARDUINO_HEADER_R3_D3 0 &ioport8 11 0>,
			   <ARDUINO_HEADER_R3_D4 0 &ioport8 10 0>,
			   <ARDUINO_HEADER_R3_D5 0 &ioport6 1 0>,
			   <ARDUINO_HEADER_R3_D6 0 &ioport6 0 0>,
			   <ARDUINO_HEADER_R3_D7 0 &ioport5 2 0>,
			   <ARDUINO_HEADER_R3_D8 0 &ioport9 3 0>,
			   <ARDUINO_HEADER_R3_D9 0 &ioport1 10 0>,
			   <ARDUINO_HEADER_R3_D10 0 &ioport2 4 0>,
			   <ARDUINO_HEADER_R3_D11 0 &ioport2 2 0>,
			   <ARDUINO_HEADER_R3_D12 0 &ioport3 13 0>,
			   <ARDUINO_HEADER_R3_D13 0 &ioport2 3 0>,
			   <ARDUINO_HEADER_R3_D14 0 &ioport4 1 0>,
			   <ARDUINO_HEADER_R3_D15 0 &ioport4 0 0>;
	};

	pmod1_header: pmod-connector-1 {
		compatible = "digilent,pmod";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &ioport8 4 0>,	/* IO1 */
			   <1 0 &ioport8 1 0>,	/* IO2 */
			   <2 0 &ioport8 2 0>,	/* IO3 */
			   <3 0 &ioport8 3 0>,	/* IO4 */
			   <4 0 &ioport0 6 0>,	/* IO5 */
			   <5 0 &ioport7 13 0>,	/* IO6 */
			   <6 0 &ioport0 10 0>,	/* IO7 */
			   <7 0 &ioport7 12 0>;	/* IO8 */
	};

	pmod2_header: pmod-connector-2 {
		compatible = "digilent,pmod";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &ioportc 11 0>,	/* IO1 */
			   <1 0 &ioportc 14 0>,	/* IO2 */
			   <2 0 &ioportc 13 0>,	/* IO3 */
			   <3 0 &ioportc 12 0>,	/* IO4 */
			   <4 0 &ioport0 12 0>,	/* IO5 */
			   <5 0 &ioport8 7 0>,	/* IO6 */
			   <6 0 &ioport1 11 0>,	/* IO7 */
			   <7 0 &ioport9 14 0>;	/* IO8 */
	};

	grove_header1: grove_header1 {
		compatible = "grove-header";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &ioport4 0 0>,	/* SCL */
			   <1 0 &ioport4 1 0>;	/* SDA */
	};

	grove_header2: grove_header2 {
		compatible = "grove-header";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &ioport4 10 0>,	/* SCL */
			   <1 0 &ioport4 9 0>;	/* SDA */
	};

	aliases {
		watchdog0 = &wdt0;
		i2c-0 = &iic0;
		pwm-test = &pwm6;
	};
};

&sci6 {
	pinctrl-0 = <&sci6_default>;
	pinctrl-names = "default";

	uart6: uart {};
};

&sci7 {
	pinctrl-0 = <&sci7_default>;
	pinctrl-names = "default";

	uart7: uart {};
};

&sci8 {
	pinctrl-0 = <&sci8_default>;
	pinctrl-names = "default";
};

&spi0 {
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";
};

&iic0 {
	#address-cells = <1>;
	#size-cells = <0>;
	clock-frequency = <DT_FREQ_M(1)>;
	pinctrl-0 = <&iic0_default>;
	pinctrl-names = "default";
};

&canfd_global {
	canfd0 {
		pinctrl-0 = <&canfd0_default>;
		pinctrl-names = "default";
		rx-max-filters = <16>;

		can-transceiver {
			max-bitrate = <5000000>;
		};
	};

	canfd1 {
		pinctrl-0 = <&canfd1_default>;
		pinctrl-names = "default";
		rx-max-filters = <16>;

		can-transceiver {
			max-bitrate = <5000000>;
		};
	};
};

&pwm6 {
	pinctrl-0 = <&pwm6_default>;
	pinctrl-names = "default";
};

&usbfs {
	pinctrl-0 = <&usbfs_default>;
	pinctrl-names = "default";
	maximum-speed = "full-speed";
};

&xtal {
	clock-frequency = <DT_FREQ_M(24)>;
	mosel = <0>;
	#clock-cells = <0>;
	status = "okay";
};

&subclk {
	status = "okay";
};

&pll {
	status = "okay";

	pllp {
		status = "okay";
	};

	pllq {
		status = "okay";
	};

	pllr {
		status = "okay";
	};
};

&pll2 {
	status = "okay";

	pll2p {
		status = "okay";
	};

	pll2q {
		status = "okay";
	};

	pll2r {
		status = "okay";
	};
};

&sciclk {
	clocks = <&pll2r>;
	div = <4>;
	status = "okay";
};

&eswclk {
	clocks = <&pllp>;
	div = <4>;
	status = "okay";
};

&eswphyclk {
	clocks = <&pllp>;
	div = <2>;
	status = "okay";
};

&ethphyclk {
	clocks = <&pllr>;
	div = <16>;
	status = "okay";
};

&canfdclk {
	status = "okay";
};

&gptclk {
	status = "okay";
};

&uclk {
	status = "okay";
};

&ioport0 {
	status = "okay";
};

&ioport1 {
	status = "okay";
};

&ioport2 {
	status = "okay";
};

&ioport3 {
	status = "okay";
};

&ioport4 {
	status = "okay";
};

&ioport5 {
	status = "okay";
};

&ioport6 {
	status = "okay";
};

&ioport7 {
	status = "okay";
};

&ioport8 {
	status = "okay";
};

&ioport9 {
	status = "okay";
};

&ioporta {
	status = "okay";
};

mikrobus_serial: &uart7 {};

mikrobus_spi: &spi0 {};

arduino_serial: &uart7 {};

arduino_spi: &spi0 {};

pmod2_serial: &uart6 {};

pmod_serial: &pmod2_serial {};

pmod_header: &pmod2_header {};
