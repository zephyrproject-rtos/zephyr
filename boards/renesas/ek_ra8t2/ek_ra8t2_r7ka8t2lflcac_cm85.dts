/dts-v1/;

#include <renesas/ra/ra8/r7ka8t2lflcac_cm85.dtsi>
#include "ek_ra8t2.dtsi"

/ {
	model = "Renesas EK-RA8T2";
	compatible = "renesas,ra8t2", "renesas,ra8";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &code_mram_cm85;
		zephyr,flash-controller = &mram_ctrl;
		zephyr,code-partition = &slot0_partition;
		zephyr,console = &uart8;
		zephyr,shell-uart = &uart8;
		zephyr,canbus = &canfd1;
		zephyr,crc = &crc;
		zephyr,entropy = &trng;
	};

	aliases {
		led0 = &led1;
		sw0 = &button0;
	};
};

&button0 {
	status = "okay";
};

&sci8 {
	interrupts = <0 1>, <1 1>, <2 1>, <3 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";

	uart8: uart {
		current-speed = <115200>;
		status = "okay";
	};
};

&sci7 {
	interrupts = <4 1>, <5 1>, <6 1>, <7 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";
};

&uart7 {
	current-speed = <115200>;
	status = "okay";
};

&spi0 {
	interrupts = <8 1>, <9 1>, <10 1>, <11 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";
};

&iic0 {
	interrupts = <12 1>, <13 1>, <14 1>, <15 1>;
	interrupt-names = "rxi", "txi", "tei", "eri";
	status = "okay";
};

&canfd_global {
	interrupts = <16 1>, <17 1>;
	interrupt-names = "rxf", "glerr";
	status = "okay";

	canfd1 {
		interrupts = <18 1>, <19 1>, <20 11>;
		interrupt-names = "err", "tx", "rx";
		status = "okay";
	};
};

&port_irq13 {
	interrupts = <21 1>;
	status = "okay";
};

&pwm6 {
	interrupts = <22 1>, <23 1>;
	interrupt-names = "gtioca", "overflow";
	status = "okay";
};

&ulpt0 {
	interrupts = <24 1>;
	interrupt-names = "ulpti";
	status = "okay";

	timer {
		status = "okay";
	};
};

&ulpt1 {
	status = "okay";

	timer {
		status = "okay";
	};
};

&crc {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&trng {
	status = "okay";
};

&usbfs {
	interrupts = <25 12>, <26 12>;
	interrupt-names = "usbfs-i", "usbfs-r";
	status = "okay";

	zephyr_udc0: udc {
		status = "okay";
	};
};

&code_mram_cm85 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x0 DT_SIZE_K(64)>;
		};

		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x10000 DT_SIZE_K(344)>;
		};

		slot1_partition: partition@66000 {
			label = "image-1";
			reg = <0x66000 DT_SIZE_K(344)>;
		};

		storage_partition: partition@bc000 {
			label = "storage";
			reg = <0xbc000 DT_SIZE_K(16)>;
		};
	};
};

&eswm {
	status = "okay";
	interrupts = <27 1>;
	interrupt-names = "gwdi";
	pinctrl-0 = <&ethphyclk_default>;
	pinctrl-names = "default";
};

&eth0 {
	phy-connection-type = "gmii";
	local-mac-address = [74 90 50 01 02 05];
	phy-clock-type = "internal";
	phy-handle = <&phy1>;
	pinctrl-0 = <&eth0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&eth1 {
	phy-connection-type = "gmii";
	local-mac-address = [74 90 50 01 02 06];
	phy-clock-type = "internal";
	phy-handle = <&phy2>;
	pinctrl-0 = <&eth1_default>;
	pinctrl-names = "default";
	status = "okay";
};

&mdio0 {
	pinctrl-0 = <&mdio0_default>;
	pinctrl-names = "default";
	mdio-hold-time-ns = <7>;
	mdio-capture-time-ns = <0>;
	status = "okay";

	phy1: phy@0 {
		compatible = "microchip,vsc8541";
		reg = <0>;
		microchip,interface-type = "gmii";
		/* Board limitations are currently being analyzed.
		 * Will be improved in the future
		 */
		default-speeds = "100BASE Full-Duplex";
		status = "okay";
	};

	phy2: phy@1 {
		compatible = "microchip,vsc8541";
		reg = <1>;
		microchip,interface-type = "gmii";
		status = "okay";
	};
};
