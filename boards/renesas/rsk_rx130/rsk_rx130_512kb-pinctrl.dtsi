&pinctrl {
    sci1_default: sci1_default {
		group1 {
			psels = <RX_PSEL(RX_PSEL_SCI_1, 2, 6)>, /* TX */
				<RX_PSEL(RX_PSEL_SCI_1, 3, 0)>; /* RX */
		};
	};

	pwm1_default: pwm1_default {
		group1 {
			psels = <RX_PSEL(RX_PSEL_P2nPFS_MTIOC1A, 2, 0)>; /* P20 MTIOC1A JA2-PIN22*/
		};
	};
};
