#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pinctrl/renesas/pinctrl-rzn-common.h>

&pinctrl {
	/omit-if-no-ref/ sci0_default: sci0_default {
		sci0-pinmux {
			pinmux = <RZN_PINMUX(PORT_27, 5, 20)>, /* TXD */
				 <RZN_PINMUX(PORT_27, 4, 20)>; /* RXD */
		};
	};

	/omit-if-no-ref/ irq3_default: irq3_default {
		irq3-pinmux {
			pinmux = <RZN_PINMUX(PORT_00, 4, 0)>;
			input-enable;
		};
	};
};
