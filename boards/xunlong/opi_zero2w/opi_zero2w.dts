/dts-v1/;

#include <allwinner/sun50i-h618.dtsi>
#include <common/mem.h>

/ {
	model = "Xunlong Orange Pi Zero 2W";
	compatible = "xunlong,orangepi-zero2w", "allwinner,sun50i-h618";

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &dram0;
	};

	dram0: memory@40080000 {
		device_type = "memory";
		compatible = "mmio-sram";
		reg = <0x40080000 DT_SIZE_M(1023)>;
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
};
