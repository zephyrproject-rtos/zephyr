/dts-v1/;

#include <ti/ti_am6254_a53.dtsi>
#include "sk-am62_am6254_a53-pinctrl.dtsi"

/ {
	model = "TI AM62X STARTER KIT (SK) EVALUATION MODULE (EVM)";
	compatible = "ti,am62x_a53_sk";

	chosen {
		zephyr,console = &main_uart0;
		zephyr,shell-uart = &main_uart0;
		zephyr,sram = &a53_ddr_section;
		zephyr,ipc = &ipc0;
	};

	aliases {
		led0 = &ld1;
		rtc = &counter_rtc0;
		sdhc0 = &main_sdhci0;
		sdhc1 = &main_sdhci1;
		sdhc2 = &main_sdhci2;
	};

	cpus {
		cpu@0 {
			status = "okay";
		};

		cpu@1 {
			status = "okay";
		};

		cpu@2 {
			status = "okay";
		};

		cpu@3 {
			status = "okay";
		};
	};

	reserved-memory {
		#address-cells = <0x1>;
		#size-cells = <0x1>;

		/* Reserved memory for TFA/OP-TEE */
		tfa_memory: memory@80000000 {
			reg = <0x80000000 DT_SIZE_M(32)>;
		};
	};

	ddr0: memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 DT_SIZE_G(2)>;
		#address-cells = <0x1>;
		#size-cells = <0x1>;

		/* First 32MiB is reserved for TFA/OP-TEE */
		a53_ddr_section: memory@82000000 {
			reg = <0x82000000 (DT_SIZE_G(2) - DT_SIZE_M(32))>;
		};
	};

	leds: leds {
		compatible = "gpio-leds";

		ld1: led_0 {
			gpios = <&main_gpio1 49 GPIO_ACTIVE_HIGH>;
		};
	};

	/* A53 -> M4F */
	ipc0: ipc0 {
		compatible = "zephyr,mbox-ipm";
		mboxes = <&mbox0 1>, <&mbox0 0>;
		mbox-names = "tx", "rx";
	};
};

&main_uart0 {
	current-speed = <115200>;
	pinctrl-0 = <&uart0_rx_default &uart0_tx_default>;
	pinctrl-names = "default";
	status = "okay";
};

&main_gpio1_1 {
	pinctrl-0 = <&main_gpio1_led>;
	pinctrl-names = "default";
	status = "okay";
};

&main_i2c0 {
	pinctrl-0 = <&main_i2c0_scl &main_i2c0_sda>;
	pinctrl-names = "default";
	status = "okay";

	eeprom0: eeprom@51 {
		compatible = "atmel,at24";
		reg = <0x51>;
		address-width = <16>;
		pagesize = <128>;
		size = <65536>;
		timeout = <5>;
	};
};

&main_i2c1 {
	pinctrl-0 = <&main_i2c1_scl &main_i2c1_sda>;
	pinctrl-names = "default";
	status = "okay";

	gpio_expander: tca6424a@22 {
		compatible = "ti,tca6424a";
		reg = <0x22>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <24>;
	};
};

&main_rtc0 {
	status = "okay";
};

&counter_rtc0 {
	status = "okay";
};

/* eMMC */
&main_sdhci0 {
	pinctrl-0 = <&mmc0_cmd
		     &mmc0_clk
		     &mmc0_dat0
		     &mmc0_dat1
		     &mmc0_dat2
		     &mmc0_dat3
		     &mmc0_dat4
		     &mmc0_dat5
		     &mmc0_dat6
		     &mmc0_dat7>;
	pinctrl-names = "default";
	status = "okay";

	mmc {
		compatible = "zephyr,mmc-disk";
		bus-width = <8>;
		disk-name = "emmc";
	};
};

/* SD */
&main_sdhci1 {
	pinctrl-0 = <&mmc1_cmd
		     &mmc1_clk
		     &mmc1_dat0
		     &mmc1_dat1
		     &mmc1_dat2
		     &mmc1_dat3
		     &mmc1_sdcd>;
	pinctrl-names = "default";
	status = "okay";

	sd {
		compatible = "zephyr,sdmmc-disk";
		disk-name = "sd";
	};
};

/* SDIO */
&main_sdhci2 {
	pinctrl-0 = <&mmc2_cmd
		     &mmc2_clk
		     &mmc2_clklb
		     &mmc2_dat0
		     &mmc2_dat1
		     &mmc2_dat2
		     &mmc2_dat3>;
	pinctrl-names = "default";
	ti,fails-without-test-cd;
	status = "disabled";
};
