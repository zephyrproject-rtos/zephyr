&wkup_pinctrl {
	status = "okay";

	uart0_rx_default: uart0_rx_default {
		pinmux = <K3_PINMUX(0x1b4, PIN_INPUT, MUX_MODE_0)>; /* (D13) UART0_RXD */
	};

	uart0_tx_default: uart0_tx_default {
		pinmux = <K3_PINMUX(0x1b8, PIN_OUTPUT, MUX_MODE_0)>; /* (C13) UART0_TXD */
	};

	eqep0_a: eqep0_a_default {
		pinmux = <K3_PINMUX(0x0cc, PIN_INPUT, MUX_MODE_4)>; /* (P23) EQEP0_A */
	};

	eqep0_b: eqep0_b_default {
		pinmux = <K3_PINMUX(0x0d0, PIN_INPUT, MUX_MODE_4)>; /* (P22) EQEP0_B */
	};

	eqep0_i: eqep0_i_default {
		pinmux = <K3_PINMUX(0x0d8, PIN_INPUT, MUX_MODE_4)>; /* (N22) EQEP0_I */
	};

	eqep0_s: eqep0_s_default {
		pinmux = <K3_PINMUX(0x0d4, PIN_INPUT, MUX_MODE_4)>; /* (N23) EQEP0_S */
	};
};
