/dts-v1/;
#include <st/f4/stm32f429Xi.dtsi>
#include <st/f4/stm32f429b(e-g-i)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/memory-controller/stm32-fmc-nor-psram.h>

/ {
	model = "Armfly STM32F429BIT6";
	compatible = "armfly,stm32f429bit6";

	chosen {
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm = &ccm0;
		zephyr,display = &ltdc;
		zephyr,touch = &gt911;
	};

	sdram1: sdram@c0000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		device_type = "memory";
		reg = <0xc0000000 DT_SIZE_M(16)>;
		zephyr,memory-region = "SDRAM1";
	};

	latch_gpio: gpio@64001000 {
		compatible = "gpio-mmio-latch";
		reg = <0x64001000 0x4>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <32>;
		initial-output = <0x00000f14>;
		status = "disabled";
	};

	leds: leds {
		compatible = "gpio-leds";
		status = "disabled";

		led0: led_0 {
			gpios = <&latch_gpio 8 GPIO_ACTIVE_LOW>;
		};

		led1: led_1 {
			gpios = <&latch_gpio 9 GPIO_ACTIVE_LOW>;
		};

		led2: led_2 {
			gpios = <&latch_gpio 10 GPIO_ACTIVE_LOW>;
		};

		led3: led_3 {
			gpios = <&latch_gpio 11 GPIO_ACTIVE_LOW>;
		};
	};

	buttons {
		compatible = "gpio-keys";
		polling-mode;

		button0: button_0 {
			gpios = <&gpioi 8 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};

		button1: button_1 {
			gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_1>;
		};

		button2: button_2 {
			gpios = <&gpioh 4 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_2>;
		};

		joy_down: joy-down {
			gpios = <&gpiof 10 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_DOWN>;
		};

		joy_select: joy-select {
			gpios = <&gpioi 11 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_ENTER>;
		};

		joy_right: joy-right {
			gpios = <&gpiog 7 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_RIGHT>;
		};

		joy_up: joy-up {
			gpios = <&gpiog 2 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_UP>;
		};

		joy_left: joy-left {
			gpios = <&gpiog 3 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_LEFT>;
		};
	};

	aliases {
		sw0 = &button0;
		sw1 = &button1;
		sw2 = &button2;
		sw3 = &joy_select;
		sw4 = &joy_down;
		sw5 = &joy_right;
		sw6 = &joy_up;
		sw7 = &joy_left;
		backlight-pwm = &lcd_bl_pwm;
	};

	backlight_pwm: backlight {
		compatible = "pwm-leds";

		lcd_bl_pwm: bl0 {
			pwms = <&tim5_pwm 1 PWM_USEC(100) PWM_POLARITY_NORMAL>;
		};
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(8)>;
	status = "okay";
};

&clk_lse {
	clock-frequency = <32768>;
	status = "okay";
};

&pll {
	div-m = <8>;
	mul-n = <336>;
	div-p = <2>;
	div-q = <7>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pllsai {
	div-m = <8>;
	mul-n = <420>;
	div-r = <7>;
	post-div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(168)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <4>;
	apb2-prescaler = <2>;
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart2 {
	status = "disabled";
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
};

&usart3 {
	status = "okay";
	pinctrl-0 = <&usart3_tx_pb10 &usart3_rx_pb11>;
	pinctrl-names = "default";
	current-speed = <115200>;
};

&can1 {
	status = "okay";
	pinctrl-0 = <&can1_rx_pa11 &can1_tx_pa12>;
	pinctrl-names = "default";
	bitrate = <500000>;
};

&can2 {
	status = "disabled";
	pinctrl-0 = <&can2_rx_pb12 &can2_tx_pb13>;
	pinctrl-names = "default";
	bitrate = <500000>;
};

&rtc {
	clocks = <&rcc STM32_CLOCK(APB1, 28)>, <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	gt911: gt911@5d {
		compatible = "goodix,gt911";
		reg = <0x5d>;
		irq-gpios = <&gpioh 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		alt-addr = <0x14>;
	};

	eeprom: eeprom@50 {
		compatible = "atmel,at24";
		reg = <0x50>;
		size = <DT_SIZE_K(16)>;
		pagesize = <64>;
		address-width = <16>;
		timeout = <5>;
		status = "okay";
	};

	mpu6050: accel-gyro@68 {
		compatible = "invensense,mpu6050";
		reg = <0x68>;
		int-gpios = <&gpioe 4 GPIO_ACTIVE_HIGH>;
		accel-fs = <2>;
		gyro-fs = <250>;
		smplrt-div = <249>;
		status = "okay";
	};

	bh1750: light-sensor@23 {
		compatible = "rohm,bh1750";
		reg = <0x23>;
		resolution = <1>;
		mtreg = <69>;
		status = "okay";
	};

	bmp180: pressure-sensor@77 {
		compatible = "bosch,bmp180";
		reg = <0x77>;
		osr-press = <3>;
		status = "okay";
	};
};

&spi1 {
	status = "disabled";
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	cs-gpios = <&gpiof 11 GPIO_ACTIVE_LOW>, <&gpiog 11 GPIO_ACTIVE_LOW>,
		   <&gpioc 3 GPIO_ACTIVE_LOW>;

	w25q64: spi-nor-flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
		jedec-id = [ef 40 17];
		size = <DT_SIZE_M(8)>;
		status = "disabled";
	};
};

&sdmmc1 {
	status = "okay";
	pinctrl-0 = <&sdio_d0_pc8
		     &sdio_d1_pc9
		     &sdio_d2_pc10
		     &sdio_d3_pc11
		     &sdio_ck_pc12
		     &sdio_cmd_pd2>;
	pinctrl-names = "default";
	cd-gpios = <&gpioe 2 GPIO_ACTIVE_LOW>;
	disk-name = "SD";
	clocks = <&rcc STM32_CLOCK(APB2, 11)>, <&rcc STM32_SRC_PLL_Q CK48M_SEL(0)>;
};

&fmc {
	status = "okay";
	pinctrl-0 = <&fmc_nbl0_pe0 &fmc_nbl1_pe1
		     &fmc_nbl2_pi4 &fmc_nbl3_pi5
		     &fmc_ne2_pg9
		     &fmc_noe_pd4
		     &fmc_nwe_pd5
		     &fmc_sdclk_pg8
		     &fmc_sdcke0_ph2 &fmc_sdne0_ph3 &fmc_sdnwe_ph5
		     &fmc_sdnras_pf11 &fmc_sdncas_pg15
		     &fmc_a0_pf0 &fmc_a1_pf1 &fmc_a2_pf2 &fmc_a3_pf3
		     &fmc_a4_pf4 &fmc_a5_pf5 &fmc_a6_pf12 &fmc_a7_pf13
		     &fmc_a8_pf14 &fmc_a9_pf15 &fmc_a10_pg0 &fmc_a11_pg1
		     &fmc_a14_pg4 &fmc_a15_pg5
		     &fmc_d0_pd14 &fmc_d1_pd15 &fmc_d2_pd0 &fmc_d3_pd1
		     &fmc_d4_pe7 &fmc_d5_pe8 &fmc_d6_pe9 &fmc_d7_pe10
		     &fmc_d8_pe11 &fmc_d9_pe12 &fmc_d10_pe13 &fmc_d11_pe14
		     &fmc_d12_pe15 &fmc_d13_pd8 &fmc_d14_pd9 &fmc_d15_pd10
		     &fmc_d16_ph8 &fmc_d17_ph9 &fmc_d18_ph10 &fmc_d19_ph11
		     &fmc_d20_ph12 &fmc_d21_ph13 &fmc_d22_ph14 &fmc_d23_ph15
		     &fmc_d24_pi0 &fmc_d25_pi1 &fmc_d26_pi2 &fmc_d27_pi3
		     &fmc_d28_pi6 &fmc_d29_pi7 &fmc_d30_pi9 &fmc_d31_pi10>;
	pinctrl-names = "default";

	sdram {
		status = "okay";
		power-up-delay = <100>;
		num-auto-refresh = <8>;
		mode-register = <0x230>;
		refresh-rate = <1292>;

		bank@0 {
			reg = <0>;

			st,sdram-control = <STM32_FMC_SDRAM_NC_8
					    STM32_FMC_SDRAM_NR_12
					    STM32_FMC_SDRAM_MWID_32
					    STM32_FMC_SDRAM_NB_4
					    STM32_FMC_SDRAM_CAS_3
					    STM32_FMC_SDRAM_SDCLK_PERIOD_2
					    STM32_FMC_SDRAM_RBURST_ENABLE
					    STM32_FMC_SDRAM_RPIPE_0>;

			st,sdram-timing = <2 6 4 6 2 2 2>;
		};
	};

	fmc_norsram: sram {
		status = "okay";
		compatible = "st,stm32-fmc-nor-psram";
		#address-cells = <1>;
		#size-cells = <0>;

		latch_bank: bank@2 {
			reg = <STM32_FMC_NORSRAM_BANK2>;

			st,control = <STM32_FMC_DATA_ADDRESS_MUX_DISABLE
				      STM32_FMC_MEMORY_TYPE_SRAM
				      STM32_FMC_NORSRAM_MEM_BUS_WIDTH_32
				      STM32_FMC_BURST_ACCESS_MODE_DISABLE
				      STM32_FMC_WAIT_SIGNAL_POLARITY_LOW
				      STM32_FMC_WAIT_TIMING_BEFORE_WS
				      STM32_FMC_WRITE_OPERATION_ENABLE
				      STM32_FMC_WAIT_SIGNAL_DISABLE
				      STM32_FMC_EXTENDED_MODE_DISABLE
				      STM32_FMC_ASYNCHRONOUS_WAIT_DISABLE
				      STM32_FMC_WRITE_BURST_DISABLE
				      STM32_FMC_CONTINUOUS_CLOCK_SYNC_ONLY
				      STM32_FMC_WRITE_FIFO_ENABLE
				      STM32_FMC_PAGE_SIZE_NONE>;

			st,timing = <3 0 6 3 0 0 STM32_FMC_ACCESS_MODE_A>;
		};
	};
};

&ltdc {
	pinctrl-0 = <&ltdc_hsync_pi12 &ltdc_vsync_pi13 &ltdc_clk_pi14 &ltdc_r0_pi15
		     &ltdc_r1_pj0 &ltdc_r2_pj1 &ltdc_r3_pj2 &ltdc_r4_pj3
		     &ltdc_r5_pj4 &ltdc_r6_pj5 &ltdc_r7_pj6 &ltdc_g0_pj7
		     &ltdc_g1_pj8 &ltdc_g2_pj9 &ltdc_g3_pj10 &ltdc_g4_pj11
		     &ltdc_b0_pj12 &ltdc_b1_pj13 &ltdc_b2_pj14 &ltdc_b3_pj15
		     &ltdc_g5_pk0 &ltdc_g6_pk1 &ltdc_g7_pk2 &ltdc_b4_pk3
		     &ltdc_b5_pk4 &ltdc_b6_pk5 &ltdc_b7_pk6 &ltdc_de_pk7>;
	pinctrl-names = "default";
	ext-sdram = <&sdram1>;
	status = "okay";

	width = <800>;
	height = <480>;
	pixel-format = <PANEL_PIXEL_FORMAT_RGB_888>;

	display-timings {
		compatible = "zephyr,panel-timing";

		de-active = <0>;
		pixelclk-active = <0>;
		hsync-active = <0>;
		vsync-active = <0>;

		hsync-len = <80>;
		hback-porch = <10>;
		hfront-porch = <10>;

		vsync-len = <10>;
		vback-porch = <10>;
		vfront-porch = <10>;
	};

	def-back-color-red = <0x00>;
	def-back-color-green = <0x00>;
	def-back-color-blue = <0x00>;
};

zephyr_udc0: &usbotg_hs {
	pinctrl-0 = <&usb_otg_hs_dm_pb14 &usb_otg_hs_dp_pb15>;
	pinctrl-names = "default";
	status = "okay";
};

&timers5 {
	status = "okay";

	tim5_pwm: pwm {
		compatible = "st,stm32-pwm";
		status = "okay";
		pinctrl-0 = <&tim5_ch1_pa0>;
		pinctrl-names = "default";
	};
};

&mac {
	status = "okay";
	pinctrl-0 = <&eth_rxd0_pc4
		     &eth_rxd1_pc5
		     &eth_ref_clk_pa1
		     &eth_crs_dv_pa7
		     &eth_tx_en_pg11
		     &eth_txd0_pg13
		     &eth_txd1_pb13>;
	pinctrl-names = "default";
	phy-connection-type = "rmii";
	phy-handle = <&eth_phy>;
};

&mdio {
	status = "okay";
	pinctrl-0 = <&eth_mdio_pa2 &eth_mdc_pc1>;
	pinctrl-names = "default";

	eth_phy: ethernet-phy@1 {
		compatible = "ethernet-phy";
		reg = <0x01>;
	};
};

&ltdc_hsync_pi12 {
	slew-rate = "very-high-speed";
};

&ltdc_vsync_pi13 {
	slew-rate = "very-high-speed";
};

&ltdc_clk_pi14 {
	slew-rate = "very-high-speed";
};

&ltdc_r0_pi15 {
	slew-rate = "very-high-speed";
};

&ltdc_r1_pj0 {
	slew-rate = "very-high-speed";
};

&ltdc_r2_pj1 {
	slew-rate = "very-high-speed";
};

&ltdc_r3_pj2 {
	slew-rate = "very-high-speed";
};

&ltdc_r4_pj3 {
	slew-rate = "very-high-speed";
};

&ltdc_r5_pj4 {
	slew-rate = "very-high-speed";
};

&ltdc_r6_pj5 {
	slew-rate = "very-high-speed";
};

&ltdc_r7_pj6 {
	slew-rate = "very-high-speed";
};

&ltdc_g0_pj7 {
	slew-rate = "very-high-speed";
};

&ltdc_g1_pj8 {
	slew-rate = "very-high-speed";
};

&ltdc_g2_pj9 {
	slew-rate = "very-high-speed";
};

&ltdc_g3_pj10 {
	slew-rate = "very-high-speed";
};

&ltdc_g4_pj11 {
	slew-rate = "very-high-speed";
};

&ltdc_g5_pk0 {
	slew-rate = "very-high-speed";
};

&ltdc_g6_pk1 {
	slew-rate = "very-high-speed";
};

&ltdc_g7_pk2 {
	slew-rate = "very-high-speed";
};

&ltdc_b0_pj12 {
	slew-rate = "very-high-speed";
};

&ltdc_b1_pj13 {
	slew-rate = "very-high-speed";
};

&ltdc_b2_pj14 {
	slew-rate = "very-high-speed";
};

&ltdc_b3_pj15 {
	slew-rate = "very-high-speed";
};

&ltdc_b4_pk3 {
	slew-rate = "very-high-speed";
};

&ltdc_b5_pk4 {
	slew-rate = "very-high-speed";
};

&ltdc_b6_pk5 {
	slew-rate = "very-high-speed";
};

&ltdc_b7_pk6 {
	slew-rate = "very-high-speed";
};

&ltdc_de_pk7 {
	slew-rate = "very-high-speed";
};
