/dts-v1/;
#include <st/h7/stm32h743Xi.dtsi>
#include <st/h7/stm32h743xihx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/memory-controller/stm32-fmc-nor-psram.h>

/ {
	model = "Armfly STM32H743XIH6 board";
	compatible = "armfly,stm32h743xih6";

	chosen {
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm = &dtcm;
		zephyr,itcm = &itcm;
		zephyr,display = &ltdc;
		zephyr,touch = &gt911;
	};

	sdram1: sdram@c0000000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		device_type = "memory";
		reg = <0xc0000000 DT_SIZE_M(32)>;
		zephyr,memory-region = "SDRAM1";
	};

	fmc_extio: memory@60000000 {
		compatible = "zephyr,memory-region";
		reg = <0x60000000 DT_SIZE_K(64)>;
		zephyr,memory-region = "FMC_EXTIO";
		zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_IO)>;
	};

	latch_gpio: gpio@60001000 {
		compatible = "gpio-mmio-latch";
		reg = <0x60001000 0x4>;
		gpio-controller;
		#gpio-cells = <2>;
		ngpios = <32>;
		initial-output = <0x00000f14>;
		status = "disabled";
	};

	leds: leds {
		compatible = "gpio-leds";
		status = "disabled";

		led0: led_0 {
			gpios = <&latch_gpio 8 GPIO_ACTIVE_LOW>;
			label = "LED0";
		};

		led1: led_1 {
			gpios = <&latch_gpio 9 GPIO_ACTIVE_LOW>;
			label = "LED1";
		};

		led2: led_2 {
			gpios = <&latch_gpio 10 GPIO_ACTIVE_LOW>;
			label = "LED2";
		};

		led3: led_3 {
			gpios = <&latch_gpio 11 GPIO_ACTIVE_LOW>;
			label = "LED3";
		};
	};

	buttons {
		compatible = "gpio-keys";
		polling-mode;

		button0: button_0 {
			gpios = <&gpioi 8 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};

		button1: button_1 {
			gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_1>;
		};

		button2: button_2 {
			gpios = <&gpioh 4 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_2>;
		};

		joy_down: joy-down {
			gpios = <&gpiob 0 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_DOWN>;
		};

		joy_select: joy-select {
			gpios = <&gpioi 11 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_ENTER>;
		};

		joy_right: joy-right {
			gpios = <&gpiog 7 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_RIGHT>;
		};

		joy_up: joy-up {
			gpios = <&gpiog 2 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_UP>;
		};

		joy_left: joy-left {
			gpios = <&gpiog 3 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_LEFT>;
		};
	};

	aliases {
		sw0 = &button0;
		sw1 = &button1;
		sw2 = &button2;
		sw3 = &joy_select;
		sw4 = &joy_down;
		sw5 = &joy_right;
		sw6 = &joy_up;
		sw7 = &joy_left;
		backlight-pwm = &lcd_bl_pwm;
	};

	backlight_pwm: backlight {
		compatible = "pwm-leds";

		lcd_bl_pwm: bl0 {
			pwms = <&tim1_pwm 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>;
			label = "lcd_backlight_pwm";
		};
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(25)>;
	status = "okay";
};

&pll {
	div-m = <5>;
	mul-n = <160>;
	div-p = <2>;
	div-q = <4>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pll2 {
	div-m = <5>;
	mul-n = <96>;
	div-p = <2>;
	div-q = <4>;
	div-r = <10>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pll3 {
	div-m = <5>;
	mul-n = <48>;
	div-p = <2>;
	div-q = <5>;
	div-r = <10>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(400)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

&pwr {
	power-supply = "ldo";
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&rtc {
	clocks = <&rcc STM32_CLOCK(APB1, 28)>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	gt911: gt911@5d {
		compatible = "goodix,gt911";
		reg = <0x5d>;
		irq-gpios = <&gpioh 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		alt-addr = <0x14>;
	};
};

&spi3 {
	pinctrl-0 = <&spi3_sck_pb3 &spi3_miso_pb4 &spi3_mosi_pb5>;
	cs-gpios = <&gpiod 13 GPIO_ACTIVE_LOW>;
	pinctrl-names = "default";
	status = "okay";

	w25q64_spi: spi-nor-flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;
		size = <DT_SIZE_M(64)>; /* 64 Mbits */
		status = "okay";
		jedec-id = [ef 40 17];
		has-dpd;
		t-enter-dpd = <3500>;
		t-exit-dpd = <3500>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			storage_partition: partition@0 {
				label = "storage";
				reg = <0x00000000 DT_SIZE_M(8)>;
			};
		};
	};
};

&sdmmc1 {
	status = "okay";
	pinctrl-0 = <&sdmmc1_d0_pc8
		     &sdmmc1_d1_pc9
		     &sdmmc1_d2_pc10
		     &sdmmc1_d3_pc11
		     &sdmmc1_ck_pc12
		     &sdmmc1_cmd_pd2>;
	pinctrl-names = "default";
	cd-gpios = <&gpiog 12 GPIO_ACTIVE_LOW>;
	disk-name = "SD";
	clocks = <&rcc STM32_CLOCK(AHB3, 16)>,
		 <&rcc STM32_SRC_PLL2_R SDMMC_SEL(1)>;
};

&fmc {
	status = "okay";

	pinctrl-0 = <&fmc_nbl0_pe0 &fmc_nbl1_pe1
		     &fmc_nbl2_pi4 &fmc_nbl3_pi5
		     &fmc_ne1_pd7
		     &fmc_noe_pd4
		     &fmc_nwe_pd5
		     &fmc_sdclk_pg8
		     &fmc_sdcke0_ph2 &fmc_sdne0_ph3 &fmc_sdnwe_ph5
		     &fmc_sdnras_pf11 &fmc_sdncas_pg15
		     &fmc_a0_pf0 &fmc_a1_pf1 &fmc_a2_pf2 &fmc_a3_pf3
		     &fmc_a4_pf4 &fmc_a5_pf5 &fmc_a6_pf12 &fmc_a7_pf13
		     &fmc_a8_pf14 &fmc_a9_pf15 &fmc_a10_pg0 &fmc_a11_pg1
		     &fmc_a14_pg4 &fmc_a15_pg5 &fmc_a16_pd11 &fmc_a17_pd12
		     &fmc_d0_pd14 &fmc_d1_pd15 &fmc_d2_pd0 &fmc_d3_pd1
		     &fmc_d4_pe7 &fmc_d5_pe8 &fmc_d6_pe9 &fmc_d7_pe10
		     &fmc_d8_pe11 &fmc_d9_pe12 &fmc_d10_pe13 &fmc_d11_pe14
		     &fmc_d12_pe15 &fmc_d13_pd8 &fmc_d14_pd9 &fmc_d15_pd10
		     &fmc_d16_ph8 &fmc_d17_ph9 &fmc_d18_ph10 &fmc_d19_ph11
		     &fmc_d20_ph12 &fmc_d21_ph13 &fmc_d22_ph14 &fmc_d23_ph15
		     &fmc_d24_pi0 &fmc_d25_pi1 &fmc_d26_pi2 &fmc_d27_pi3
		     &fmc_d28_pi6 &fmc_d29_pi7 &fmc_d30_pi9 &fmc_d31_pi10>;
	pinctrl-names = "default";

	sdram {
		status = "okay";
		power-up-delay = <100>;
		num-auto-refresh = <8>;
		mode-register = <0x230>;
		refresh-rate = <1543>;

		bank@0 {
			reg = <0>;

			st,sdram-control = <STM32_FMC_SDRAM_NC_9
					    STM32_FMC_SDRAM_NR_12
					    STM32_FMC_SDRAM_MWID_32
					    STM32_FMC_SDRAM_NB_4
					    STM32_FMC_SDRAM_CAS_3
					    STM32_FMC_SDRAM_SDCLK_PERIOD_2
					    STM32_FMC_SDRAM_RBURST_ENABLE
					    STM32_FMC_SDRAM_RPIPE_0>;

			st,sdram-timing = <2 7 4 7 2 2 2>;
		};
	};

	fmc_norsram: sram {
		status = "okay";
		compatible = "st,stm32-fmc-nor-psram";
		#address-cells = <1>;
		#size-cells = <0>;

		sram1@0 {
			reg = <STM32_FMC_NORSRAM_BANK1>;

			st,control = <STM32_FMC_DATA_ADDRESS_MUX_DISABLE
				      STM32_FMC_MEMORY_TYPE_SRAM
				      STM32_FMC_NORSRAM_MEM_BUS_WIDTH_32
				      STM32_FMC_BURST_ACCESS_MODE_DISABLE
				      STM32_FMC_WAIT_SIGNAL_POLARITY_LOW
				      STM32_FMC_WAIT_TIMING_BEFORE_WS
				      STM32_FMC_WRITE_OPERATION_ENABLE
				      STM32_FMC_WAIT_SIGNAL_DISABLE
				      STM32_FMC_EXTENDED_MODE_DISABLE
				      STM32_FMC_ASYNCHRONOUS_WAIT_DISABLE
				      STM32_FMC_WRITE_BURST_DISABLE
				      STM32_FMC_CONTINUOUS_CLOCK_SYNC_ONLY
				      STM32_FMC_WRITE_FIFO_ENABLE
				      STM32_FMC_PAGE_SIZE_NONE>;

			st,timing = <5 2 2 1 2 2 STM32_FMC_ACCESS_MODE_A>;
		};
	};
};

&ltdc {
	pinctrl-0 = <&ltdc_hsync_pi12 &ltdc_vsync_pi13 &ltdc_clk_pi14 &ltdc_r0_pi15
		     &ltdc_r1_pj0 &ltdc_r2_pj1 &ltdc_r3_pj2 &ltdc_r4_pj3
		     &ltdc_r5_pj4 &ltdc_r6_pj5 &ltdc_r7_pj6 &ltdc_g0_pj7
		     &ltdc_g1_pj8 &ltdc_g2_pj9 &ltdc_g3_pj10 &ltdc_g4_pj11
		     &ltdc_b0_pj12 &ltdc_b1_pj13 &ltdc_b2_pj14 &ltdc_b3_pj15
		     &ltdc_g5_pk0 &ltdc_g6_pk1 &ltdc_g7_pk2 &ltdc_b4_pk3
		     &ltdc_b5_pk4 &ltdc_b6_pk5 &ltdc_b7_pk6 &ltdc_de_pk7>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB3, 3)>,
		 <&rcc STM32_SRC_PLL3_R NO_SEL>;
	ext-sdram = <&sdram1>;
	status = "okay";

	width = <800>;
	height = <480>;
	pixel-format = <PANEL_PIXEL_FORMAT_RGB_888>;

	display-timings {
		compatible = "zephyr,panel-timing";

		de-active = <0>;
		pixelclk-active = <0>;
		hsync-active = <0>;
		vsync-active = <0>;

		hsync-len = <96>;
		hback-porch = <10>;
		hfront-porch = <10>;

		vsync-len = <2>;
		vback-porch = <10>;
		vfront-porch = <10>;
	};

	def-back-color-red = <0x00>;
	def-back-color-green = <0x00>;
	def-back-color-blue = <0x00>;
};

&timers1 {
	status = "okay";

	tim1_pwm: pwm {
		compatible = "st,stm32-pwm";
		status = "okay";
		pinctrl-0 = <&tim1_ch1_pa8>;
		pinctrl-names = "default";
	};
};

&mac {
	status = "okay";
	phy-connection-type = "rmii";
	phy-handle = <&eth_phy>;
	pinctrl-names = "default";
	pinctrl-0 = <&eth_rxd0_pc4
		     &eth_rxd1_pc5
		     &eth_ref_clk_pa1
		     &eth_crs_dv_pa7
		     &eth_tx_en_pg11
		     &eth_txd0_pg13
		     &eth_txd1_pb13>;
};

&mdio {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&eth_mdio_pa2 &eth_mdc_pc1>;

	eth_phy: ethernet-phy@1 {
		compatible = "ethernet-phy";
		reg = <1>;
	};
};

&ltdc_hsync_pi12 {
	slew-rate = "very-high-speed";
};

&ltdc_vsync_pi13 {
	slew-rate = "very-high-speed";
};

&ltdc_clk_pi14 {
	slew-rate = "very-high-speed";
};

&ltdc_r0_pi15 {
	slew-rate = "very-high-speed";
};

&ltdc_r1_pj0 {
	slew-rate = "very-high-speed";
};

&ltdc_r2_pj1 {
	slew-rate = "very-high-speed";
};

&ltdc_r3_pj2 {
	slew-rate = "very-high-speed";
};

&ltdc_r4_pj3 {
	slew-rate = "very-high-speed";
};

&ltdc_r5_pj4 {
	slew-rate = "very-high-speed";
};

&ltdc_r6_pj5 {
	slew-rate = "very-high-speed";
};

&ltdc_r7_pj6 {
	slew-rate = "very-high-speed";
};

&ltdc_g0_pj7 {
	slew-rate = "very-high-speed";
};

&ltdc_g1_pj8 {
	slew-rate = "very-high-speed";
};

&ltdc_g2_pj9 {
	slew-rate = "very-high-speed";
};

&ltdc_g3_pj10 {
	slew-rate = "very-high-speed";
};

&ltdc_g4_pj11 {
	slew-rate = "very-high-speed";
};

&ltdc_g5_pk0 {
	slew-rate = "very-high-speed";
};

&ltdc_g6_pk1 {
	slew-rate = "very-high-speed";
};

&ltdc_g7_pk2 {
	slew-rate = "very-high-speed";
};

&ltdc_b0_pj12 {
	slew-rate = "very-high-speed";
};

&ltdc_b1_pj13 {
	slew-rate = "very-high-speed";
};

&ltdc_b2_pj14 {
	slew-rate = "very-high-speed";
};

&ltdc_b3_pj15 {
	slew-rate = "very-high-speed";
};

&ltdc_b4_pk3 {
	slew-rate = "very-high-speed";
};

&ltdc_b5_pk4 {
	slew-rate = "very-high-speed";
};

&ltdc_b6_pk5 {
	slew-rate = "very-high-speed";
};

&ltdc_b7_pk6 {
	slew-rate = "very-high-speed";
};

&ltdc_de_pk7 {
	slew-rate = "very-high-speed";
};
