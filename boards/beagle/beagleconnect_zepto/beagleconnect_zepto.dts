/dts-v1/;

#include <ti/mspm0/l/mspm0l1117.dtsi>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/pinctrl/mspm0-pinctrl.h>

/ {
	model = "BeagleBoard.org BeagleConnect Zepto";
	compatible = "beagle,beagleconnect_zepto_mspm0l1117";

	aliases {
		led0 = &led0;
		sw0 = &button0;
		watchdog0 = &wdt0;
	};

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &uart0;
		zephyr,entropy = &trng;
	};

	gpio_keys {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpioa 18 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	leds: leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpioa 13 GPIO_ACTIVE_HIGH>;
		};
	};
};

&flash0 {
	status = "okay";
};

/* TODO: Remove these pinmux from here once upstream merges
 * https://github.com/zephyrproject-rtos/hal_ti/pull/80
 */
&pinctrl {
	status = "okay";

	uart0_tx: uart0_tx {
		pinmux = <MSP_PINMUX(21, MSPM0_PIN_FUNCTION_2)>;
	};

	uart0_rx: uart0_rx {
		pinmux = <MSP_PINMUX(22, MSPM0_PIN_FUNCTION_2)>;
		input-enable;
	};
};

&uart0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_tx &uart0_rx>;
};

&gpioa {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&trng {
	status = "okay";
};
