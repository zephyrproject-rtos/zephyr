CONFIG_XIP=n

# GPIO Driver
CONFIG_GPIO=y

# Serial Driver
CONFIG_SERIAL=y

# Enable Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_INTERRUPT_DRIVEN=y

# ARM Options
CONFIG_AARCH64_IMAGE_HEADER=y
CONFIG_ARMV8_A_NS=y
CONFIG_ARM64_VA_BITS_36=y
CONFIG_ARM64_PA_BITS_36=y

# Cache Options
CONFIG_CACHE_MANAGEMENT=y
CONFIG_DCACHE_LINE_SIZE_DETECT=y
CONFIG_ICACHE_LINE_SIZE_DETECT=y

# Multicore Support
CONFIG_SMP=y
CONFIG_PM_CPU_OPS=y
CONFIG_MP_MAX_NUM_CPUS=2

CONFIG_PM_CPU_OPS=y
CONFIG_PM_CPU_OPS_PSCI=y
CONFIG_POWEROFF=y
