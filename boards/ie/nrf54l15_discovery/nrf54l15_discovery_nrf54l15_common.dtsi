#include "nrf54l15_discovery_nrf54l15-pinctrl.dtsi"
#include <zephyr/dt-bindings/regulator/npm13xx.h>

/ {
	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio1 4 GPIO_ACTIVE_HIGH>;
			label = "Green LED 0";
		};
	};

	pwmleds {
		compatible = "pwm-leds";

		/*
		 * PWM signal can be exposed on GPIO pin only within same domain.
		 * There is only one domain which contains both PWM and GPIO:
		 * PWM20/21/22 and GPIO Port P1.
		 */
		pwm_led0: pwm_led_0 {
			pwms = <&pwm20 0 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio1 9 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 0";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	aliases {
		led0 = &led0;
		pwm-led0 = &pwm_led0;
		sw0 = &button0;
		watchdog0 = &wdt31;
		i2c-controller = &i2c20;
		battery = &npm1300_charger;
	};
};

&uart30 {
	current-speed = <115200>;
	pinctrl-0 = <&uart30_default>;
	pinctrl-1 = <&uart30_sleep>;
	pinctrl-names = "default", "sleep";
};

&i2c20 {
	pinctrl-0 = <&i2c20_default>;
	pinctrl-1 = <&i2c20_sleep>;
	pinctrl-names = "default", "sleep";
	zephyr,concat-buf-size = <256>;
	status = "okay";

	pmic_main: npm1300@6b {
		compatible = "nordic,npm1300";
		status = "okay";
		reg = <0x6b>;

		regulators {
			compatible = "nordic,npm1300-regulator";
			status = "okay";

			vdd_nrf: BUCK1 {
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-always-on;
			};

			ldo2_3v3: LDO2 {
				regulator-initial-mode = <NPM13XX_LDSW_MODE_LDO>;
				regulator-allowed-modes = <NPM13XX_LDSW_MODE_LDO>;
				regulator-init-microvolt = <3300000>;
				regulator-boot-on;
			};
		};

		npm1300_charger: charger {
			compatible = "nordic,npm1300-charger";
			status = "okay";
			vbus-limit-microamp = <500000>;
			term-microvolt = <4150000>;
			current-microamp = <150000>;
			dischg-limit-microamp = <1000000>;
			term-warm-microvolt = <4000000>;
			thermistor-ohms = <10000>;
			thermistor-beta = <3380>;
			charging-enable;
		};
	};
};

&pwm20 {
	status = "okay";
	pinctrl-0 = <&pwm20_default>;
	pinctrl-1 = <&pwm20_sleep>;
	pinctrl-names = "default", "sleep";
};
