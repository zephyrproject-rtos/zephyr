/dts-v1/;

#include <nxp/nxp_mimx9131.dtsi>
#include "frdm_imx91-pinctrl.dtsi"

/ {
	model = "NXP FRDM-IMX91 A55";
	compatible = "fsl,mimx91";

	chosen {
		zephyr,console = &lpuart1;
		zephyr,shell-uart = &lpuart1;
		zephyr,sram = &dram;
	};

	dram: memory@80000000 {
		reg = <0x80000000 DT_SIZE_M(1)>;
	};

};

&lpuart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

&tpm2 {
	status = "okay";
};

&enet {
	status = "okay";
};

&enet_mac {
	pinctrl-0 = <&pinmux_enet>;
	pinctrl-names = "default";
	phy-handle = <&phy>;
	zephyr,random-mac-address;
	phy-connection-type = "rgmii";
	status = "okay";
};

&enet_mdio {
	pinctrl-0 = <&pinmux_mdio>;
	pinctrl-names = "default";
	status = "okay";

	phy: phy@2 {
		compatible = "motorcomm,yt8521";
		reg = <2>;
		status = "okay";
		motorcomm,rx-delay-sel = <13>;
		motorcomm,tx-delay-sel = <13>;
	};
};
