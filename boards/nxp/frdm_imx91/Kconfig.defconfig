if BOARD_FRDM_IMX91

config GPIO
	default y if IMX_USDHC

if CAN

# CAN Phy must be initialized after board mux
configdefault GPIO_PCA_SERIES_INIT_PRIORITY
	default 60

configdefault CAN_TRANSCEIVER_INIT_PRIORITY
	default 65

endif # CAN

endif # BOARD_FRDM_IMX93
