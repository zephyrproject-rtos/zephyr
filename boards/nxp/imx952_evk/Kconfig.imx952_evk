config BOARD_IMX952_EVK
	select SOC_MIMX9529_M7 if BOARD_IMX952_EVK_MIMX9529_M7 || \
				BOARD_IMX952_EVK_MIMX9529_M7_DDR || \
				BOARD_IMX952_EVK_MIMX9529_M7_FLASH
	select SOC_MIMX9529_A55 if BOARD_IMX952_EVK_MIMX9529_A55 || \
				BOARD_IMX952_EVK_MIMX9529_A55_SMP
	select SOC_PART_NUMBER_MIMX9529xxVZx
