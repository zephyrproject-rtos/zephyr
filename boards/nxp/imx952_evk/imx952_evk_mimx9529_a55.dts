/dts-v1/;

#include <nxp/nxp_mimx952_a55.dtsi>
#include "imx952_evk-pinctrl.dtsi"

/ {
	model = "NXP i.MX952 A55";
	compatible = "fsl,mimx952";

	chosen {
		zephyr,console = &lpuart1;
		zephyr,shell-uart = &lpuart1;
		zephyr,sram = &dram;
	};

	cpus {
		cpu@0 {
			status = "disabled";
		};

		cpu@100 {
			status = "disabled";
		};

		cpu@200 {
			status = "disabled";
		};
	};

	dram: memory@d0000000 {
		reg = <0xd0000000 DT_SIZE_M(10)>;
	};
};

&lpuart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&lpuart1_default>;
	pinctrl-names = "default";
};

&gpio2 {
	status = "okay";
};

&lpi2c4 {
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&lpi2c4_default>;
	pinctrl-names = "default";
	status = "okay";

	gpio_exp0: pcal6408@21 {
		compatible = "nxp,pcal6408";
		reg = <0x21>;
		#gpio-cells = <2>;
		gpio-controller;
		ngpios = <8>;
		int-gpios = <&gpio2 18 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		status = "okay";
	};
};
