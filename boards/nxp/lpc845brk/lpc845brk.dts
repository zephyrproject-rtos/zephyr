/dts-v1/;

#include <nxp/lpc/nxp_lpc845.dtsi>
#include <zephyr/dt-bindings/pinctrl/lpc84x-pinctrl.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	model = "NXP LPC845-BRK Board";
	compatible = "nxp,lpc845-brk";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,flash-controller = &iap;
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio1 0 GPIO_ACTIVE_LOW>;
			label = "RGB Green Led";
		};

		led1: led_1 {
			gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;
			label = "RGB Blue Led";
		};

		led2: led_2 {
			gpios = <&gpio1 2 GPIO_ACTIVE_LOW>;
			label = "RGB Red Led";
		};
	};
};

&iap {
	status = "okay";
};

&syscon {
	status = "okay";
};

&iocon {
	status = "okay";
};

&uart0 {
	status = "okay";
	clock-source = "frg0";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&swm {
	status = "okay";

	uart0_default: uart0_default {
		group0 {
			pinmux = <LPC84X_PINMUX_M(LPC84X_SWM_USART0_TXD, P0_25)>,
				 <LPC84X_PINMUX_M(LPC84X_SWM_USART0_RXD, P0_24)>;
		};
	};
};

&flash0 {
	partitions {
		ranges;
		#address-cells = <1>;
		#size-cells = <1>;

		slot0_partition: partition@0 {
			compatible = "zephyr,mapped-partition";
			label = "image-0";
			reg = <0x00000000 DT_SIZE_K(48)>;
		};

		slot1_partition: partition@8000 {
			compatible = "zephyr,mapped-partition";
			label = "image-1";
			reg = <0x00008000 DT_SIZE_K(8)>;
		};

		storage_partition: partition@f000 {
			compatible = "zephyr,mapped-partition";
			label = "storage";
			reg = <0x0000f000 DT_SIZE_K(8)>;
		};
	};
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&pint {
	status = "okay";
};
