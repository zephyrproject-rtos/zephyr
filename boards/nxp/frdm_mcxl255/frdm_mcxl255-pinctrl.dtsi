#include <nxp/mcx/MCXL255VDF-pinctrl.h>

&pinctrl {
	pinmux_lpuart0: pinmux_lpuart0 {
		group0 {
			pinmux = <LPUART0_RXD_P2_10>,
				 <LPUART0_TXD_P2_11>;
			drive-strength = "low";
			slew-rate = "fast";
			input-enable;
		};
	};

	pinmux_aon_lpuart0: pinmux_aon_lpuart0 {
		group0 {
			pinmux = <AON_LPUART0_TX_P0_6>,
				 <AON_LPUART0_RX_P0_7>;
			drive-strength = "low";
			slew-rate = "fast";
			input-enable;
		};
	};

	pinmux_aon_kpp0: pinmux_aon_kpp0 {
		row {
			pinmux = <KPP_ROW_0_P0_12>,
					<KPP_ROW_1_P0_13>;
			drive-strength = "low";
			slew-rate = "fast";
			bias-pull-up;
			input-enable;
		};

		col {
			pinmux = <KPP_COL_0_P0_2>,
					<KPP_COL_1_P0_3>;
			drive-strength = "low";
			slew-rate = "fast";
			drive-open-drain;
			input-enable;
		};
	};
};
