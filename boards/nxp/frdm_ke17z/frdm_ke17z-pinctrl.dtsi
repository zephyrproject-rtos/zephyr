#include <nxp/kinetis/MKE17Z256VLL7-pinctrl.h>

&pinctrl {

	lpuart0_default: lpuart0_default {
		group0 {
			pinmux = <LPUART0_TX_PTB1>,
				<LPUART0_RX_PTB0>;
			drive-strength = "low";
			slew-rate = "slow";
		};
	};

	adc0_default: adc0_default {
		group0 {
			pinmux = <ADC0_SE0_PTE9>;
			drive-strength = "low";
			slew-rate = "slow";
		};
	};
};
