/dts-v1/;

#include <nxp/mcx/nxp_mcxa5x.dtsi>
#include "frdm_mcxa577.dtsi"

/ {
	model = "NXP FRDM_MCXA577 board";
	compatible = "nxp,mcxa577", "nxp,mcx";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash;
		zephyr,flash-controller = &fmu;
		zephyr,code-partition = &slot0_partition;
		zephyr,console = &lpuart1;
		zephyr,shell-uart = &lpuart1;
		zephyr,edac = &erm0;
		zephyr,crc = &crc;
		zephyr,canbus = &flexcan0;
		zephyr,system-timer-companion = &lptmr0;
	};
};

&dac0 {
	status = "okay";
	pinctrl-0 = <&pinmux_dac0>;
	pinctrl-names = "default";
};
