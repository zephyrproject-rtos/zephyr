#include <nxp/lpc/LPC54628J512ET180-pinctrl.h>

&pinctrl {
	pinmux_flexcomm0_usart: pinmux_flexcomm0_usart {
		group0 {
			pinmux = <FC0_RXD_SDA_MOSI_PIO0_29>,
				 <FC0_TXD_SCL_MISO_PIO0_30>;
			slew-rate = "standard";
		};
	};
};
