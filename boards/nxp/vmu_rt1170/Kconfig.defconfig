if BOARD_VMU_RT1170

if DISK_DRIVERS

config IMX_USDHC_DAT3_PWR_TOGGLE
	default y

endif # DISK_DRIVERS

configdefault NET_L2_ETHERNET
	default y if CPU_CORTEX_M7 # No cache memory support is required for driver

configdefault ETH_NXP_ENET_RMII_EXT_CLK
	default y


config FLASH_MCUX_FLEXSPI_MX25UM51345G
	default y if FLASH
	imply FLASH_MCUX_FLEXSPI_NOR_WRITE_BUFFER

endif # BOARD_VMU_RT1170
