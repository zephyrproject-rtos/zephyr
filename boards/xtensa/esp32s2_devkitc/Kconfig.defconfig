config BOARD
	default "esp32s2_devkitc"
	depends on BOARD_ESP32S2_DEVKITC

config ENTROPY_GENERATOR
	default y

config HEAP_MEM_POOL_SIZE
	default 32768 if WIFI
	default 4096
