/dts-v1/;

#include <espressif/esp32c5/esp32c5_common.dtsi>
#include "esp32c5_zero-partitions.dtsi"
#include "esp32c5_zero_hpcore-pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>


/ {
	model = "Waveshare ESP32=C5-Zero HP Core";
	compatible = "espressif,esp32c5";

	chosen {
		zephyr,sram = &sramhp;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,ieee802154 = &ieee802154;
	};

	aliases {
		sw0 = &boot_button;
		watchdog0 = &wdt0;
		led-strip = &led_strip;
	};

	gpio_keys {
		compatible = "gpio-keys";

		boot_button: button {
			label = "Boot Button";
			gpios = <&gpio0 28 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};


&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&trng0 {
	status = "okay";
};


&i2s {
	pinctrl-0 = <&i2s_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&wifi {
	status = "okay";
};

&ieee802154 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};


&usb_serial {
	status = "okay";
};

&i2s_default {
	group1 {
		pinmux = <I2S_O_SD_GPIO27>;
	};
};

i2s_led: &i2s {
	status = "okay";

	pinctrl-0 = <&i2s_default>;
	pinctrl-names = "default";

	dmas = <&dma 3>;
	dma-names = "tx";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-i2s";

		reg = <0>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
		reset-delay = <500>;
	};
};

&dma {
	status = "okay";
};
