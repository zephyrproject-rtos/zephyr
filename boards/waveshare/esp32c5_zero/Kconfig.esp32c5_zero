config BOARD_ESP32C5_ZERO
	select SOC_ESP32C5
	select SOC_ESP32C5_HPCORE if BOARD_ESP32C5_ZERO_ESP32C5_HPCORE
	select SOC_ESP32C5_LPCORE if BOARD_ESP32C5_ZERO_ESP32C5_LPCORE
