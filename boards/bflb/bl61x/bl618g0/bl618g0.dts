/dts-v1/;

#include <bflb/bl618.dtsi>
#include <bflb/bl61x_em_32kb_wifi.dtsi>
#include "bl618g0-pinctrl.dtsi"

/ {
	model = "Bouffalo Lab BL618 G0 evaluation board";
	compatible = "bflb,bl618";

	chosen {
		zephyr,flash = &w25q64jv;
		zephyr,flash-controller = &sf_bank1;
		zephyr,code-partition = &slot0_partition;
		zephyr,sram = &all_ram;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,entropy = &sec_eng_trng;
		zephyr,bt-hci = &bt_hci_bflb;
	};

	aliases {
		led0 = &led0;
		sw0 = &button_0;
		watchdog0 = &wdt0;
		sdhc0 = &sdhc0;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio1 0 GPIO_ACTIVE_HIGH>;
			label = "LED0";
		};
	};

	buttons {
		compatible = "gpio-keys";

		button_0: sw0 {
			gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
			label = "SW0";
		};
	};
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(320)>;
};

&clk_flash {
	divider = <1>;
};

&sf_ctrl {
	override-bank1;
	no-header;
};

&sf_bank1 {
	reg = <0xa0000000 DT_SIZE_M(8)>;
	ranges = <0x0 0xa0000000 DT_SIZE_M(8)>;

	pinctrl-0 = <&sf2_default>;
	pinctrl-names = "default";

	w25q64jv: flash@0 {
		compatible = "bflb,sf-flash", "soc-nv-flash";
		reg = <0 DT_SIZE_M(8)>;
		ranges;
		#address-cells = <1>;
		#size-cells = <1>;
		write-block-size = <4>;
		erase-block-size = <DT_SIZE_K(4)>;

		spi-bus-mode = <4>;
		sf-pad = <2>;
		jedec-id = [ef 40 17];

		/* The flash equipped on BL618G0 board doesn't support useful SFDP,
		 * and the flash header doesn't provide a working configuration.
		 * Manually set configuration for best performance.
		 */
		read-command = <0xeb>;
		read-dummy-cycles = <2>;
		continuous-read-command = <0xa0>;

		partitions {
			ranges;
			#address-cells = <1>;
			#size-cells = <1>;

			boot_header_partition: partition@0 {
				compatible = "zephyr,mapped-partition";
				label = "boot_header";
				reg = <0x00000000 0x2000>;
				read-only;
			};

			slot0_partition: partition@2000 {
				compatible = "zephyr,mapped-partition";
				label = "image-0";
				reg = <0x00002000 (DT_SIZE_M(8) - DT_SIZE_K(64) - 0x2000)>;
				read-only;
			};

			storage_partition: partition@7f0000 {
				compatible = "zephyr,mapped-partition";
				label = "storage";
				reg = <0x7f0000 DT_SIZE_K(64)>;
			};
		};
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;

	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&sec_eng_trng {
	status = "okay";
};

&bt_hci_bflb {
	status = "okay";

	pwr-table-ble = <13>;
	pwr-table-bt = <10 8 8>;
	pwr-offset-bz = <16 16 16 16 16>;
};

&wifi0 {
	status = "okay";
};

&sdhc0 {
	pinctrl-0 = <&sdh_default>;
	pinctrl-names = "default";
	status = "okay";

	sdmmc {
		compatible = "zephyr,sdmmc-disk";
		disk-name = "SD";
		status = "okay";
	};
};
