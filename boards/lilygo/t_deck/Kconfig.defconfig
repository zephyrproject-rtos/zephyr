if BOARD_T_DECK_ESP32S3_PROCPU

if LVGL

choice LV_COLOR_DEPTH
	default LV_COLOR_DEPTH_16
endchoice

config LV_COLOR_16_SWAP
	default y

endif # LVGL

if FUEL_GAUGE && BOARD_REVISION = "plus"

# Composite fuel gauge gets battery voltage from ADC-based voltage-divider sensor

config ADC
	default y

config SENSOR
	default y

endif # FUEL_GAUGE && BOARD_REVISION = "plus"

endif # BOARD_T_DECK_ESP32S3_PROCPU
