/dts-v1/;

#include <bflb/bl704l.dtsi>
#include "3r_tnh_sensor_lite-pinctrl.dtsi"

/ {
	model = "ThirdReality Temperature and Humidity Sensor Lite";
	compatible = "bflb,bl704l";

	chosen {
		zephyr,flash = &zb25d80d;
		zephyr,flash-controller = &sf_bank1;
		zephyr,code-partition = &slot0_partition;
		zephyr,itcm = &itcm;
		zephyr,sram = &sram0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,entropy = &sec_eng_trng;
	};

	aliases {
		led0 = &blue_led;
		led1 = &red_led;
		pwm-led0 = &pwm_led_blue;
		pwm-led1 = &pwm_led_red;
		sw0 = &button_0;
		watchdog0 = &wdt0;
	};

	leds {
		compatible = "gpio-leds";

		blue_led: led_0 {
			gpios = <&gpio0 7 GPIO_ACTIVE_HIGH>;
			label = "Blue - LED0";
		};

		red_led: led_1 {
			gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
			label = "Red - LED1";
		};
	};

	buttons {
		compatible = "gpio-keys";

		button_0: sw0 {
			gpios = <&gpio0 13 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	pwmleds: pwmleds {
		compatible = "pwm-leds";
		status = "disabled";

		pwm_led_blue: pwm_led_blue {
			pwms = <&pwm1 1 PWM_MSEC(1) PWM_POLARITY_INVERTED>;
			label = "Blue LED PWM";
		};

		pwm_led_red: pwm_led_red {
			pwms = <&pwm1 2 PWM_MSEC(1) PWM_POLARITY_INVERTED>;
			label = "Red LED PWM";
		};
	};
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(128)>;
};

&sf_bank1 {
	reg = <0x23000000 DT_SIZE_K(1024)>;
	ranges = <0x0 0x23000000 DT_SIZE_K(1024)>;

	zb25d80d: flash@0 {
		compatible = "bflb,sf-flash", "soc-nv-flash";
		reg = <0 DT_SIZE_K(1024)>;
		write-block-size = <1>;
		erase-block-size = <DT_SIZE_K(4)>;

		/* Only Dual mode :( */
		spi-bus-mode = <1>;
		sf-pad = <1>;
		jedec-id = [5e 32 14];

		partitions {
			#address-cells = <1>;
			#size-cells = <1>;

			slot0_partition: partition@0 {
				compatible = "zephyr,mapped-partition";
				label = "image-0";
				reg = <0x00000000 (DT_SIZE_K(900) - 0x2000)>;
				read-only;
			};

			storage_partition: partition@e1000 {
				compatible = "zephyr,mapped-partition";
				label = "storage";
				reg = <0x000e1000 DT_SIZE_K(124)>;
			};
		};
	};
};

&gpio0 {
	status = "okay";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;

	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";

	sht4x@44 {
		compatible = "sensirion,sht4x";
		reg = <0x44>;
		repeatability = <2>;
	};
};

&wdt0 {
	status = "okay";
};

&sec_eng_trng {
	status = "okay";
};

&sec_eng_aes {
	status = "okay";
};

&sec_eng_sha {
	status = "okay";
};
