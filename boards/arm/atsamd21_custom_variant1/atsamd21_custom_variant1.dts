/dts-v1/;
#include <atmel/samd21.dtsi>
#include <atmel/samx2xx18.dtsi>
#include "atsamd21_custom_variant1-pinctrl.dtsi"
#include "atsamd21_custom_variant1_connector.dtsi"

/ {
	model = "ATSAMD21 Custom Variant1";
	compatible = "samd21,samd21_custom_variant1", "atmel,samd21j18a", "atmel,samd21";

	chosen {
		zephyr,console = &sercom4;
		zephyr,shell-uart = &sercom4;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
	};

	/* Define the inboard leds */
	leds {
		compatible = "gpio-leds";
		led: led_0 {
			gpios = <&portb 22 GPIO_ACTIVE_HIGH>;
			label = "LED";
		};
	};

	/* Define the RS-485 enable GPIOs */
	rs485_en {
		compatible = "gpio-rs485-en";
		rs485_en_1: rs485_en_1 {
			gpios = <&porta 10 GPIO_ACTIVE_HIGH>;
			label = "RS485_EN_1";
		};
		rs485_en_2: rs485_en_2 {
			gpios = <&porta 13 GPIO_ACTIVE_HIGH>;
			label = "RS485_EN_2";
		};
		rs485_en_3: rs485_en_3 {
			gpios = <&porta 12 GPIO_ACTIVE_HIGH>;
			label = "RS485_EN_3";
		};
	};

	/* Define the SPI CS pin */
	spi_cs {
		compatible = "gpio-generic";
		spi_cs: spi_cs {
			gpios = <&porta 4 GPIO_ACTIVE_HIGH>;
			label = "SPI_CS";
		};
	};

	/* Define generic io pin */
	generic_io {
		compatible = "gpio-generic";
		generic_io_1: generic_io_1 {
			gpios = <&porta 14 GPIO_ACTIVE_HIGH>;
			label = "GENERIC_IO";
		};

		reset_line: reset_line {
			gpios = <&porta 8 GPIO_ACTIVE_HIGH>;
			label = "GENERIC_IO";
		};

		snx4hx595_clock: snx4hx595_clock {
			gpios = <&porta 9 GPIO_ACTIVE_HIGH>;
			label = "GENERIC_IO";
		};

		ad654_fout: ad654_fout {
			gpios = <&porta 16 GPIO_ACTIVE_HIGH>;
			label = "GENERIC_IO";
		};
	};

	relays_shift_register {
		compatible = "gpio-generic";
		/* Define control pins for the TPIC6B595DWR */
		mic584x_clock: mic584x_clock {
			gpios = <&porta 13 GPIO_ACTIVE_HIGH>;
			label = "CLOCK";
		};
		mic584x_strobe: mic584x_strobe {
			gpios = <&porta 10 GPIO_ACTIVE_HIGH>;
			label = "STROBE";
		};
		mic584x_serout: mic584x_serout {
			gpios = <&porta 17 GPIO_ACTIVE_HIGH>;
			label = "SEROUT";
		};
	};

	aliases {
		led0 = &led;
		rs485-uart-1 = &sercom2;
		rs485-uart-2 = &sercom1;
		rs485-uart-3 = &sercom5;
	};
};

&cpu0 {
	clock-frequency = <48000000>;
};

&sercom4 {
	status = "okay";
	compatible = "atmel,sam0-uart";
	current-speed = <115200>;
	rxpo = <1>;
	txpo = <0>;

	pinctrl-0 = <&sercom4_uart_default>;
	pinctrl-names = "default";
};

&sercom0 {
	status = "okay";
	compatible = "atmel,sam0-spi";
	dipo = <1>;
	dopo = <1>;
	#address-cells = <1>;
	#size-cells = <0>;

	pinctrl-0 = <&sercom0_spi_default>;
	pinctrl-names = "default";

	// cs-gpios = <&porta 4 GPIO_ACTIVE_LOW>;

	pic16c63: spi-device@0 {
		status = "okay";
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <250000>;
		label = "GenDev";
	};

	snx4hx595: spi-device@1 {
		status = "okay";
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <500000>;
		label = "GenDev";
	};
};

&sercom2 {
	status = "okay";
	compatible = "atmel,sam0-uart";
	current-speed = <115200>;
	rxpo = <1>;
	txpo = <0>;

	pinctrl-0 = <&sercom2_rs485_default>;
	pinctrl-names = "default";
};

&sercom1 {
	status = "okay";
	compatible = "atmel,sam0-uart";
	current-speed = <115200>;
	rxpo = <1>;
	txpo = <0>;

	pinctrl-0 = <&sercom1_rs485_default>;
	pinctrl-names = "default";
};

&sercom5 {
	status = "okay";
	compatible = "atmel,sam0-uart";
	current-speed = <115200>;
	rxpo = <1>;
	txpo = <0>;

	pinctrl-0 = <&sercom5_rs485_default>;
	pinctrl-names = "default";
};

zephyr_udc0: &usb0 {
	status = "okay";

	pinctrl-0 = <&usb_dc_default>;
	pinctrl-names = "default";
};

&dac0 {
	status = "okay";

	pinctrl-0 = <&dac_default>;
	pinctrl-names = "default";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		code_partition: partition@0 {
			label = "code";
			reg = <0x00000000 DT_SIZE_K(240)>; /* Full flash minus storage */
		};

		storage_partition: partition@3c000 {
			label = "storage";
			reg = <0x0003c000 DT_SIZE_K(16)>;
		};
	};
};
