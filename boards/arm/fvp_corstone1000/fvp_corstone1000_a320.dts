/dts-v1/;

#include <arm64/armv9-a.dtsi>
#include "fvp_corstone1000.dtsi"

/ {
	model = "Arm Corstone-1000-A320 FVP";
};

&cpu0 {
	compatible = "arm,cortex-a320";
};

&cpu1 {
	compatible = "arm,cortex-a320";
};

&cpu2 {
	compatible = "arm,cortex-a320";
};

&cpu3 {
	compatible = "arm,cortex-a320";
};
