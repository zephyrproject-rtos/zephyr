/dts-v1/;

#include <espressif/esp32s3/esp32s3_common.dtsi>
#include <espressif/partitions_0x0_amp.dtsi>
#include "matouch_mtro128g-pinctrl.dtsi"

/ {
	model = "Makerfabs Matouch MTRO128g";
	compatible = "espressif,esp32s3";

	chosen {
		zephyr,sram = &sram1;
		zephyr,ipc_shm = &shm0;
		zephyr,ipc = &ipm0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_appcpu_partition;
	};
};

&trng0 {
	status = "okay";
};

&ipm0 {
	status = "okay";
};

/* 16MB flash */
&flash0 {
	reg = <0x0 DT_SIZE_M(16)>;
	ranges = <0x0 0x0 DT_SIZE_M(16)>;
};
