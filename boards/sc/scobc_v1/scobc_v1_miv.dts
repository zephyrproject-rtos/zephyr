/dts-v1/;

/ {
	model = "SC-OBC Module V1 IGLOO2 Mi-V";

	#address-cells = <1>;
	#size-cells = <1>;

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &tcm0;
		zephyr,flash-controller = &envm;
		zephyr,flash = &flash0;
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu@0 {
			clock-frequency = <0>;
			compatible = "microchip,miv", "riscv";
			device_type = "cpu";
			reg = <0>;
			riscv,isa-base = "rv32i";
			riscv,isa-extensions = "i", "m", "c", "zicsr", "zifencei";

			hlic: interrupt-controller {
				compatible = "riscv,cpu-intc";
				#address-cells = <0>;
				#interrupt-cells = <1>;
				interrupt-controller;
			};
		};
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "microchip,miv-soc", "simple-bus";
		ranges;

		plic: interrupt-controller@10000000 {
			compatible = "sifive,plic-1.0.0";
			#address-cells = <0>;
			#interrupt-cells = <2>;
			interrupt-controller;
			interrupts-extended = <&hlic 11>;
			reg = <0x10000000 0x04000000>;
			riscv,max-priority = <1>;
			riscv,ndev = <31>;
		};

		uart0: uart@11001000 {
			compatible = "microchip,coreuart";
			reg = <0x11001000 0x1000>;
			status = "okay";
			current-speed = <0>;
			clock-frequency = <0>;
		};

		mtimer: timer@1200bff8 {
			compatible = "riscv,machine-timer";
			interrupts-extended = <&hlic 7>;
			reg = <0x1200bff8 0x8 0x12004000 0x8>;
			reg-names = "mtime", "mtimecmp";
			clock-frequency = <25000000>;
		};

		tcm0: memory@20000000 {
			device_type = "memory";
			compatible = "mmio-sram";
			reg = <0x20000000 0x20000>;
		};

		envm: flash-controller@60080000 {
			compatible = "microchip,igloo2-envm-controller";

			/* Control registers for each physical eNVM bank. */
			reg = <0x60080000 0x200>, <0x600c0000 0x200>;
			reg-names = "envm0", "envm1";

			ranges;
			#address-cells = <1>;
			#size-cells = <1>;
			status = "okay";

			flash0: flash@60000000 {
				/*
				 * Logical eNVM data window exposed to the CPU.
				 * eNVM0 and eNVM1 are contiguous here.
				 */
				compatible = "soc-nv-flash";
				reg = <0x60000000 0x80000>;
				ranges = <0x0 0x60000000 0x80000>;
				#address-cells = <1>;
				#size-cells = <1>;
				status = "okay";
			};
		};

		uartlite0: uartlite@8f000000 {
			compatible = "xlnx,xps-uartlite-1.00.a";
			interrupt-parent = <&plic>;
			interrupts = <17 1>;
			reg = <0x8f000000 0x10000>;
			status = "disabled";
		};
	};
};
