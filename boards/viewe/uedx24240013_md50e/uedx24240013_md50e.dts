/dts-v1/;

#include <zephyr/dt-bindings/display/panel.h>
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/input/esp32-touch-sensor-input.h>
#include <espressif/esp32c3/esp32c3_wroom_n4.dtsi>
#include <espressif/partitions_0x0_default.dtsi>
#include "uedx24240013_md50e-pinctrl.dtsi"

/ {
	model = "VIEWE UEDX24240013-MD50E";
	compatible = "viewe,uedx24240013_md50e", "espressif,esp32c3";

	chosen {
		zephyr,sram = &sram1;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci = &esp32_bt_hci;
		zephyr,display = &gc9a01;
	};

	aliases {
		sw0 = &button;
		qdec0 = &encoder;
		watchdog0 = &wdt0;
	};

	keys: keys {
		compatible = "gpio-keys";
		debounce-interval-ms = <10>;

		button: button {
			gpios = <&gpio0 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_0>;
		};

		encoder_button: encoder_button {
			gpios = <&gpio0 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_ENTER>;
		};
	};

	encoder: encoder {
		compatible = "gpio-qdec";
		gpios = <&gpio0 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>,
			<&gpio0 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		zephyr,axis = <INPUT_REL_WHEEL>;
		steps-per-period = <4>;
		sample-time-us = <2000>;
		idle-timeout-ms = <200>;
	};

	lcd_backlight_en {
		compatible = "regulator-fixed";
		regulator-name = "LCD Backlight Enable";
		enable-gpios = <&gpio0 8 GPIO_ACTIVE_LOW>;
		regulator-boot-on;
	};

	mipi_dbi {
		compatible = "zephyr,mipi-dbi-spi";
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		spi-dev = <&spi2>;
		dc-gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
		write-only;

		gc9a01: gc9a01@0 {
			status = "okay";
			compatible = "galaxycore,gc9x01x";
			reg = <0>;
			mipi-max-frequency = <DT_FREQ_M(100)>;
			pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
			display-inversion;
			width = <240>;
			height = <240>;
		};
	};
};

&timer0 {
	status = "disabled";
};

&timer1 {
	status = "disabled";
};

&trng0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";
};

&esp32_bt_hci {
	status = "okay";
};

&wifi {
	status = "okay";
};

&usb_serial {
	status = "okay";
};
