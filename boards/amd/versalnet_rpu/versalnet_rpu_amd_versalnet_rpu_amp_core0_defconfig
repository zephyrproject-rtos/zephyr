# VersalNet RPU AMP Core0 defconfig

# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable serial port
CONFIG_UART_PL011=y

# Disable lockstep — split mode
CONFIG_DCLS=n

# GICv3: Skip distributor re-init if another core already configured it.
# In split mode either core may boot first; both must preserve shared
# GICD state (ISENABLER, IROUTER, priorities).
CONFIG_GIC_SAFE_CONFIG=y
