# Versal Gen 2 RPU AMP Core1 defconfig

# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable serial port
CONFIG_UART_PL011=y

# Disable lockstep — split mode
CONFIG_DCLS=n

# GICv3: Skip distributor re-init on secondary core
CONFIG_GIC_SAFE_CONFIG=y
