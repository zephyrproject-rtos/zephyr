# Versal RPU AMP Core0 defconfig

CONFIG_XIP=n

CONFIG_ISR_STACK_SIZE=512
CONFIG_THREAD_STACK_INFO=y

# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable serial port
CONFIG_UART_PL011=y

# Disable lockstep — split mode
CONFIG_DCLS=n

# GIC: Skip distributor re-init if another core already configured it.
# In split mode either core may boot first; both must preserve shared
# GICD state (ISENABLER, ITARGETSR, priorities).
CONFIG_GIC_SAFE_CONFIG=y
