/dts-v1/;
#include <st/wba/stm32wba25Xe.dtsi>
#include <st/wba/stm32wba25ceux-pinctrl.dtsi>
#include "arduino_r3_connector.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "STMicroelectronics STM32WBA25CE1-NUCLEO board";
	compatible = "st,stm32wba25ce1-nucleo";

	#address-cells = <1>;
	#size-cells = <1>;

	chosen {
		zephyr,uart-pipe = &usart1;
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	leds: leds {
		compatible = "gpio-leds";

		/* Pin muxing conflict with ADC4 */
		blue_led_1: led_0 {
			gpios = <&gpioa 7 GPIO_ACTIVE_LOW>;
			label = "User LD1";
		};

		green_led_2: led_1 {
			gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;
			label = "User LD2";
		};

		red_led_3: led_2 {
			gpios = <&gpiob 15 GPIO_ACTIVE_LOW>;
			label = "User LD3";
		};
	};

	pwmleds: pwmleds {
		compatible = "pwm-leds";

		green_pwm_led: green_pwm_led {
			pwms = <&pwm2 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_button_1: button_0 {
			label = "User B1";
			gpios = <&gpioa 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_0>;
		};

		user_button_2: button_1 {
			label = "User B2";
			gpios = <&gpioc 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_1>;
		};

		user_button_3: button_2 {
			label = "User B3";
			gpios = <&gpioa 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_2>;
		};
	};

	aliases {
		led0 = &blue_led_1;
		led1 = &green_led_2;
		led2 = &red_led_3;
		pwm-led0 = &green_pwm_led;
		sw0 = &user_button_1;
		sw1 = &user_button_2;
		sw2 = &user_button_3;
		mcuboot-led0 = &blue_led_1;
		mcuboot-button0 = &user_button_1;
		die-temp0 = &die_temp;
	};
};

&clk_lse {
	status = "okay";
};

&clk_hse {
	status = "okay";
};

&clk_hsi {
	status = "okay";
};

&rcc {
	clocks = <&clk_hse>;
	clock-frequency = <DT_FREQ_M(32)>; /* Lowest value to manage radio events */
	ahb-prescaler = <1>;
	ahb5-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <2>;
	apb7-prescaler = <1>;
};

&pwr {
	power-supply = "smps";
};

&iwdg {
	status = "okay";
};

&rtc {
	status = "okay";
	clocks = <&rcc STM32_CLOCK(APB7, 21)>,
		 <&rcc STM32_SRC_LSE RTC_SEL(1)>;
	prescaler = <32768>;
};

&usart1 {
	clocks = <&rcc STM32_CLOCK(APB2, 14)>,
		 <&rcc STM32_SRC_HSI16 USART1_SEL(2)>;
	pinctrl-0 = <&usart1_tx_pa6 &usart1_rx_pa12>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&spi3 {
	pinctrl-0 = <&spi3_nss_pa5 &spi3_sck_pa8
		     &spi3_miso_pa10 &spi3_mosi_pa9>;
	pinctrl-names = "default";
	status = "disabled";
};

&i2c3 {
	pinctrl-0 = <&i2c3_scl_pb2 &i2c3_sda_pa11>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
};

&adc4 {
	/* Pin muxing conflict with LED1, disabled by default */
	pinctrl-0 = <&adc4_in2_pa7>;
	pinctrl-names = "default";
	st,adc-clock-source = "ASYNC";
	st,adc-prescaler = <4>;
	status = "disabled";
};

&die_temp {
	/* keep disabled if adc4 is disabled */
	status = "disabled";
};

&timers2 {
	st,prescaler = <10000>;
	status = "okay";

	pwm2: pwm {
		status = "okay";
		pinctrl-0 = <&tim2_ch1_pb12>;
		pinctrl-names = "default";
	};
};

stm32_lp_tick_source: &lptim1 {
	clocks = <&rcc STM32_CLOCK(APB7, 11)>,
		 <&rcc STM32_SRC_LSE LPTIM1_SEL(3)>;
	status = "okay";
};

&rng {
	status = "okay";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(64)>;
		};

		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 DT_SIZE_K(192)>;
		};

		slot1_partition: partition@40000 {
			label = "image-1";
			reg = <0x00040000 DT_SIZE_K(192)>;
		};

		storage_partition: partition@70000 {
			label = "storage";
			reg = <0x00070000 DT_SIZE_K(64)>;
		};
	};
};
