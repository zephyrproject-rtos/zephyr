/dts-v1/;
#include "stm32n6570_dk_common.dtsi"

/ {
	model = "STMicroelectronics STM32N6570 Discovery Kit board";
	compatible = "st,stm32n6570-dk-fsbl";

	chosen {
		zephyr,flash-controller = &mx66uw1g45g_1;
		zephyr,flash = &ext_flash_xspi1;
		zephyr,uart-mcumgr = &usart1;
	};
};

&xspim {
	io-port-1 = <&xspi3>;
	io-port-2 = <&xspi2>, <&xspi1>;
	status = "okay";
	req2ack-time = <10>;
};

&xspi2 {
	status = "okay";
	memory-mapped;
};

&mx66uw1g45g{
	status = "okay";
};

&xspi1 {
	status = "okay";
};

&ext_flash_xspi2{
	status = "okay";
};

&mx66uw1g45g_1{
	status = "okay";
	ncs-line = <1>;
};

&ext_flash_xspi1{
	status = "okay";
	#include "partitions.dtsi"
};
