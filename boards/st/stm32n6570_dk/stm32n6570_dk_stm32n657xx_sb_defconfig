# Enable UART driver
CONFIG_SERIAL=y

# Enable GPIO
CONFIG_GPIO=y

# Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable MPU
CONFIG_ARM_MPU=y

# Enable HW stack protection
CONFIG_HW_STACK_PROTECTION=y

# No internal Flash
CONFIG_XIP=n

# Use serial boot (USB)
CONFIG_STM32N6_BOOT_SERIAL=y

# Rely on Multi-Heap / Shared-Multi-Heap for PSRAM access
CONFIG_MULTI_HEAP=y
CONFIG_SHARED_MULTI_HEAP=y

# Let LTDC use memory allocated via SMH
CONFIG_STM32_LTDC_FB_USE_SHARED_MULTI_HEAP=y
CONFIG_STM32_LTDC_FB_SMH_ATTRIBUTE=2
CONFIG_STM32_LTDC_FB_SMH_ALIGN=256
