/dts-v1/;
#include <st/u3/stm32u3c5Xi.dtsi>
#include <st/u3/stm32u3c5zitxq-pinctrl.dtsi>
#include "arduino_r3_connector.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "STMicroelectronics STM32U3C5ZI-NUCLEO-Q board";
	compatible = "st,stm32u3c5zi-nucleo-q";

	#address-cells = <1>;
	#size-cells = <1>;

	chosen {
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan1;
		zephyr,code-partition = &slot0_partition;
	};

	aliases {
		led0 = &green_led_1;
		sw0 = &user_button;
		pwm-led0 = &pwm_led_1;
		pwm-led1 = &pwm_led_2;
		watchdog0 = &iwdg;
	};

	leds: leds {
		compatible = "gpio-leds";

		green_led_1: led_1 {
			gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;
			label = "User LD1";
		};

		red_led_1: led_2 {
			gpios = <&gpioe 14 GPIO_ACTIVE_HIGH>;
			label = "User LD2";
		};

		/* PF8 is shared between User LD3 and FDCAN1_TX. Keep LD3 enabled by default. */
		blue_led_1: led_3 {
			gpios = <&gpiof 8 GPIO_ACTIVE_HIGH>;
			label = "User LD3";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_button: button {
			label = "User";
			gpios = <&gpioc 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	pwmleds: pwmleds {
		compatible = "pwm-leds";
		/* NOTE: disabled by default, PWM reuses LED pins */
		status = "disabled";

		pwm_led_1: green_led_1 {
			pwms = <&pwm2 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "green led";
		};

		pwm_led_2: red_led_1 {
			pwms = <&pwm1 4 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "red led";
		};
	};
};

&clk_hsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&clk_lse {
	status = "okay";
};

&clk_msik {
	status = "okay";
};

&clk_msis {
	status = "okay";
	msi-pll-mode;
	msi-range = <0>; /* 96 MHz */
};

&rcc {
	clocks = <&clk_msis>;
	clock-frequency = <DT_FREQ_M(96)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
	apb3-prescaler = <1>;
};

&clk_lsi {
	status = "okay";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/*
		 * Following flash partition is dedicated to the use of nucleo_u3c5zi_q
		 * with TZEN=0 (so w/o TFM).
		 * The board has in total 2048 KiB of flash memory.
		 */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(64)>;
		};

		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 DT_SIZE_K(928)>;
		};

		slot1_partition: partition@f8000 {
			label = "image-1";
			reg = <0x000f8000 DT_SIZE_K(928)>;
		};

		storage_partition: partition@1e0000 {
			label = "storage";
			reg = <0x001e0000 DT_SIZE_K(128)>;
		};
	};
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&gpdma1 {
	status = "okay";
};

&lpuart1 {
	pinctrl-0 = <&lpuart1_tx_pg7 &lpuart1_rx_pg8>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
};

/* PA5 is shared between SPI1_SCK and TIM2_CH1 (PWM2). Keep SPI1 enabled by default */
&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";

	cs-gpios = <&gpiod 14 GPIO_ACTIVE_LOW>;
	status = "okay";
};

&timers1 {
	st,prescaler = <10000>;
	status = "okay";

	pwm1: pwm {
		pinctrl-0 = <&tim1_ch4_pe14>;
		pinctrl-names = "default";
		status = "okay";
	};
};

/* PA5 is shared between SPI1_SCK and TIM2_CH1 (PWM2). Keep PWM2 disabled by default */
&timers2 {
	st,prescaler = <10000>;
	status = "okay";

	pwm2: pwm {
		pinctrl-0 = <&tim2_ch1_pa5>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&iwdg {
	status = "okay";
};

&rng {
	status = "okay";
};

zephyr_udc0: &usb {
	pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

/* PF8 is shared between User LD3 and FDCAN1_TX. Keep FDCAN1 disabled by default. */
&fdcan1 {
	pinctrl-0 = <&fdcan1_rx_pf7 &fdcan1_tx_pf8>;
	pinctrl-names = "default";
	status = "disabled";
};

&rtc {
	clocks = <&rcc STM32_CLOCK(APB1, 30)>,
		 <&rcc STM32_SRC_LSE RTC_SEL(1)>;
	status = "okay";
};
