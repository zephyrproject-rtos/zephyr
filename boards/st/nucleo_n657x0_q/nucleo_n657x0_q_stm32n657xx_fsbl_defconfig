# Enable UART driver
CONFIG_SERIAL=y

# Enable GPIO
CONFIG_GPIO=y

# Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable MPU
CONFIG_ARM_MPU=y

# Enable Hardware stack protection
CONFIG_HW_STACK_PROTECTION=y

# Don't place text and such in ROM
CONFIG_XIP=n

# HAL needs TRUSTED_EXECUTION_SECURE explicitly enabled
CONFIG_TRUSTED_EXECUTION_SECURE=y
