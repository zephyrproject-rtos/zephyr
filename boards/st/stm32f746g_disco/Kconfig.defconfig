if BOARD_STM32F746G_DISCO

configdefault NET_L2_ETHERNET
	default y

# MEMC needs to be enabled in order to store
# LTDC framebuffer to external SDRAM connected to FMC
config MEMC
	default y if STM32_LTDC

endif # BOARD_STM32F746G_DISCO
