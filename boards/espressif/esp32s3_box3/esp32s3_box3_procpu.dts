/dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n16.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <espressif/partitions_0x0_amp_16M.dtsi>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include "esp32s3_box3-pinctrl.dtsi"

/ {
	model = "Espressif ESP32S3-BOX-3 PROCPU";
	compatible = "espressif,esp32s3";

	aliases {
		watchdog0 = &wdt0;
		sw0 = &button0;
		radar-int = &radar_detect_pin;
	};

	chosen {
		zephyr,sram = &sram1;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "BOOT Button";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	gpio_radar {
		compatible = "gpio-keys";
		radar_detect_pin: radar_detect {
			gpios = <&gpio0 21 GPIO_ACTIVE_LOW>;
			label = "Radar Detection Pin";
			zephyr,code = <INPUT_KEY_1>;
		};
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";

	at581x: at581x@28 {
		compatible = "andar,at581x";
		reg = <0x28>;
		status = "okay";
	};
};

&usb_serial {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&dma {
	status = "okay";
};