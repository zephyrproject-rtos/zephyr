/dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n16.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/input/esp32-touch-sensor-input.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <espressif/partitions_0x0_amp_16M.dtsi>
#include "esp32s3_box3-pinctrl.dtsi"

/ {
	model = "Espressif ESP32S3-BOX-3 PROCPU";
	compatible = "espressif,esp32s3";

	aliases {
		watchdog0 = &wdt0;
		sw0 = &button0;
		radar-int = &radar_detect_pin;
		audio-codec-spk = &es8311;
		audio-codec-mic = &es7210;
		audio-i2s = &i2s0;
	};

	chosen {
		zephyr,sram = &sram1;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,audio = &i2s0;
		zephyr,display = &esp32_lcd;
		zephyr,keyboard-scan = &gt911;
		zephyr,bt-hci = &esp32_bt_hci;
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "BOOT Button";
			zephyr,code = <INPUT_KEY_0>;
		};

		button1: button_1 {
			gpios = <&gpio0 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "MUTE Button";
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	leds {
		compatible = "gpio-leds";

		lcd_backlight: lcd_backlight {
			gpios = <&gpio1 15 GPIO_ACTIVE_HIGH>;
			label = "LCD Backlight";
		};

		pa_ctrl: pa_ctrl {
			gpios = <&gpio1 14 GPIO_ACTIVE_HIGH>;
			label = "Speaker PA Control";
		};
	};

	gpio_radar {
		compatible = "gpio-keys";
		radar_detect_pin: radar_detect {
			gpios = <&gpio0 21 GPIO_ACTIVE_LOW>;
			label = "Radar Detection Pin";
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	mute_ctrl_gpio {
		compatible = "gpio-leds";

		mute_ctrl: mute_ctrl {
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
			label = "Audio Mute Control";
		};
	};
};

&usb_serial {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";

	gt911: gt911@5d {
		compatible = "goodix,gt911";
		reg = <0x5d>;
		irq-gpios = <&gpio0 3 GPIO_ACTIVE_LOW>;
		status = "okay";
	};

	es8311: es8311@18 {
		compatible = "everest,es8311";
		reg = <0x18>;
		pa-gpios = <&gpio1 14 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};

	es7210: es7210@40 {
		compatible = "everest,es7210";
		reg = <0x40>;
		mclk-freq = <4096000>;
		mic-mask = <0x03>;
		mic-gain-db = <24>;
		status = "okay";
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
	
	at581x: at581x@28 {
		compatible = "andar,at581x";
		reg = <0x28>;
		status = "okay";
	};

	aht30: aht30@38 {
		compatible = "aosong,aht20";
		reg = <0x38>;
		status = "okay";
	};
};

&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";

	esp32_lcd: esp32_lcd@0 {
		compatible = "espressif,esp32-lcd";
		reg = <0>;
		spi-max-frequency = <20000000>;
		width = <320>;
		height = <240>;
		pixel-format = <0>;
		rotation = <0>;
		dc-gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio1 16 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

&touch {
	debounce-interval-ms = <30>;
	href-microvolt = <2700000>;
	lref-microvolt = <500000>;
	href-atten-microvolt = <1000000>;
	filter-mode = <ESP32_TOUCH_FILTER_MODE_IIR_16>;
	filter-debounce-cnt = <1>;
	filter-noise-thr = <ESP32_TOUCH_FILTER_NOISE_THR_4_8TH>;
	filter-jitter-step = <4>;
	filter-smooth-level = <ESP32_TOUCH_FILTER_SMOOTH_MODE_IIR_2>;
};

&i2s0 {
	status = "okay";
	pinctrl-0 = <&i2s0_default>;
	pinctrl-names = "default";
};

&timer0 {
	status = "okay";
};

&timer1 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&wifi {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&dma {
	status = "okay";
};
