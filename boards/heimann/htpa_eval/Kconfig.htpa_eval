config BOARD_HTPA_EVAL
	select SOC_SAME70Q20B if BOARD_HTPA_EVAL_SAME70Q20B
	select SOC_SAME70Q21 if BOARD_HTPA_EVAL_SAME70Q21
	select SOC_SAME70Q21B if BOARD_HTPA_EVAL_SAME70Q21B

config BOARD_HTPA_SENSOR_160x120
	bool
	default y
	help
	  Enable 160x120 sensor.
