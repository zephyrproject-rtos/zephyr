config COUNTER_MSPM0_TIMER
	bool "TI MSPM GPTIMER counter driver"
	default y
	depends on DT_HAS_TI_MSPM0_TIMER_COUNTER_ENABLED
	help
	  Enable the TI MSPM MCU family counter driver.
