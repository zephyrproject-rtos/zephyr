config AC057TC1
	bool "AC057TC1 display controller"
	default y
	depends on DT_HAS_EINK_AC057TC1_ENABLED
	select MIPI_DBI
	select DISPLAY_COLOR_PALETTE
	select DISPLAY_COLOR_DITHER_SUPPORTED
	help
	  Enable driver for AC057TC1 display controller.
