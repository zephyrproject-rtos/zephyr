config MFD_INFINEON_AUTANALOG_PRB
	bool "Infineon AutAnalog PRB multi-function device driver"
	default y
	depends on DT_HAS_INFINEON_AUTANALOG_PRB_ENABLED
	depends on MFD_INFINEON_AUTANALOG
	help
	  Enable the Infineon AutAnalog PRB (Programmable Reference Block) MFD
	  driver.  The PRB contains two voltage references (Vref0, Vref1) that
	  share a combined configuration.  This driver aggregates both references
	  and manages the shared PDL config structure.

config MFD_INFINEON_AUTANALOG_PRB_INIT_PRIORITY
	int "Infineon AutAnalog PRB MFD init priority"
	default 42
	depends on MFD_INFINEON_AUTANALOG_PRB
	help
	  Init priority for the PRB MFD.  Must be higher (later) than the
	  AutAnalog MFD init priority (default 41).
