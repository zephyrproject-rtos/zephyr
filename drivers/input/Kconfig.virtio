config INPUT_VIRTIO
	bool "VIRTIO input device driver"
	default y
	depends on DT_HAS_VIRTIO_INPUT_ENABLED
	select VIRTIO
	help
	  Enable driver for VIRTIO input devices.

config INPUT_VIRTIO_EVENT_BUF_COUNT
	int "Number of queued event buffers"
	depends on INPUT_VIRTIO
	default 16
	range 1 256
	help
	  Number of event buffers queued on the event virtqueue. Each buffer
	  holds a single input event.
