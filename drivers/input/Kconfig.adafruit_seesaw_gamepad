config INPUT_ADAFRUIT_SEESAW_GAMEPAD
	bool "Adafruit Mini I2C Gamepad with seesaw"
	default y
	depends on DT_HAS_ADAFRUIT_SEESAW_GAMEPAD_ENABLED
	select I2C
	help
	  Enable driver for the Adafruit Mini I2C Gamepad with seesaw
	  (product 5743). Reports a 2-axis joystick (ABS_X/ABS_Y) and
	  6 buttons (A, B, X, Y, Start, Select) via the Zephyr input
	  subsystem.
