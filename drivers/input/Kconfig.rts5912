config INPUT_REALTEK_RTS5912_KBD
	bool "RealTek RTS5912 keyboard scanning driver"
	default y
	depends on DT_HAS_REALTEK_RTS5912_KBD_ENABLED
	select INPUT_KBD_MATRIX
	help
	  This option enables the REALTEK keyboard scan driver.
