# TAD2144 TMR angle sensor device configuration options

# Copyright (c) 2020 TDK Invensense
# SPDX-License-Identifier: Apache-2.0

menuconfig TAD2144
	bool "TAD2144 TMR Angle Sensor Device"
	default y
	depends on DT_HAS_INVENSENSE_TAD2144_ENABLED
	select SPI if $(dt_compat_on_bus,$(DT_COMPAT_INVENSENSE_TAD2144),spi)
	select I2C if $(dt_compat_on_bus,$(DT_COMPAT_INVENSENSE_TAD2144),i2c)
	select USE_EMD_TAD2144
	help
	  Enable driver for TAD2144 SPI-based TMR angle sensor device.

if TAD2144

choice TAD2144_TRIGGER_MODE
	prompt "Trigger mode"
	default TAD2144_TRIGGER_GLOBAL_THREAD
	help
	  Specify the type of triggering to be used by the driver.

config TAD2144_TRIGGER_NONE
	bool "No trigger"

config TAD2144_TRIGGER_GLOBAL_THREAD
	bool "Use global thread"
	depends on GPIO
	select TAD2144_TRIGGER

config TAD2144_TRIGGER_OWN_THREAD
	bool "Use own thread"
	depends on GPIO
	select TAD2144_TRIGGER

endchoice

config TAD2144_TRIGGER
	bool
	default y

config TAD2144_THREAD_PRIORITY
	int "Thread priority"
	depends on TAD2144_TRIGGER_OWN_THREAD
	default 10
	help
	  Priority of thread used by the driver to handle interrupts.

config TAD2144_THREAD_STACK_SIZE
	int "Thread stack size"
	depends on TAD2144_TRIGGER_OWN_THREAD
	default 1024
	help
	  Stack size of thread used by the driver to handle interrupts.

endif # TAD2144

