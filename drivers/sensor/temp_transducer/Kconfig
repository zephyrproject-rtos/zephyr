config TEMP_TRANSDUCER
	bool "Temperature transducer driver"
	default y
	depends on DT_HAS_TEMPERATURE_TRANSDUCER_ENABLED
	select ADC
	help
	  Enable temperature transducer driver for converting
	  voltage/current from temperature sensors to temperature values.
	  This driver supports transducers like LTC2997 and AD590 that
	  convert thermal quantities into voltage or current.
