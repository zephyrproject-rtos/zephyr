config MAX31826
	bool "MAX31826 1-Wire Temperature Sensor"
	default y
	depends on DT_HAS_MAXIM_MAX31826_ENABLED
	depends on W1_NET
	help
	  Enable driver for the MAX31826 1-Wire temperature sensor.
