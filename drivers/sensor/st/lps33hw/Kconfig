config LPS33HW
	bool "LPS33HW pressure and temperature sensor"
	default y
	depends on DT_HAS_ST_LPS33HW_ENABLED
	select I2C
	help
	  Enable the I2C driver for the STMicroelectronics LPS33HW
	  pressure and temperature sensor.
