config TACH_RTS5912
	bool "RTS5912 Tachometer sensor"
	default y
	depends on DT_HAS_REALTEK_RTS5912_TACH_ENABLED
	help
	  Enable the Realtek RTS5912 tachometer sensor.

if TACH_RTS5912

choice
	prompt "Number of tach edges"
	default TACH_RTS5912_5_TACH_EDGES
	help
	  This value represents the number of Tach edges that
	  will be used to determine the interval for which the number of
	  100KHz pulses will be counted.

config TACH_RTS5912_9_TACH_EDGES
	bool "Configure 9 tach edges or 4 tach periods"

config TACH_RTS5912_5_TACH_EDGES
	bool "Configure 5 tach edges or 2 tach periods"

config TACH_RTS5912_3_TACH_EDGES
	bool "Configure 3 tach edges or 1 tach period"

config TACH_RTS5912_2_TACH_EDGES
	bool "Configure 2 tach edges or 1/2 tach period"

endchoice

config TACH_RTS5912_EDGES
	int
	range 0 3
	default 0 if TACH_RTS5912_2_TACH_EDGES
	default 1 if TACH_RTS5912_3_TACH_EDGES
	default 2 if TACH_RTS5912_5_TACH_EDGES
	default 3 if TACH_RTS5912_9_TACH_EDGES

endif #TACH_RTS5912
