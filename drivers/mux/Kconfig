menuconfig MUX_CONTROL
	bool "Mux control drivers"
	help
	  Enable support for mux control hardware drivers. This is
	  for hardware devices which are used to mux and enable or
	  disable various signals either on or off SOCs.

if MUX_CONTROL

config MUX_CONTROL_INIT_PRIORITY
	int "Mux control init priority"
	default KERNEL_INIT_PRIORITY_DEFAULT
	help
	  Mux control device driver init priority.

config MUX_CONTROL_MAX_CELLS
	int "Maximum number of cells in a mux control specifier"
	default 4
	help
	  Upper bound on the number of cells in a single mux-controls or
	  mux-states specifier.  Used by the syscall handler to allocate a
	  fixed-size kernel-side copy of the cells array, avoiding VLAs in
	  syscall context.  Increase this value if your MUX binding requires
	  more than 4 cells per specifier.

module = MUX_CONTROL
module-str = mux control
source "subsys/logging/Kconfig.template.log_config"

source "drivers/mux/Kconfig.reg_mux"
source "drivers/mux/Kconfig.nxp_inputmux"
source "drivers/mux/Kconfig.nxp_xbar"
source "drivers/mux/Kconfig.gpio_mux"

endif # MUX_CONTROL
