# TI ADS7828/ADS7830 ADC configuration options

# Copyright (c) 2026 RAKwireless Technology Limited
# SPDX-License-Identifier: Apache-2.0

config ADC_ADS7828
	bool "TI ADS7828/ADS7830 I2C ADC"
	default y
	depends on DT_HAS_TI_ADS7828_ENABLED || DT_HAS_TI_ADS7830_ENABLED
	select I2C
	help
	  Enable the driver for the Texas Instruments ADS7828 12-bit and
	  ADS7830 8-bit, 8-channel I2C SAR ADCs.
