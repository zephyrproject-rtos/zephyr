config ADC_MSPM0_ADC12
	bool "TI ADC MSPM0 driver"
	default y
	depends on DT_HAS_TI_MSPM0_ADC12_ENABLED
	select USE_MSPM0_DL_ADC
	select PINCTRL
	help
	  Enable support for ADC12 on the TI MSPM0 series.
