config VIDEO_HEIMANN_HTPA
	bool "Heimann HTPA IR camera"
	depends on DT_HAS_HEIMANN_HTPA_160X120_ENABLED || DT_HAS_HEIMANN_HTPA_120X84_ENABLED
	select SPI
	select FLASH
	default y
	help
	  Enable the driver for Heimann HTPA thermopile infrared array sensors with
	  integrated flash memory that holds temperature calibration and compensation data.

if VIDEO_HEIMANN_HTPA

config VIDEO_HM_HTPA_WORKER_STACK_SIZE
	int "HTPA worker thread stack size"
	default 1024
	help
	  Stack size for the background worker that produces mock frames.

config VIDEO_HM_HTPA_WORKER_PRIORITY
	int "HTPA worker thread priority"
	default 5
	help
	  Priority for the background worker thread.

config VIDEO_HM_HTPA_GRAB_STACK_SIZE
	int "HTPA sensor grab thread stack size"
	default 1024
	help
	  Stack size for the thread that continuously acquires sensor frames.

config VIDEO_HM_HTPA_GRAB_PRIORITY
	int "HTPA sensor grab thread priority"
	default 4
	help
	  Priority for the sensor acquisition thread.

choice VIDEO_HM_HTPA_AUTOSCALE_MODE
	prompt "HTPA automatic scaling mode"
	default VIDEO_HM_HTPA_AUTOSCALE_HISTOGRAM
	help
	  Select how raw sensor values are mapped to the output pixel range.

config VIDEO_HM_HTPA_AUTOSCALE_HISTOGRAM
	bool "Histogram percentile scaling"
	help
	  Scale using the first and 99th percentiles to reject isolated outliers.

config VIDEO_HM_HTPA_AUTOSCALE_LEGACY
	bool "Legacy minimum and maximum scaling"
	help
	  Scale using the original sequential minimum and maximum heuristic.

endchoice

endif # VIDEO_HEIMANN_HTPA
