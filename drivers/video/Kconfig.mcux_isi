config VIDEO_MCUX_ISI
	bool "MCUX ISI driver"
	default y
	depends on DT_HAS_NXP_IMX_ISI_ENABLED
	help
	  Enable support for MCUX Image Sensing Interface (ISI) driver.

config VIDEO_MCUX_ISI_CORE_INIT_PRIORITY
	int "NXP MCUX ISI Core init priority"
	default 59
	depends on VIDEO_MCUX_ISI
	help
	  Initialization priority for the MCUX ISI Core device.
