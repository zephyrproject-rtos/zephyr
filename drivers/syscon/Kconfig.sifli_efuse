config SYSCON_SIFLI_EFUSE
	bool "SiFli SF32LB eFuse driver"
	default y
	depends on DT_HAS_SIFLI_SF32LB_EFUSE_ENABLED
	help
	  E-Fuse access via SYSCON API for SiFli SF32LB platforms.
	  The driver caches entire eFuse content at init time for
	  fast subsequent reads.
