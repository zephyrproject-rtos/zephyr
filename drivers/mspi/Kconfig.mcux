config MSPI_MCUX_FLEXSPI
	bool "MCUX FlexSPI MSPI controller driver"
	depends on DT_HAS_NXP_FLEXSPI_MSPI_CONTROLLER_ENABLED
	default y
	select USE_MCUX_FLEXSPI
	select PINCTRL
	help
	  Enable MSPI controller support on NXP FlexSPI instances.
