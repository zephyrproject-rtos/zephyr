config MDIO_RENESAS_RA
	bool "RENESAS MDIO controller driver"
	default y
	depends on DT_HAS_RENESAS_RA_MDIO_ENABLED
	select PINCTRL
	select USE_RA_FSP_ETHER_PHY
	help
	  Enable RENESAS MDIO support.

config MDIO_RENESAS_RA_RMAC
	bool "RENESAS MDIO RMAC controller driver"
	default y
	depends on DT_HAS_RENESAS_RA_MDIO_RMAC_ENABLED
	select PINCTRL
	help
	  Enable RENESAS MDIO RMAC support.
