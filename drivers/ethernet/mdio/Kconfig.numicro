config MDIO_NUMICRO
	bool "Nuvoton MCU mdio driver"
	default y
	depends on DT_HAS_NUVOTON_NUMICRO_MDIO_ENABLED
	select PINCTRL
	help
	  This option enables MDIO driver for Nuvoton Numicro family of
	  processors.
	  Say y if you wish to enable Numicro MDIO.
