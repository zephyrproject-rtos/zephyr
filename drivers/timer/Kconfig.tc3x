config TC3X_STM
	bool "TC3x System Timer Module (STM) support"
	depends on SOC_SERIES_TC3X
	default y
	select TICKLESS_CAPABLE
	select TIMER_HAS_64BIT_CYCLE_COUNTER
	select SYSTEM_TIMER_HAS_DISABLE_SUPPORT
	help
	  This option enables the system timer driver for the Infineon TC3x
	  System Timer Module as separate modules.
