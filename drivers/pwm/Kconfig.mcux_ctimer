config PWM_MCUX_CTIMER
	bool "MCUX CTimer PWM driver"
	default y
	depends on DT_HAS_NXP_CTIMER_PWM_ENABLED
	select PINCTRL
	select NXP_INPUTMUX if PWM_CAPTURE
	help
	  Enable ctimer based pwm driver.
