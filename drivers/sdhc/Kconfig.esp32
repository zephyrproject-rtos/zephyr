config SDHC_ESP32
	bool "ESP32 SDHC Driver"
	default y
	depends on DT_HAS_ESPRESSIF_ESP32_SDHC_SLOT_ENABLED
	select SDHC_SUPPORTS_NATIVE_MODE
	select PINCTRL
	help
	  Enables the ESP32 SD Host controller driver

if SDHC_ESP32

# DMA buffers must be cache-line aligned on SoCs with L1 data cache
config SDHC_BUFFER_ALIGNMENT
	default DCACHE_LINE_SIZE if DCACHE
	default 4

endif
