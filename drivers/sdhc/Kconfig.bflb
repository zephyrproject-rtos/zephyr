config SDHC_BFLB
	bool "Bouffalo Lab SDHC driver"
	default y
	depends on DT_HAS_BFLB_SDHC_ENABLED
	select SDHC_SUPPORTS_NATIVE_MODE
	select PINCTRL
	help
	  Enable the Bouffalo Lab SD Host Controller driver.

if SDHC_BFLB

config SDHC_BFLB_DMA
	bool "Use DMA for Bouffalo lab SDHC"
	default y
	help
	  Use ADMA2 (DMA system specific to the SDHC controller) instead of polling
	  to transfer data faster.

endif
