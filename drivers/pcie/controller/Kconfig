config PCIE_CONTROLLER
	bool "PCIe Controller management"
	depends on $(dt_chosen_enabled,$(ZEPHYR_PCIE_CONTROLLER))
	depends on PCIE_HOST
	default y
	help
	  Add support for PCIe Controller management when not handled by a
	  system firmware like on x86 platforms.

# zephyr-keep-sorted-start
source "drivers/pcie/controller/Kconfig.brcmstb"
source "drivers/pcie/controller/Kconfig.ecam"
source "drivers/pcie/controller/Kconfig.iproc"
# zephyr-keep-sorted-stop
