config DAC_DAC161S997
	bool "TI DAC161S997 DAC driver"
	default y
	select SPI
	depends on DT_HAS_TI_DAC161S997_ENABLED
	help
	  Enable the driver for the TI DAC161S997.

if DAC_DAC161S997

config DAC_DAC161S997_INIT_PRIORITY
	int "Init priority"
	default 80
	help
	  TI DAC161S997 DAC device driver initialization priority.
	  Must be greater than SPI_INIT_PRIORITY.

endif # DAC_DAC161S997
