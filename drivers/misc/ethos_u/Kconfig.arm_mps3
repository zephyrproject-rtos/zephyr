config ETHOS_U_ARM
	bool "Arm Ethos-U NPU driver"
	default y
	depends on DT_HAS_ARM_ETHOS_U_ENABLED
	help
	  Enables Arm Ethos-U NPU driver.

choice ARM_ETHOS_U_NPU_CONFIG
	default ARM_ETHOS_U55_128
endchoice # ARM_ETHOS_U_NPU_CONFIG
