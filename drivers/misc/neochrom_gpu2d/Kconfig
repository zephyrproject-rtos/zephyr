config NEOCHROM_GPU2D
	bool "STM32 NeoChrom GPU2D support"
	depends on DT_HAS_ST_NEOCHROM_GPU2D_ENABLED && LV_USE_NEMA_GFX
	select RESET
	select USE_STM32_HAL_GPU2D
	help
	  Enable support for STM32 NeoChrom GPU2D accelerator.
	  This driver provides low-level access to the GPU2D hardware
	  and is used by NemaGFX for hardware-accelerated rendering.

if NEOCHROM_GPU2D

config NEOCHROM_GPU2D_INIT_PRIORITY
	int "Neochrom gpu2d device init priority"
	default 90
	help
	  Neochrom gpu2d device initialization priority.

module = NEOCHROM_GPU2D
module-str = neochrom_gpu2d
source "subsys/logging/Kconfig.template.log_config"

endif # NEOCHROM_GPU2D
