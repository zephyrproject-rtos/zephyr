config ADGM3121
	bool "Analog Devices ADGM3121 MEMS switch driver"
	default y
	depends on DT_HAS_ADI_ADGM3121_ENABLED || \
		   DT_HAS_ADI_ADGM3121_GPIO_ENABLED
	depends on SPI || GPIO
	help
	  Enable driver for Analog Devices ADGM3121 (DPDT MEMS switch,
	  DC-24GHz). Supports both SPI and parallel GPIO control modes.

if ADGM3121

config ADGM3121_INIT_PRIORITY
	int "Init priority"
	default 90
	help
	  Analog Devices ADGM3121 MEMS switch driver initialization
	  priority.

module = ADGM3121
module-str = adgm3121
source "subsys/logging/Kconfig.template.log_config"

endif # ADGM3121
