menuconfig GRAPHIC_DRIVERS
	bool "Graphic drivers"
	help
	  Enable support for graphic drivers

if GRAPHIC_DRIVERS

module = GRAPHIC_DRIVERS
module-str = graphic_drivers
source "subsys/logging/Kconfig.template.log_config"

config GRAPHIC_INIT_PRIORITY
	int "Graphic initialization priority"
	default 60
	help
	  System initialization priority for graphic drivers.

# zephyr-keep-sorted-start
source "drivers/graphic/Kconfig.stm32_dma2d"
# zephyr-keep-sorted-stop

endif # GRAPHIC_DRIVERS
