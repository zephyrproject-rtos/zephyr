config WDT_NRF_GSWDT
	bool "Nordic Global Software Watchdog Timer (GSWDT) driver"
	depends on DT_HAS_NORDIC_NRF_GSWDT_ENABLED
	default y
	select MBOX
	select HAS_WDT_NO_CALLBACKS
	help
	  This option enables the Nordic Global Software Watchdog Timer
	  (GSWDT) driver.
