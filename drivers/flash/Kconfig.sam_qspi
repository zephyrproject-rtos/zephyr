# Atmel SAM flash driver config

# Copyright (c) 2026 Eve Redero
# SPDX-License-Identifier: Apache-2.0

config FLASH_SAM_QSPI
	bool "Atmel SAM QSPI flash driver"
	default y
	depends on DT_HAS_ATMEL_SAM_FLASH_QSPI_ENABLED
	select FLASH_HAS_PAGE_LAYOUT
	select FLASH_HAS_DRIVER_ENABLED
	select FLASH_HAS_EXPLICIT_ERASE
	select MPU_ALLOW_FLASH_WRITE if ARM_MPU
	help
	  Enable the Atmel SAM series QSPI flash driver.
