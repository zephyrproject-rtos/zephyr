config PINCTRL_TC3X
	bool "Infineon TC3x pin controller driver"
	default y
	select PINCTRL_STORE_REG
	depends on DT_HAS_INFINEON_TC3X_PINCTRL_ENABLED
	help
	  Enables Infineon TC3x pin controller driver

config PINCTRL_TC4X
	bool "Infineon TC4x pin controller driver"
	default y
	select PINCTRL_STORE_REG
	depends on DT_HAS_INFINEON_TC4X_PINCTRL_ENABLED
	help
	  Enables Infineon TC4x pin controller driver
