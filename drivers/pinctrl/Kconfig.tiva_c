config PINCTRL_TIVA_C
	bool "TI Tiva C Series pinctrl driver"
	default y
	depends on DT_HAS_TI_TIVA_C_PINCTRL_ENABLED
	help
	  Enable pin controller support for TI Tiva C Series
	  (TM4C123G, TM4C129x) microcontrollers.
	  Uses TivaWare driverlib GPIOPinConfigure() and GPIOPinType*().
