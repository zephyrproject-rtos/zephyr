config STEPPER_H_BRIDGE_STEPPER_CTRL
	bool "Activate driver for gpio h-bridge stepper control"
	select GPIO_STEPPER
	depends on DT_HAS_ZEPHYR_H_BRIDGE_STEPPER_CTRL_ENABLED
	default y
