config CAN_MSPM0_CANFD
	bool "MSPM0 CANFD driver"
	default y
	depends on DT_HAS_TI_MSPM0_CANFD_ENABLED
	select CAN_MCAN
	select USE_MSPM0_DL_MCAN
	help
	  Enable support for CANFD on the TI MSPM0 series.

if CAN_MSPM0_CANFD

endif # CAN_MSPM0G3XXX_CANFD
