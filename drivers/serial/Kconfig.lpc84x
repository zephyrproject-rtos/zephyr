config UART_LPC84X
	bool "LPC84x UART driver"
	default y
	depends on DT_HAS_NXP_LPC84X_UART_ENABLED
	select SERIAL_HAS_DRIVER
	select SERIAL_SUPPORT_INTERRUPT
	select UART_USE_RUNTIME_CONFIGURE
	help
	 Enable the LPC84x UART driver.
