# GD32 UART configuration

# Copyright (c) 2016 Open-RnD Sp. z o.o.
# SPDX-License-Identifier: Apache-2.0

config UART_GD32
	bool "GD32 MCU serial driver"
	select SERIAL_HAS_DRIVER
	select SERIAL_SUPPORT_INTERRUPT
	depends on SOC_SERIES_RISCV_GIGADEVICE_GD32V
	help
	  This option enables the UART driver for GD32 family of
	  processors.
	  Say y if you wish to use serial port on GD32 MCU.
