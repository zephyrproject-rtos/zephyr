menuconfig PULSE_IO
	bool "Pulse IO drivers"
	help
	  Enable support for the Pulse IO subsystem, a vendor-neutral
	  abstraction for hardware that generates and captures timed
	  digital edges on a GPIO line.

if PULSE_IO

module = PULSE_IO
module-str = pulse_io
source "subsys/logging/Kconfig.template.log_config"

config PULSE_IO_INIT_PRIORITY
	int "Pulse IO init priority"
	default 80
	help
	  Device driver init priority for Pulse IO devices.

config PULSE_IO_LOOPBACK
	bool "Software loopback Pulse IO backend"
	default y
	depends on DT_HAS_ZEPHYR_PULSE_IO_LOOPBACK_ENABLED
	help
	  Enable the software loopback Pulse IO backend. It loops
	  transmitted symbols back on receive so the subsystem API can
	  be tested without hardware.

endif # PULSE_IO
