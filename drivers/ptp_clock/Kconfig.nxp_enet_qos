config PTP_CLOCK_NXP_ENET_QOS
	bool "NXP ENET QoS PTP Clock driver"
	default y
	depends on DT_HAS_NXP_ENET_QOS_PTP_CLOCK_ENABLED && NET_L2_PTP
	depends on ETH_NXP_ENET_QOS
	help
	  Enable NXP ENET QoS PTP clock support
