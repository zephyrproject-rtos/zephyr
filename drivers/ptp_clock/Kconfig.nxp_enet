config PTP_CLOCK_NXP_ENET
	bool "NXP ENET PTP Clock driver"
	default y
	depends on DT_HAS_NXP_ENET_PTP_CLOCK_ENABLED
	depends on ETH_NXP_ENET
	select NET_L2_PTP_TIMESTAMPING
	select PINCTRL
	help
	  Enable NXP ENET PTP clock to support Ethernet timestamping.
