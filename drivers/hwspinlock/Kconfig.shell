config HWSPINLOCK_SHELL
	bool "HW spinlock shell"
	depends on SHELL
	help
	  Adds a 'hwspinlock' shell command for interacting with HWSPINLOCK
	  controller devices at runtime. Useful for manual testing when the
	  remote side is not running Zephyr.
