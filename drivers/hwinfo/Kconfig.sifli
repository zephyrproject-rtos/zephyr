config HWINFO_SIFLI_SF32LB52X
	bool "SiFli SF32LB52X device ID"
	default y
	depends on SOC_SERIES_SF32LB52X
	depends on OTP && OTP_SIFLI_EFUSE
	select HWINFO_HAS_DRIVER
	help
	  Enable the hwinfo device ID implementation for SiFli SF32LB52X.
	  The device ID is read from the eFuse OTP controller.

