menuconfig BBRAM
	bool "Battery-backed RAM drivers"
	default y
	help
	  Enable BBRAM (battery-backed RAM) driver configuration.

if BBRAM

config BBRAM_INIT_PRIORITY
	int "Init priority"
	default 10
	help
	  BBRAM driver initialization priority

source drivers/bbram/Kconfig.npcx

endif # BBRAM
