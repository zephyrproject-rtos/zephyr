config I2C_BEE
	bool "Realtek Bee series I2C driver"
	default y
	depends on DT_HAS_REALTEK_BEE_I2C_ENABLED
	select HAL_REALTEK_BEE_I2C
	select PINCTRL
	help
	  This option enables the I2C driver for Realtek Bee SoCs.
