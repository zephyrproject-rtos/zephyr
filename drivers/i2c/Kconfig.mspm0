config I2C_MSPM0
	bool "MSPM0 I2C driver"
	default y
	depends on DT_HAS_TI_MSPM0_I2C_ENABLED
	select USE_MSPM0_DL_I2C
	select PINCTRL
	help
	  This option enables the TI MSPM0 I2C driver.

config I2C_SCL_LOW_TIMEOUT_MS
	int "I2C SCL Timeout"
	default 1000
	help
	  Timeout in milliseconds that reflects acceptable
	  cumulative low period in a transaction. Note this
	  can be a restriction on very long SCL stretch

config I2C_TRANSFER_TIMEOUT_MS
	int "I2C Transfer Timeout"
	default 2000
	help
	  Timeout in milliseconds to wait for an I2C
	  transfer to complete before timing out.
