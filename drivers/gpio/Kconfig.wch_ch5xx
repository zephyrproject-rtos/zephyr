config GPIO_WCH_CH5XX
	bool "WCH CH5xx GPIO driver"
	depends on DT_HAS_WCH_CH5XX_GPIO_ENABLED
	default y

config GPIO_WCH_CH5XX_INTERRUPTS
	bool "Interrupt support"
	depends on GPIO_WCH_CH5XX
	depends on DT_HAS_WCH_PFIC_ENABLED
	default y
	help
	  Support triggering an interrupt on pin change.
