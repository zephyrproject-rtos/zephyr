config GPIO_TLA2528
	bool "Texas Instruments TLA2528 ADC with GPIOs"
	default y
	depends on DT_HAS_TI_TLA2528_GPIO_ENABLED
	select MFD
	help
	  Enable the gpio driver implementation for the TLA2528

config GPIO_TLA2528_INIT_PRIO
	int "Init priority"
	default 70
	depends on GPIO_TLA2528
	help
	  Device driver initialization priority.
	  Priority has to be lower (=higher value) than the TLA2528 mfd driver prio.
