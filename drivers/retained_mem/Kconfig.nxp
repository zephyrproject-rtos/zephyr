config RETAINED_MEM_NXP_SNVS_GPR
	bool "NXP i.MX SNVS General Purpose Registers retained memory driver"
	default y
	depends on DT_HAS_NXP_IMX_SNVS_GPR_ENABLED
	help
	  Enable the retained memory driver for the NXP i.MX SNVS Low-Power
	  General Purpose Registers. The bank's base address and size are
	  obtained from the MCUX HAL SNVS_Type definition for the active SoC.
