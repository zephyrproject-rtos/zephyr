config OTP_SUNXI
	bool "Allwinner sunXi SID/eFuse driver"
	default y
	depends on DT_HAS_ALLWINNER_SUNXI_SID_ENABLED
	help
	  Enable Allwinner sunXi Security ID (SID) eFuse driver.
