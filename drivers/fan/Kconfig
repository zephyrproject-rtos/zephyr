menuconfig FAN
	bool "Fan drivers [EXPERIMENTAL]"
	select EXPERIMENTAL
	help
	  Include fan drivers in the system configuration.

if FAN

module = FAN
module-str = fan
source "subsys/logging/Kconfig.template.log_config"

config FAN_INIT_PRIORITY
	int "Fan initialization priority"
	default 90
	help
	  System initialization priority for fan drivers.

rsource "Kconfig.fan_pwm"

endif # FAN
