menuconfig SDIO_DC
	bool "SDIO device controller drivers"
	help
	  Enable the SDIO device controller (slave/peripheral side) driver
	  class. SDIO device controllers answer commands from a remote SDIO
	  host and are the counterpart of SD host controllers (SDHC).

if SDIO_DC

module = SDIO_DC
module-str = SDIO device controller
source "subsys/logging/Kconfig.template.log_config"

config SDIO_DEVICE_INIT_PRIORITY
	int "SDIO device controller init priority"
	default 70
	help
	  Device initialization priority for SDIO device controllers.

endif # SDIO_DC
