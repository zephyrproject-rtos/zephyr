{
  "psa_framework_version": 1.1,
  "name": "TFM_SP_SE",
  "type": "APPLICATION-ROT",
  "priority": "NORMAL",
  "model": "${SPM_BACKEND}",
  "entry_point": "tfm_se_req_mngr_init",
  "stack_size": "0x0800",
