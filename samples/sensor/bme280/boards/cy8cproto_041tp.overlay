&spi1 {
	status = "okay";
	cs-gpios = <&gpio_prt4 0 GPIO_ACTIVE_LOW>;

	bme280@0 {
		compatible = "bosch,bme280";
		reg = <0>;
		spi-max-frequency = <100000>;
	};
};
