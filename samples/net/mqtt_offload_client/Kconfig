# Configuration options for MQTT-OFFLOAD sample

# Copyright (c) 2022 René Beckmann
# SPDX-License-Identifier: Apache-2.0
menu "Mqtt Offload"
mainmenu "MQTT-OFFLOAD sample application"

config NET_SAMPLE_MQTT_OFFLOAD_BUFFER_SIZE
	int "Size of the TX and RX buffers"
	default 255
config MQTT_ENDPOINT
	string "MQTT endpoint"
	default ""
	help
	  Endpoint (hostname) of the MQTT broker.
	  Note that the endpoint is different when using AWS Device Advisor.

config MQTT_PORT
	int "MQTT Port"
	default 8883
	help
	  Set port of MQTT broker.

config MQTT_THING_NAME
	string "MQTT Thing name"
	default "myThingName"
	help
	  Set the MQTT Thing name created on IoT Console

config MQTT_SUBSCRIBE_TOPIC
	string "MQTT subscribe topic"
	default "myThingName/downlink"
	help
	  MQTT topic the client should subscribe to.

config MQTT_PUBLISH_TOPIC
	string "MQTT publish topic"
	default "myThingName/data"
	help
	  MQTT topic the client should publish to.

choice MQTT_TEST_SUITE
	prompt "Device Advisor test suite"
	default MQTT_TEST_SUITE_NONE
	help
	  Select the AWS Device Advisor test suite to run.

config MQTT_TEST_SUITE_NONE
	bool "No test suite running"

config MQTT_TEST_SUITE_DQP
	bool "Device Qualification Program (DQP)"
	help
	  Make sure your region supports AWS Device Advisor for DQP

config MQTT_TEST_SUITE_RECV_QOS1
	bool "Test suite for receiving QoS 1 messages"
	help
	  For single test case "MQTT Client Puack QoS1"

endchoice

config MQTT_LIB_CUSTOM_TRANSPORT
	bool "Custom transport support for socket MQTT Library"
	help
	  Enable custom transport support for socket MQTT Library.
	  User must provide implementation for transport procedure.

config MQTT_OFFLOAD_LIB_TLS
	bool "TLS support for socket MQTT Library"
	help
	  Enable TLS support for socket MQTT Library

config MQTT_QOS
	int "MQTT QoS"
	default 0 if MQTT_TEST_SUITE_DQP
	default 1 if MQTT_TEST_SUITE_RECV_QOS1
	default 0
	range 0 1
	help
	  Quality of Service to use for publishing and subscribing to topics.
	  Notes:
	  - Use QoS 0 when passing DQP test suite
	  - QoS 2 is not supported by AWS MQTT broker


config MQTT_EXPONENTIAL_BACKOFF
	bool "enable exponential backoff"
	default n if MQTT_TEST_SUITE_DQP || MQTT_TEST_SUITE_RECV_QOS1
	default y
	help
	  Enable AWS exponential backoff for reconnecting to AWS MQTT broker.

endmenu

source "samples/net/common/Kconfig"
source "Kconfig.zephyr"
