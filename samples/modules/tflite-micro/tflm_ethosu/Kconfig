config TFLM_ETHOSU_TAINT_BLOBS
	bool
	default y
	select TAINT_BLOBS

config TFLM_ETHOSU_PMU
	bool "Enable Ethos-U PMU counters in sample"
	depends on ETHOS_U
	help
	  Enable Ethos-U PMU counters for this sample. When enabled,
	  the sample collects cycle and selected event counters per inference.

source "Kconfig.zephyr"
