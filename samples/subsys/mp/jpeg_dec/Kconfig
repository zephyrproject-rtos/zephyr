mainmenu "MJPEG decode pipeline"

menu "Pipeline configuration"

config FILE_INPUT_PATH
	string "Input MJPEG file path"
	default "/SD:/test.mjpeg"
	help
	  Absolute path to the MJPEG input file.

config JPEG_IMAGE_WIDTH
	int "Width of the decoded JPEG image"
	default 320

config JPEG_IMAGE_HEIGHT
	int "Height of the decoded JPEG image"
	default 240

config MJPEG_NUM_FRAMES
	int "Number of frames in the generated test MJPEG file"
	default 150
	help
	  Number of video frames to generate in the test MJPEG file.
	  The file is produced at build time using GStreamer CLI.

config VIDEO_ROTATION_ANGLE
	int "Rotate the decoded frame by a specified angle"
	range 0 270
	default 0
	help
	  Specify one of these values {0, 90, 180, 270} in degree to rotate the video frame.
	  Only applies when a zephyr,videotrans device is present.

endmenu

source "Kconfig.zephyr"
