source "Kconfig.zephyr"

choice SAMPLE_AUDIO_SOURCE
	prompt "Capture source the pipeline reads from"
	default SAMPLE_AUDIO_SOURCE_DMIC
	help
	  Which source element the pipeline is built with. The rest of the
	  pipeline is the same either way.

config SAMPLE_AUDIO_SOURCE_DMIC
	bool "Digital microphone"
	help
	  Capture from a PDM microphone through the DMIC API. Requires a
	  dmic_dev node label.

config SAMPLE_AUDIO_SOURCE_I2S
	bool "I2S receiver"
	help
	  Capture from an I2S receiver, either a microphone that outputs I2S
	  directly or a codec's ADC. Requires an i2s-codec-rx alias, and an
	  audio-codec-capture alias when the capture path runs through a codec
	  that has to be configured.

endchoice

config SAMPLE_AUDIO_GAIN_PERCENT
	int "Gain applied by the pipeline (percent)"
	default 90
	range 0 1000
	help
	  Gain the pipeline's gain element applies, as a percentage: 0 mutes,
	  100 is unity and 1000 amplifies ten times. Values above 100 can clip,
	  in which case samples saturate at full scale.

config USE_I2S_TARGET_CODEC_CONTROLLER
	bool "I2S BCK is generated by a selected codec device"
	help
	  If selected, the I2S selected peripheral will be configured to consume
	  (receive) the I2S BCK and WS signals and the codec will be configured
	  to generate those. If not selected, the I2S peripheral will generate
	  them and the codec will be expected to consume them.
