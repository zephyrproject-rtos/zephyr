&zephyr_udc0 {
	status = "disabled";
};

&usbhs {
	pinctrl-0 = <&usbhs_default>;
	pinctrl-names = "default";
	maximum-speed = "high-speed";
	status = "okay";

	zephyr_uhc0: uhc {
		status = "okay";
	};
};
