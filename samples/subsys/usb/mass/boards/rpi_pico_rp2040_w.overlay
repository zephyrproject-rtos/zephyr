/delete-node/ &code_partition;

#include <raspberrypi/partitions_2M_storage.dtsi>

/ {
	msc_disk0 {
		compatible = "zephyr,flash-disk";
		partition = <&storage_partition>;
		disk-name = "NAND";
		cache-size = <4096>;
	};
};
