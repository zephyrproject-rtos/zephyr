&cpuapp_bellboard {
	status = "okay";
};

/ {
	ipc_proxy_agent: ipc-proxy {
		compatible = "zephyr,zbus-proxy-agent-ipc";
		status = "okay";
		ipc-device = <&ipc0>;
	};

	chosen {
		/delete-property/ zephyr,bt-hci;
	};
};
