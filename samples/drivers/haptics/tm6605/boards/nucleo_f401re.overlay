#include <zephyr/dt-bindings/i2c/i2c.h>

&arduino_i2c {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	haptic: tm6605@2d {
		compatible = "titanmec,tm6605";
		reg = <0x2d>;
		status = "okay";
	};
};
