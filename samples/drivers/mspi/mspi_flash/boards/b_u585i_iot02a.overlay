/ {
	aliases {
		/* The sample gets the DT_ALIAS(flash0) as the mspi device */
		flash0 = &mx25lm51245;
	};
};

&mx25lm51245 {
	/* permission = 0 for Rd/Wr */
	xip-config = <1 0 DT_SIZE_M(64) 0>;

	#address-cells = <1>;
	#size-cells = <1>;
	ranges = <0x0 0x70000000 DT_SIZE_M(64)>;
};
