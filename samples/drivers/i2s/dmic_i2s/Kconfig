source "Kconfig.zephyr"

config SAMPLE_FREQ
	int "Sample rate"
	default 16000
	help
	  Sample frequency of the system.

config USE_DMIC
	bool "Use DMIC as an audio input"
	default y

if USE_DMIC

config DMIC_CHANNELS
	int "Number of DMIC channels"
	default 1
	help
	  Count of DMIC & I2S channels to capture and .

endif
