 *
 * Sample devicetree overlay for a fingerprint sensor
 */

/ {
	aliases {
		fingerprint = &as608;
	};
};

&uart1 {
	status = "okay";
	current-speed = <57600>;

	as608: as608 {
		compatible = "synochip,as608";
		status = "okay";
		comm-addr = <0xffffffff>;
	};
};
