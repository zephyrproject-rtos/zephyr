mainmenu "Clock Monitor - Frequency Meter sample"

config SAMPLE_WINDOW_NS
	int "Measurement window duration (ns)"
	default 1000000
	help
	  CMU_FM measurement window in nanoseconds. Longer windows give
	  finer resolution; 1 ms default.

source "Kconfig.zephyr"
